---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InboxPage from '../../components/InboxPage';
---

<BaseLayout title="Inbox" description="Feature ideas and bug reports from users">
  <h1>Inbox</h1>
  <p class="page-desc">
    Messages from the feedback widget — feature ideas and bug reports. Visible only to you as
    superadmin.
  </p>
  <InboxPage client:load />
</BaseLayout>

<style>
  .page-desc {
    color: var(--color-ink-muted);
    margin-bottom: 1.5rem;
    max-width: 40rem;
    line-height: 1.55;
  }

  :global(.inbox-muted),
  :global(.inbox-empty) {
    color: var(--color-ink-muted);
    padding: 1rem 0;
  }
  :global(.inbox-banner),
  :global(.inbox-error) {
    color: var(--color-maroon);
    background: rgba(113, 32, 56, 0.08);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    margin-bottom: 1rem;
  }
  :global(.inbox-toolbar) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem 1rem;
    margin-bottom: 1.25rem;
  }
  :global(.inbox-count) {
    margin: 0;
    font-size: 0.95rem;
    color: var(--color-ink-muted);
  }
  :global(.inbox-filters) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  :global(.inbox-filter) {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: #fff;
    color: var(--color-ink-muted);
    cursor: pointer;
  }
  :global(.inbox-filter.is-active) {
    border-color: var(--color-maroon);
    background: rgba(113, 32, 56, 0.08);
    color: var(--color-maroon);
    font-weight: 600;
  }
  :global(.inbox-list) {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  :global(.inbox-item) {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1rem 1.15rem;
    background: #fff;
  }
  :global(.inbox-item.is-unread) {
    border-color: rgba(113, 32, 56, 0.35);
    box-shadow: inset 3px 0 0 var(--color-maroon);
  }
  :global(.inbox-item-head) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
    font-size: 0.82rem;
    color: var(--color-ink-muted);
  }
  :global(.inbox-kind) {
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    font-size: 0.72rem;
  }
  :global(.inbox-kind-feature) {
    color: #1a5f4a;
  }
  :global(.inbox-kind-bug) {
    color: var(--color-maroon);
  }
  :global(.inbox-subject) {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    margin: 0 0 0.4rem;
    color: var(--color-ink);
  }
  :global(.inbox-body) {
    margin: 0 0 0.75rem;
    white-space: pre-wrap;
    line-height: 1.55;
    color: var(--color-ink);
  }
  :global(.inbox-meta) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.85rem;
    font-size: 0.82rem;
    color: var(--color-ink-muted);
    margin-bottom: 0.85rem;
  }
  :global(.inbox-meta-email) {
    opacity: 0.85;
  }
  :global(.inbox-page-link) {
    color: var(--color-maroon);
  }
  :global(.inbox-actions) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  :global(.inbox-btn) {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    padding: 0.35rem 0.7rem;
    border-radius: 6px;
    border: 1px solid var(--color-border);
    background: var(--color-bg-alt);
    color: var(--color-ink);
    cursor: pointer;
  }
  :global(.inbox-btn:hover:not(:disabled)) {
    border-color: var(--color-maroon-muted);
  }
  :global(.inbox-btn:disabled) {
    opacity: 0.55;
    cursor: default;
  }
  :global(.inbox-btn-danger) {
    color: var(--color-maroon);
  }
</style>
