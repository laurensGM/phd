---
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Process" description="Redirect to LR process">
  <meta http-equiv="refresh" content={`0;url=${base}writing/lr-process/`} />
  <article class="redirect-page">
    <h1>Process</h1>
    <p>This page has moved. <a href={`${base}writing/lr-process/`}>Go to LR process →</a></p>
  </article>
</BaseLayout>

<style>
  .redirect-page {
    padding: 2rem 0;
  }
  .redirect-page a {
    font-weight: 600;
  }
</style>
