---
import BaseLayout from '../../layouts/BaseLayout.astro';
import academics from '../../data/academics.json';
import constructs from '../../data/constructs.json';
import models from '../../data/models.json';

const base = import.meta.env.BASE_URL;

const constructNameToSlug: Record<string, string> = {};
constructs.forEach((c: { name: string; id: string }) => {
  constructNameToSlug[c.name] = c.id;
});

const modelIdToSlug: Record<string, string> = {};
models.forEach((m: { id: string }) => {
  modelIdToSlug[m.id] = m.id;
});

type Academic = {
  id: string;
  name: string;
  bio: string;
  image?: string;
  keyContributions: { title: string; modelId: string; year: number }[];
  keyArticles: { citation: string; doi?: string; description: string }[];
  constructs: string[];
  profilePath?: string;
};

export function getStaticPaths() {
  return (academics as Academic[])
    .filter((a) => !a.profilePath)
    .map((a) => ({
      params: { id: a.id },
      props: { academic: a },
    }));
}

interface Props {
  academic: Academic;
}

const { academic } = Astro.props as Props;
const initials = academic.name
  .split(/\s+/)
  .map((n: string) => n[0])
  .slice(0, 2)
  .join('')
  .toUpperCase();

const title = `${academic.name} — Academics`;
const description = academic.bio.slice(0, 155) + (academic.bio.length > 155 ? '…' : '');
---

<BaseLayout title={title} description={description}>
  <a href={`${base}academics/`} class="academic-detail-back">← Key Academics</a>

  <article class="academic-detail">
    <div class="academic-detail-inner">
      <div class="academic-avatar-wrap">
        {academic.image ? (
          <img
            src={`${base}academics/${academic.image}`}
            alt={academic.name}
            class="academic-avatar academic-avatar-img"
            width="140"
            height="140"
            loading="eager"
            data-initials={initials}
          />
        ) : (
          <span class="academic-avatar academic-avatar-initials" aria-hidden="true">{initials}</span>
        )}
      </div>
      <div class="academic-detail-body">
        <header class="academic-detail-header">
          <h1>{academic.name}</h1>
        </header>

        <section class="academic-bio">
          <h2>Biography</h2>
          <p>{academic.bio}</p>
        </section>

        {academic.keyContributions && academic.keyContributions.length > 0 && (
          <section class="academic-contributions">
            <h2>Theoretical contributions</h2>
            <ul class="contribution-list">
              {academic.keyContributions.map((c: { title: string; modelId: string; year: number }) => {
                const href = modelIdToSlug[c.modelId] ? `${base}models/${c.modelId}/` : '#';
                return (
                  <li>
                    <a href={href} class="contrib-link">{c.title}</a>
                    {c.year ? <span class="contrib-year"> ({c.year})</span> : null}
                  </li>
                );
              })}
            </ul>
          </section>
        )}

        {academic.keyArticles && academic.keyArticles.length > 0 && (
          <section class="academic-articles">
            <h2>Key articles</h2>
            <ul class="article-list">
              {academic.keyArticles.map((art: { citation: string; doi?: string; description: string }) => (
                <li class="article-item">
                  <cite>{art.citation}</cite>
                  {art.doi ? (
                    <a href={`https://doi.org/${art.doi}`} target="_blank" rel="noopener" class="article-doi">
                      DOI
                    </a>
                  ) : null}
                  <p class="article-desc">{art.description}</p>
                </li>
              ))}
            </ul>
          </section>
        )}

        {academic.constructs && academic.constructs.length > 0 && (
          <section class="academic-constructs">
            <h2>Related constructs</h2>
            <div class="construct-chips">
              {academic.constructs.map((name: string) => {
                const slug = constructNameToSlug[name];
                const href = slug ? `${base}constructs/${slug}/` : '#';
                return <a href={href} class="construct-chip">{name}</a>;
              })}
            </div>
          </section>
        )}
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .academic-detail-back {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--color-maroon);
    text-decoration: none;
    font-weight: 500;
  }
  .academic-detail-back:hover {
    text-decoration: underline;
  }
  .academic-detail {
    padding: 0;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    border-left: 4px solid var(--color-maroon);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    max-width: min(820px, 100%);
  }
  .academic-detail-inner {
    display: flex;
    gap: 1.75rem;
    align-items: flex-start;
    padding: 2rem 2.25rem;
  }
  .academic-avatar-wrap {
    flex-shrink: 0;
  }
  .academic-avatar {
    display: block;
    width: 140px;
    height: 140px;
    border-radius: 50%;
    object-fit: cover;
    background: var(--color-bg-alt);
  }
  .academic-avatar-img {
    border: 2px solid var(--color-border);
  }
  .academic-avatar-initials {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--color-maroon);
    border: 2px solid var(--color-border);
    font-family: var(--font-serif);
  }
  .academic-detail-body {
    flex: 1;
    min-width: 0;
  }
  .academic-detail-header h1 {
    font-family: var(--font-serif);
    font-size: 1.85rem;
    margin: 0 0 1.25rem 0;
    color: var(--color-ink);
    line-height: 1.25;
  }
  .academic-detail section {
    margin-bottom: 1.5rem;
  }
  .academic-detail section:last-child {
    margin-bottom: 0;
  }
  .academic-detail h2 {
    font-size: 1.05rem;
    font-weight: 600;
    margin: 0 0 0.5rem 0;
    color: var(--color-maroon);
  }
  .academic-bio p {
    margin: 0;
    line-height: 1.65;
    color: var(--color-ink);
  }
  .contribution-list {
    margin: 0;
    padding-left: 1.25rem;
    line-height: 1.8;
  }
  .contrib-link {
    color: var(--color-maroon);
    font-weight: 500;
  }
  .contrib-link:hover {
    text-decoration: underline;
  }
  .contrib-year {
    color: var(--color-ink-muted);
    font-size: 0.95em;
  }
  .article-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .article-item {
    margin-bottom: 1.25rem;
  }
  .article-item cite {
    font-style: normal;
    font-size: 0.9rem;
    color: var(--color-ink);
    display: block;
  }
  .article-doi {
    font-size: 0.85rem;
    margin-left: 0.25rem;
  }
  .article-desc {
    margin: 0.35rem 0 0 0;
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    line-height: 1.5;
  }
  .construct-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .construct-chip {
    display: inline-block;
    padding: 0.35rem 0.75rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-size: 0.875rem;
    color: var(--color-maroon);
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s;
  }
  .construct-chip:hover {
    background: rgba(113, 32, 56, 0.08);
    border-color: var(--color-maroon-muted);
  }
  @media (max-width: 540px) {
    .academic-detail-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .article-item cite {
      text-align: left;
    }
    .article-desc {
      text-align: left;
    }
    .contribution-list {
      text-align: left;
    }
  }
</style>

<script>
  document.querySelectorAll('.academic-avatar-img').forEach((img) => {
    img.addEventListener('error', () => {
      const initials = img.getAttribute('data-initials') || '?';
      const wrap = img.closest('.academic-avatar-wrap');
      if (wrap) {
        const span = document.createElement('span');
        span.className = 'academic-avatar academic-avatar-initials';
        span.setAttribute('aria-hidden', 'true');
        span.textContent = initials;
        wrap.replaceChild(span, img);
      }
    });
  });
</script>
