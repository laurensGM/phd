---
import BaseLayout from '../../layouts/BaseLayout.astro';
import academics from '../../data/academics.json';
import constructs from '../../data/constructs.json';
import models from '../../data/models.json';

const base = import.meta.env.BASE_URL;

const constructNameToSlug: Record<string, string> = {};
constructs.forEach((c: { name: string; id: string }) => {
  constructNameToSlug[c.name] = c.id;
});

const modelIdToSlug: Record<string, string> = {};
models.forEach((m: { id: string }) => {
  modelIdToSlug[m.id] = m.id;
});
---

<BaseLayout title="Academics" description="Key academic figures - biography, contributions, key articles">
  <h1>Key Academics</h1>
  <p class="page-desc">Key researchers in technology acceptance and IS continuance. Short biographies, theoretical contributions, and links to models and constructs.</p>

  <div class="academics-list">
    {academics.map((academic: {
      id: string;
      name: string;
      bio: string;
      keyContributions: { title: string; modelId: string; year: number }[];
      keyArticles: { citation: string; doi?: string; description: string }[];
      constructs: string[];
    }) => (
      <article class="academic-card">
        <header class="academic-header">
          <h2>{academic.name}</h2>
        </header>

        <section class="academic-bio">
          <h3>Biography</h3>
          <p>{academic.bio}</p>
        </section>

        <section class="academic-contributions">
          <h3>Theoretical contributions</h3>
          <ul class="contribution-list">
            {academic.keyContributions.map((c: { title: string; modelId: string; year: number }) => {
              const model = models.find((m: { id: string }) => m.id === c.modelId);
              const href = modelIdToSlug[c.modelId] ? `${base}models/${c.modelId}/` : '#';
              return (
                <li>
                  <a href={href} class="contrib-link">{c.title}</a>
                  {c.year && <span class="contrib-year"> ({c.year})</span>}
                </li>
              );
            })}
          </ul>
        </section>

        <section class="academic-articles">
          <h3>Key articles</h3>
          <ul class="article-list">
            {academic.keyArticles.map((art: { citation: string; doi?: string; description: string }) => (
              <li class="article-item">
                <cite>{art.citation}</cite>
                {art.doi && (
                  <a href={`https://doi.org/${art.doi}`} target="_blank" rel="noopener" class="article-doi">DOI</a>
                )}
                <p class="article-desc">{art.description}</p>
              </li>
            ))}
          </ul>
        </section>

        {academic.constructs && academic.constructs.length > 0 && (
          <section class="academic-constructs">
            <h3>Related constructs</h3>
            <div class="construct-chips">
              {academic.constructs.map((name: string) => {
                const slug = constructNameToSlug[name];
                const href = slug ? `${base}constructs/${slug}/` : '#';
                return (
                  <a href={href} class="construct-chip">{name}</a>
                );
              })}
            </div>
          </section>
        )}
      </article>
    ))}
  </div>
</BaseLayout>

<style>
  .page-desc {
    color: var(--color-ink-muted);
    margin-bottom: 2.5rem;
    line-height: 1.6;
  }

  .academics-list {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .academic-card {
    padding: 2rem 2.25rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    border-left: 4px solid var(--color-maroon);
    box-shadow: var(--shadow-sm);
  }

  .academic-header h2 {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    margin: 0 0 1.25rem 0;
    color: var(--color-ink);
  }

  .academic-card section {
    margin-bottom: 1.5rem;
  }

  .academic-card section:last-child {
    margin-bottom: 0;
  }

  .academic-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.5rem 0;
    color: var(--color-maroon);
  }

  .academic-bio p {
    margin: 0;
    line-height: 1.65;
    color: var(--color-ink);
  }

  .contribution-list {
    margin: 0;
    padding-left: 1.25rem;
    line-height: 1.8;
  }

  .contrib-link {
    color: var(--color-maroon);
    font-weight: 500;
  }

  .contrib-link:hover {
    text-decoration: underline;
  }

  .contrib-year {
    color: var(--color-ink-muted);
    font-size: 0.95em;
  }

  .article-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .article-item {
    margin-bottom: 1.25rem;
  }

  .article-item cite {
    font-style: normal;
    font-size: 0.9rem;
    color: var(--color-ink);
    display: block;
  }

  .article-doi {
    font-size: 0.85rem;
    margin-left: 0.25rem;
  }

  .article-desc {
    margin: 0.35rem 0 0 0;
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    line-height: 1.5;
  }

  .construct-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .construct-chip {
    display: inline-block;
    padding: 0.35rem 0.75rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-size: 0.875rem;
    color: var(--color-maroon);
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s;
  }

  .construct-chip:hover {
    background: rgba(113, 32, 56, 0.08);
    border-color: var(--color-maroon-muted);
  }
</style>
