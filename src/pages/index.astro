---
import BaseLayout from '../layouts/BaseLayout.astro';
import researchQuestions from '../data/research-questions.json';
import researchObjectives from '../data/research-objectives.json';
import supervisors from '../data/supervisor.json';
import HomeDashboard from '../components/HomeDashboard';
import { abbreviateObjectiveText } from '../lib/abbreviateObjectiveText';

type RQ = { date?: string; question: string };
type Objective = { type: string; status: string; objective: string };
type Supervisor = { name: string; initials?: string; title: string; profileUrl: string };

const latestRq = ([...researchQuestions] as RQ[]).sort((a, b) => (b.date || '').localeCompare(a.date || ''))[0];
const researchTopic = latestRq?.question ?? 'Your research question';

const primaryObjective = (researchObjectives as Objective[]).find(
  (o) => o.type === 'primary' && o.status === 'current'
);
const primaryObjectiveText = primaryObjective
  ? abbreviateObjectiveText(primaryObjective.objective)
  : '';

const supervisorList = supervisors as Supervisor[];
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Home" description="PhD Operating System - Your research topic and stats" deferLoader>
  <div class="homepage">
    <h1>PhD Manager</h1>
    <p class="tagline">Organizing theory, constructs, and literature for doctoral research</p>

    <section class="positioning">
      <h2>Research Focus</h2>
      <p class="research-topic">
        <em>{researchTopic}</em>
      </p>
      <p class="positioning-statement">
        This site tracks theoretical models (TAM, ECM, ECT), their constructs and relationships, literature findings, and the evolution of research questions through the doctoral journey.
      </p>
    </section>

    <section class="home-context-widget" aria-label="Research objective and supervisors">
      <div class="home-objective-card">
        <div class="home-context-card-head">
          <h2 class="home-context-title">Primary research objective</h2>
          <a href={`${base}research-questions/objectives/`} class="home-context-link">Objectives →</a>
        </div>
        {primaryObjectiveText ? (
          <p class="home-objective-text">{primaryObjectiveText}</p>
        ) : (
          <p class="home-objective-text home-objective-empty">No current primary objective set.</p>
        )}
      </div>

      <div class="home-supervisors-card">
        <div class="home-context-card-head">
          <h2 class="home-context-title">Supervisors</h2>
          <a href={`${base}supervisor/`} class="home-context-link">Profiles →</a>
        </div>
        <ul class="home-supervisors-list">
          {supervisorList.map((s) => {
            const initials =
              s.initials ||
              s.name
                .replace(/^Prof\s+/i, '')
                .split(/[\s-]+/)
                .filter(Boolean)
                .map((w) => w[0])
                .join('')
                .slice(0, 3)
                .toUpperCase();
            return (
              <li class="home-supervisor-item">
                <a href={`${base}supervisor/`} class="home-supervisor-link" title={s.title}>
                  <span class="home-supervisor-avatar" aria-hidden="true">{initials}</span>
                  <span class="home-supervisor-meta">
                    <span class="home-supervisor-name">{s.name}</span>
                    <span class="home-supervisor-initials-label">{initials}</span>
                  </span>
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    </section>

    <section class="home-dashboard-section">
      <HomeDashboard client:load />
    </section>
  </div>
</BaseLayout>

<style>
  .homepage {
    max-width: none;
    width: 100%;
  }

  .tagline {
    font-size: 1.1rem;
    color: var(--color-ink-muted);
    margin-bottom: 2rem;
  }

  .positioning {
    margin-bottom: 1.75rem;
  }

  .research-topic {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-style: italic;
    margin-bottom: 1rem;
  }

  .positioning-statement {
    color: var(--color-ink-muted);
  }

  .home-context-widget {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 1rem;
    margin-bottom: 1.75rem;
  }

  .home-objective-card,
  .home-supervisors-card {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.15rem 1.25rem;
  }

  .home-context-card-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.85rem;
  }

  .home-context-title {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-ink);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .home-context-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-maroon);
    white-space: nowrap;
  }

  .home-context-link:hover {
    text-decoration: underline;
  }

  .home-objective-text {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 1.15rem;
    line-height: 1.5;
    color: var(--color-ink);
  }

  .home-objective-empty {
    color: var(--color-ink-muted);
    font-style: italic;
  }

  .home-supervisors-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .home-supervisor-item {
    margin: 0;
  }

  .home-supervisor-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: inherit;
    padding: 0.35rem 0.25rem;
    border-radius: 8px;
    transition: background 0.15s;
  }

  .home-supervisor-link:hover {
    background: rgba(113, 32, 56, 0.05);
    text-decoration: none;
    color: inherit;
  }

  .home-supervisor-avatar {
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: #fff;
    background: var(--color-maroon);
    border: 2px solid var(--color-gold);
  }

  .home-supervisor-meta {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }

  .home-supervisor-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-ink);
    line-height: 1.3;
  }

  .home-supervisor-initials-label {
    font-size: 0.8rem;
    color: var(--color-ink-muted);
    font-weight: 600;
  }

  @media (max-width: 800px) {
    .home-context-widget {
      grid-template-columns: 1fr;
    }
  }

  .home-dashboard-section {
    margin-top: 0.5rem;
  }

  :global(.home-dashboard) {
    margin-bottom: 2rem;
  }

  :global(.home-dashboard-loading),
  :global(.home-dashboard-error) {
    padding: 1rem;
    color: var(--color-ink-muted);
  }

  :global(.home-dashboard-error) {
    color: var(--color-error, #b91c1c);
    background: #fef2f2;
    border-radius: 8px;
  }

  :global(.home-stats-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }

  :global(.home-stat-card) {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.5rem 1rem;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
  }

  :global(.home-stat-card:hover) {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    text-decoration: none;
    color: inherit;
    border-color: var(--color-gold);
  }

  :global(.home-stat-value) {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-ink);
  }

  :global(.home-stat-label) {
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    margin-top: 0.25rem;
    text-align: center;
  }

  :global(.home-stat-snippets-processed) {
    border-left: 4px solid #15803d;
    background: linear-gradient(to right, rgba(22, 101, 52, 0.06), #fff 40%);
  }

  :global(.home-section-title) {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 1rem 0;
  }

  :global(.home-top-row) {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 1rem;
    margin-bottom: 1.75rem;
    align-items: stretch;
  }

  @media (max-width: 800px) {
    :global(.home-top-row) {
      grid-template-columns: 1fr;
    }
  }

  :global(.home-tasks-section) {
    margin: 0;
    padding: 1.15rem 1.25rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  :global(.home-tasks-header) {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.85rem;
  }

  :global(.home-tasks-header .home-section-title) {
    margin: 0;
  }

  :global(.home-tasks-chart) {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
  }

  :global(.home-tasks-bars) {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: flex-end;
    gap: 0.5rem;
    flex: 1;
    min-height: 9rem;
  }

  :global(.home-tasks-bar-col) {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
  }

  :global(.home-tasks-bar-stack) {
    flex: 1;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    gap: 0.25rem;
    min-height: 0;
  }

  :global(.home-tasks-bar-label) {
    margin-top: 0.45rem;
    color: var(--color-ink);
    font-size: 0.72rem;
    font-weight: 500;
    text-align: center;
    line-height: 1.2;
  }

  :global(.home-tasks-bar-fill) {
    display: block;
    width: 72%;
    max-width: 2.75rem;
    border-radius: 6px 6px 0 0;
    min-height: 4px;
    transition: height 0.2s ease;
  }

  :global(.home-tasks-bar-fill-empty) {
    min-height: 3px;
    opacity: 0.2;
  }

  :global(.home-tasks-bar-count) {
    font-weight: 600;
    color: var(--color-ink-muted);
    font-variant-numeric: tabular-nums;
    font-size: 0.78rem;
    line-height: 1;
  }

  :global(.home-tasks-bar-total) {
    margin: 0.5rem 0 0;
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.8rem;
    color: var(--color-ink-muted);
  }

  :global(.home-timeline-section) {
    margin: 0;
    padding: 1.15rem 1.25rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    min-width: 0;
  }

  :global(.home-timeline-header) {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.85rem;
  }

  :global(.home-timeline-header .home-section-title) {
    margin: 0;
  }

  /* Papers by publication year histogram */
  :global(.home-papers-histogram-section) {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  :global(.home-papers-histogram-header) {
    margin-bottom: 1rem;
  }

  :global(.home-papers-histogram-header .home-section-title) {
    margin-bottom: 0.35rem;
  }

  :global(.home-papers-histogram-subtitle),
  :global(.home-papers-histogram-empty) {
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    line-height: 1.45;
  }

  :global(.home-papers-histogram-wrap) {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: 1fr auto;
    gap: 0.35rem 0.5rem;
    align-items: stretch;
  }

  :global(.home-papers-histogram-y-label) {
    grid-row: 1;
    grid-column: 1;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-ink-muted);
    text-align: center;
    justify-self: center;
    padding: 0.25rem 0;
  }

  :global(.home-papers-histogram-chart) {
    grid-row: 1;
    grid-column: 2;
    display: flex;
    gap: 0.5rem;
    min-height: 200px;
    overflow-x: auto;
    padding-bottom: 0.25rem;
  }

  :global(.home-papers-histogram-x-axis-label) {
    grid-row: 2;
    grid-column: 2;
    text-align: center;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-ink-muted);
    padding-top: 0.15rem;
  }

  :global(.home-papers-histogram-y-axis) {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    flex-shrink: 0;
    width: 1.75rem;
    padding-bottom: 1.35rem;
    font-size: 0.72rem;
    color: var(--color-ink-muted);
    font-variant-numeric: tabular-nums;
    text-align: right;
  }

  :global(.home-papers-histogram-y-tick) {
    line-height: 1;
  }

  :global(.home-papers-histogram-plot) {
    position: relative;
    flex: 1;
    min-width: min(100%, 480px);
  }

  :global(.home-papers-histogram-grid) {
    position: absolute;
    inset: 0 0 1.35rem 0;
    pointer-events: none;
  }

  :global(.home-papers-histogram-gridline) {
    position: absolute;
    left: 0;
    right: 0;
    border-top: 1px dashed #e5e7eb;
  }

  :global(.home-papers-histogram-bars) {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: flex-end;
    gap: 0.35rem;
    height: 100%;
    min-height: 200px;
    padding-bottom: 1.35rem;
  }

  :global(.home-papers-histogram-bar-col) {
    flex: 1 1 0;
    min-width: 2rem;
    max-width: 3.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
  }

  :global(.home-papers-histogram-bar-stack) {
    flex: 1;
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 0;
  }

  :global(.home-papers-histogram-bar) {
    width: 100%;
    min-height: 3px;
    background: var(--color-maroon);
    border-radius: 4px 4px 0 0;
    position: relative;
    display: flex;
    justify-content: center;
    transition: background 0.15s;
  }

  :global(.home-papers-histogram-bar:hover) {
    background: var(--color-maroon-dark);
  }

  :global(.home-papers-histogram-bar-empty) {
    min-height: 0;
    background: transparent;
    pointer-events: none;
  }

  :global(.home-papers-histogram-bar-empty:hover) {
    background: transparent;
  }

  :global(.home-papers-histogram-bar-value) {
    position: absolute;
    top: -1.1rem;
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--color-ink-muted);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  :global(.home-papers-histogram-x-label) {
    margin-top: 0.35rem;
    font-size: 0.72rem;
    color: var(--color-ink-muted);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  /* Paper field / journal pie charts */
  :global(.home-paper-pies-section) {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  :global(.home-paper-pies-header) {
    margin-bottom: 1.25rem;
  }

  :global(.home-paper-pies-header .home-section-title) {
    margin-bottom: 0.35rem;
  }

  :global(.home-paper-pies-note) {
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    line-height: 1.45;
  }

  :global(.home-paper-pies-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  :global(.home-paper-pie-card) {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1.25rem;
    background: var(--color-bg-alt);
  }

  :global(.home-paper-pie-title) {
    margin: 0 0 0.25rem 0;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-ink);
  }

  :global(.home-paper-pie-subtitle) {
    margin: 0 0 1rem 0;
    font-size: 0.78rem;
    color: var(--color-ink-muted);
    line-height: 1.4;
  }

  :global(.home-paper-pie-empty) {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-ink-muted);
  }

  :global(.home-paper-pie-body) {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: 1.25rem;
  }

  :global(.home-paper-pie-chart) {
    width: 150px;
    height: 150px;
    border-radius: 50%;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  :global(.home-paper-pie-hole) {
    width: 92px;
    height: 92px;
    border-radius: 50%;
    background: white;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    box-shadow: inset 0 0 0 1px var(--color-border);
  }

  :global(.home-paper-pie-value) {
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1.1;
    color: var(--color-ink);
  }

  :global(.home-paper-pie-label) {
    font-size: 0.65rem;
    color: var(--color-ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  :global(.home-paper-pie-legend) {
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 1;
    min-width: 160px;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    max-height: 240px;
    overflow-y: auto;
  }

  :global(.home-paper-pie-legend-item) {
    display: grid;
    grid-template-columns: 11px 1fr auto;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.82rem;
  }

  :global(.home-paper-pie-legend-swatch) {
    width: 11px;
    height: 11px;
    border-radius: 3px;
  }

  :global(.home-paper-pie-legend-label) {
    color: var(--color-ink);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :global(.home-paper-pie-legend-count) {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    font-weight: 600;
    color: var(--color-ink);
    font-variant-numeric: tabular-nums;
    line-height: 1.2;
  }

  :global(.home-paper-pie-legend-pct) {
    font-size: 0.68rem;
    font-weight: 500;
    color: var(--color-ink-muted);
  }

  /* Snippet tag charts */
  :global(.home-snippet-charts-section) {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  :global(.home-snippet-charts-header) {
    margin-bottom: 1.25rem;
  }

  :global(.home-snippet-charts-header .home-section-title) {
    margin-bottom: 0.35rem;
  }

  :global(.home-snippet-charts-note) {
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    line-height: 1.45;
  }

  :global(.home-snippet-charts-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  :global(.home-snippet-chart-card) {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1.25rem;
    background: var(--color-bg-alt);
  }

  :global(.home-snippet-chart-title) {
    margin: 0 0 0.25rem 0;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-ink);
  }

  :global(.home-snippet-chart-subtitle) {
    margin: 0 0 1rem 0;
    font-size: 0.8rem;
    color: var(--color-ink-muted);
  }

  :global(.home-snippet-chart-empty) {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-ink-muted);
  }

  :global(.home-snippet-chart-bars) {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-height: 280px;
    overflow-y: auto;
  }

  :global(.home-snippet-chart-bar-row) {
    display: grid;
    grid-template-columns: minmax(5rem, 38%) 1fr auto;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
  }

  :global(.home-snippet-chart-bar-label) {
    color: var(--color-ink);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :global(.home-snippet-chart-bar-track) {
    height: 0.65rem;
    background: #e5e7eb;
    border-radius: 999px;
    overflow: hidden;
  }

  :global(.home-snippet-chart-bar-fill) {
    display: block;
    height: 100%;
    border-radius: 999px;
    min-width: 3px;
    transition: width 0.2s ease;
  }

  :global(.home-snippet-chart-bar-count) {
    font-weight: 600;
    color: var(--color-ink-muted);
    font-variant-numeric: tabular-nums;
    min-width: 1.5rem;
    text-align: right;
  }

  /* Milestones timeline (shared item styles; section chrome is in .home-top-row) */
  :global(.home-top-row .home-timeline-section) {
