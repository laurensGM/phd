---
import BaseLayout from '../layouts/BaseLayout.astro';
import researchQuestions from '../data/research-questions.json';
import HomeDashboard from '../components/HomeDashboard';

type RQ = { date?: string; question: string };
const latestRq = ([...researchQuestions] as RQ[]).sort((a, b) => (b.date || '').localeCompare(a.date || ''))[0];
const researchTopic = latestRq?.question ?? 'Your research question';
---

<BaseLayout title="Home" description="PhD Operating System - Your research topic and stats">
  <div class="homepage">
    <h1>PhD Manager</h1>
    <p class="tagline">Organizing theory, constructs, and literature for doctoral research</p>

    <section class="positioning">
      <h2>Research Focus</h2>
      <p class="research-topic">
        <em>{researchTopic}</em>
      </p>
      <p class="positioning-statement">
        This site tracks theoretical models (TAM, ECM, ECT), their constructs and relationships, literature findings, and the evolution of research questions through the doctoral journey.
      </p>
    </section>

    <section class="home-dashboard-section">
      <HomeDashboard client:load />
    </section>
  </div>
</BaseLayout>

<style>
  .homepage {
    max-width: 720px;
  }

  .tagline {
    font-size: 1.1rem;
    color: var(--color-ink-muted);
    margin-bottom: 2rem;
  }

  .positioning {
    margin-bottom: 2.5rem;
  }

  .research-topic {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-style: italic;
    margin-bottom: 1rem;
  }

  .positioning-statement {
    color: var(--color-ink-muted);
  }

  .home-dashboard-section {
    margin-top: 2rem;
  }

  :global(.home-dashboard) {
    margin-bottom: 2rem;
  }

  :global(.home-dashboard-loading),
  :global(.home-dashboard-error) {
    padding: 1rem;
    color: var(--color-ink-muted);
  }

  :global(.home-dashboard-error) {
    color: var(--color-error, #b91c1c);
    background: #fef2f2;
    border-radius: 8px;
  }

  :global(.home-stats-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }

  :global(.home-stat-card) {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.5rem 1rem;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
  }

  :global(.home-stat-card:hover) {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    text-decoration: none;
    color: inherit;
    border-color: var(--color-gold);
  }

  :global(.home-stat-value) {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-ink);
  }

  :global(.home-stat-label) {
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    margin-top: 0.25rem;
    text-align: center;
  }

  :global(.home-papers-chart) {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
  }

  :global(.home-section-title) {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 1rem 0;
  }

  :global(.home-pie-legend) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 2rem;
  }

  :global(.home-pie-chart) {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  :global(.home-pie-legend-list) {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  :global(.home-pie-legend-item) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
  }

  :global(.home-pie-legend-swatch) {
    width: 12px;
    height: 12px;
    border-radius: 3px;
    flex-shrink: 0;
  }

  :global(.home-pie-legend-label) {
    color: var(--color-ink);
  }

  :global(.home-pie-legend-count) {
    margin-left: auto;
    font-weight: 600;
    color: var(--color-ink-muted);
  }

  /* Milestones timeline */
  :global(.home-timeline-section) {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    margin-top: 1.5rem;
  }

  :global(.home-timeline-header) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  :global(.home-timeline-link) {
    font-size: 0.875rem;
    color: var(--color-maroon);
    text-decoration: none;
  }

  :global(.home-timeline-link:hover) {
    text-decoration: underline;
  }

  :global(.home-timeline) {
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
    padding-left: 0;
  }

  :global(.home-timeline-item) {
    display: grid;
    grid-template-columns: auto 12px 1fr;
    gap: 0 0.75rem;
    padding-bottom: 1rem;
    position: relative;
    align-items: center;
  }

  :global(.home-timeline-item:last-child) {
    padding-bottom: 0;
  }

  :global(.home-timeline-item)::before {
    content: '';
    position: absolute;
    left: 5px;
    top: 22px;
    bottom: 0;
    width: 2px;
    background: var(--color-border);
  }

  :global(.home-timeline-item:last-child)::before {
    display: none;
  }

  :global(.home-timeline-date) {
    grid-column: 1;
    font-size: 0.8rem;
    color: var(--color-ink-muted);
    white-space: nowrap;
  }

  :global(.home-timeline-dot) {
    grid-column: 2;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-border);
    position: relative;
    z-index: 1;
  }

  :global(.home-timeline-content) {
    grid-column: 3;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  :global(.home-timeline-title) {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-ink);
  }

  :global(.home-timeline-past .home-timeline-title) {
    color: var(--color-ink-muted);
  }

  :global(.home-timeline-past .home-timeline-dot) {
    background: var(--color-ink-muted);
    opacity: 0.6;
  }

  :global(.home-timeline-next .home-timeline-dot) {
    background: var(--color-maroon);
    box-shadow: 0 0 0 3px rgba(128, 0, 0, 0.2);
  }

  :global(.home-timeline-next .home-timeline-title) {
    font-weight: 600;
    color: var(--color-maroon);
  }

  :global(.home-timeline-badge) {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: white;
    background: var(--color-maroon);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
  }
</style>
