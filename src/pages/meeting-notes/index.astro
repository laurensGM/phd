---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MeetingNotesPage from '../../components/MeetingNotesPage';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Meeting notes" description="Official meeting notes - date, title, content, participants, location">
  <p class="back-link"><a href={`${base}manager/`}>← Manager</a></p>
  <h1>Meeting notes</h1>
  <p class="page-desc">Record official meetings with date, title, content, participants, and location. Add, edit, or delete notes below (saved in Supabase).</p>

  <MeetingNotesPage client:load />
</BaseLayout>

<style>
  .back-link {
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }
  .back-link a {
    color: var(--color-maroon);
  }
  .page-desc {
    color: var(--color-ink-muted);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  /* Meeting notes (React) – design aligned with Diary */
  :global(.meeting-notes-page .meeting-notes-add-section) {
    margin-bottom: 3rem;
    padding: 2rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    box-shadow: var(--shadow-sm);
  }
  :global(.meeting-notes-page .meeting-notes-add-btn) {
    margin-bottom: 2rem;
    padding: 0.65rem 1.25rem;
    background: var(--color-maroon);
    color: #fff;
    border: 2px solid var(--color-gold);
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    font-size: 0.95rem;
    transition: background 0.2s, border-color 0.2s;
  }
  :global(.meeting-notes-page .meeting-notes-add-btn:hover) {
    background: var(--color-maroon-dark);
    border-color: var(--color-gold-light);
  }

  :global(.meeting-notes-page .meeting-notes-form) {
    max-width: 960px;
    padding: 2.5rem 3rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    border-left: 4px solid var(--color-maroon);
    box-shadow: var(--shadow-sm);
  }
  :global(.meeting-notes-page .meeting-notes-form-title) {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    color: var(--color-ink);
    margin: 0 0 0.5rem 0;
  }
  :global(.meeting-notes-page .meeting-notes-form-row) {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }
  :global(.meeting-notes-page .meeting-notes-form-row .meeting-notes-form-field) {
    flex: 1;
    min-width: 140px;
  }
  :global(.meeting-notes-page .meeting-notes-form-field) {
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  :global(.meeting-notes-page .meeting-notes-form-field-details) {
    margin-bottom: 3.5rem;
    gap: 1.25rem;
  }
  :global(.meeting-notes-page .meeting-notes-form-field label),
  :global(.meeting-notes-page .meeting-notes-form-label) {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-ink);
  }

  :global(.meeting-notes-page .meeting-notes-format-hint) {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.45;
    color: var(--color-ink-muted);
  }
  :global(.meeting-notes-page .meeting-notes-format-hint kbd) {
    display: inline-block;
    padding: 0.1rem 0.35rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: #f7f5f2;
    font-size: 0.8rem;
    font-family: var(--font-sans);
  }
  :global(.meeting-notes-page .meeting-notes-format-hint code) {
    font-size: 0.85rem;
  }

  :global(.meeting-notes-page .meeting-notes-input),
  :global(.meeting-notes-page .meeting-notes-textarea) {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 2px solid var(--color-border);
    border-radius: 8px;
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-ink);
    background: #fff;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }
  :global(.meeting-notes-page .meeting-notes-input:focus),
  :global(.meeting-notes-page .meeting-notes-textarea:focus) {
    outline: none;
    border-color: var(--color-maroon);
    box-shadow: 0 0 0 3px rgba(113, 32, 56, 0.12);
  }
  :global(.meeting-notes-page .meeting-notes-input::placeholder),
  :global(.meeting-notes-page .meeting-notes-textarea::placeholder) {
    color: var(--color-ink-muted);
    opacity: 0.8;
  }
  :global(.meeting-notes-page .meeting-notes-textarea) {
    min-height: 260px;
    resize: vertical;
    line-height: 1.6;
  }

  :global(.meeting-notes-page .meeting-notes-submit) {
    margin-top: 1.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--color-maroon);
    color: #fff;
    border: 2px solid var(--color-gold);
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    font-size: 1rem;
    transition: background 0.2s, border-color 0.2s;
  }
  :global(.meeting-notes-page .meeting-notes-submit:hover:not(:disabled)) {
    background: var(--color-maroon-dark);
    border-color: var(--color-gold-light);
  }
  :global(.meeting-notes-page .meeting-notes-submit:disabled) {
    opacity: 0.7;
    cursor: not-allowed;
  }

  :global(.meeting-notes-page .meeting-notes-filters) {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  :global(.meeting-notes-page .meeting-notes-search) {
    flex: 1;
    min-width: 200px;
    padding: 0.65rem 1rem;
    border: 2px solid var(--color-border);
    border-radius: 8px;
    font-size: 0.95rem;
  }
  :global(.meeting-notes-page .meeting-notes-search:focus) {
    outline: none;
    border-color: var(--color-maroon);
  }
  :global(.meeting-notes-page .meeting-notes-date) {
    padding: 0.65rem 1rem;
    border: 2px solid var(--color-border);
    border-radius: 8px;
    font-size: 0.95rem;
  }

  :global(.meeting-notes-page .meeting-notes-history-section) {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
  :global(.meeting-notes-page .meeting-notes-history-title) {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--color-border);
    color: var(--color-ink);
  }
  :global(.meeting-notes-page .meeting-notes-entries) {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  :global(.meeting-notes-page .meeting-notes-entry) {
    padding: 0;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    box-shadow: var(--shadow-sm);
    transition: border-color 0.2s, box-shadow 0.2s;
    overflow: hidden;
  }
  :global(.meeting-notes-page .meeting-notes-entry:hover),
  :global(.meeting-notes-page .meeting-notes-entry.is-open) {
    border-color: var(--color-maroon-muted);
    box-shadow: var(--shadow-md);
  }
  :global(.meeting-notes-page .meeting-notes-entry-summary) {
    display: grid;
    grid-template-columns: auto minmax(6.5rem, auto) minmax(0, 1.4fr) minmax(0, 1fr);
    align-items: center;
    gap: 0.75rem 1rem;
    width: 100%;
    padding: 0.85rem 1.1rem;
    margin: 0;
    border: none;
    background: transparent;
    text-align: left;
    cursor: pointer;
    font: inherit;
    color: inherit;
  }
  :global(.meeting-notes-page .meeting-notes-entry-summary:hover) {
    background: rgba(113, 32, 56, 0.04);
  }
  :global(.meeting-notes-page .meeting-notes-entry-summary:focus-visible) {
    outline: 2px solid var(--color-maroon);
    outline-offset: -2px;
  }
  :global(.meeting-notes-page .meeting-notes-entry-chevron) {
    color: var(--color-maroon);
    font-size: 0.85rem;
    width: 1rem;
    text-align: center;
  }
  :global(.meeting-notes-page .meeting-notes-entry-date) {
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    white-space: nowrap;
  }
  :global(.meeting-notes-page .meeting-notes-entry-title) {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-ink);
    line-height: 1.35;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  :global(.meeting-notes-page .meeting-notes-entry-participants) {
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  :global(.meeting-notes-page .meeting-notes-entry-detail) {
    padding: 0 1.1rem 1.15rem;
    border-top: 1px solid var(--color-border);
  }
  :global(.meeting-notes-page .meeting-notes-entry-detail-bar) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-top: 0.85rem;
    margin-bottom: 0.75rem;
  }
  :global(.meeting-notes-page .meeting-notes-entry-meta) {
    font-size: 0.9rem;
    margin: 0;
    color: var(--color-ink-muted);
  }
  :global(.meeting-notes-page .meeting-notes-entry-empty-content) {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    font-style: italic;
  }
  :global(.meeting-notes-page .meeting-notes-entry-reflection) {
    margin: 0;
    color: var(--color-ink-muted);
    line-height: 1.6;
    font-size: 0.95rem;
  }
  :global(.meeting-notes-page .meeting-notes-entry-reflection .fmt-text-block) {
    display: block;
  }
  :global(.meeting-notes-page .meeting-notes-entry-reflection .fmt-text-block + .fmt-bullet-list),
  :global(.meeting-notes-page .meeting-notes-entry-reflection .fmt-bullet-list + .fmt-text-block) {
    margin-top: 0.5rem;
  }
  :global(.meeting-notes-page .meeting-notes-entry-reflection .fmt-bullet-list) {
    margin: 0.35rem 0;
    padding-left: 1.25rem;
  }
  :global(.meeting-notes-page .meeting-notes-entry-reflection .fmt-bullet-list ul) {
    margin: 0.2rem 0;
    padding-left: 1.15rem;
  }
  :global(.meeting-notes-page .meeting-notes-entry-reflection .fmt-bullet-list li) {
    margin: 0.15rem 0;
  }
  :global(.meeting-notes-page .meeting-notes-entry-reflection strong) {
    color: var(--color-ink);
    font-weight: 700;
  }
  :global(.meeting-notes-page .meeting-notes-entry-actions) {
    display: flex;
    gap: 0.5rem;
    margin-left: auto;
  }
  :global(.meeting-notes-page .meeting-notes-entry-action) {
    padding: 0.3rem 0.6rem;
    font-size: 0.85rem;
    font-weight: 600;
    border: 1px solid var(--color-border);
    background: #fff;
    border-radius: 6px;
    cursor: pointer;
    color: var(--color-ink);
    transition: border-color 0.2s, background 0.2s, color 0.2s;
  }
  :global(.meeting-notes-page .meeting-notes-entry-action:hover:not(:disabled)) {
    border-color: var(--color-maroon-muted);
    background: rgba(113, 32, 56, 0.06);
  }
  :global(.meeting-notes-page .meeting-notes-entry-action-delete:hover:not(:disabled)) {
    border-color: var(--color-maroon);
    color: var(--color-maroon);
  }

  @media (max-width: 720px) {
    :global(.meeting-notes-page .meeting-notes-entry-summary) {
      grid-template-columns: auto 1fr;
      grid-template-areas:
        "chevron date"
        "chevron title"
        "chevron participants";
      gap: 0.2rem 0.75rem;
    }
    :global(.meeting-notes-page .meeting-notes-entry-chevron) {
      grid-area: chevron;
      align-self: start;
      padding-top: 0.15rem;
    }
    :global(.meeting-notes-page .meeting-notes-entry-date) {
      grid-area: date;
    }
    :global(.meeting-notes-page .meeting-notes-entry-title) {
      grid-area: title;
      white-space: normal;
    }
    :global(.meeting-notes-page .meeting-notes-entry-participants) {
      grid-area: participants;
      white-space: normal;
    }
  }

  :global(.meeting-notes-page .meeting-notes-edit-form) {
    padding: 1.15rem 1.25rem;
  }
  :global(.meeting-notes-page .meeting-notes-edit-form .meeting-notes-form-row) {
    margin-bottom: 1.5rem;
  }
  :global(.meeting-notes-page .meeting-notes-edit-actions) {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
  }
  :global(.meeting-notes-page .meeting-notes-btn) {
    padding: 0.5rem 1rem;
    font-size: 0.9rem;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }
  :global(.meeting-notes-page .meeting-notes-btn-primary) {
    background: var(--color-maroon);
    color: #fff;
    border: 2px solid var(--color-gold);
  }
  :global(.meeting-notes-page .meeting-notes-btn-primary:hover:not(:disabled)) {
    background: var(--color-maroon-dark);
    border-color: var(--color-gold-light);
  }
  :global(.meeting-notes-page .meeting-notes-btn-secondary) {
    background: #fff;
    color: var(--color-ink);
    border: 2px solid var(--color-border);
  }
  :global(.meeting-notes-page .meeting-notes-btn-secondary:hover) {
    border-color: var(--color-maroon-muted);
    background: rgba(113, 32, 56, 0.06);
  }

  :global(.meeting-notes-page .meeting-notes-setup) {
    max-width: 480px;
    padding: 2rem 2.5rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    border-left: 4px solid var(--color-gold);
  }
  :global(.meeting-notes-page .meeting-notes-setup-hint) {
    font-size: 0.9rem;
    margin-top: 1rem;
    color: var(--color-ink-muted);
  }
  :global(.meeting-notes-page .meeting-notes-setup code),
  :global(.meeting-notes-page .meeting-notes-setup-hint code) {
    background: var(--color-bg-alt);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-size: 0.85rem;
  }
  :global(.meeting-notes-page .meeting-notes-loading) {
    padding: 2.5rem;
    color: var(--color-ink-muted);
    text-align: center;
  }
  :global(.meeting-notes-page .meeting-notes-error) {
    color: var(--color-maroon);
    font-size: 0.95rem;
    margin-bottom: 1.25rem;
    padding: 1rem 1.25rem;
    background: rgba(113, 32, 56, 0.08);
    border-radius: 8px;
    border-left: 4px solid var(--color-maroon);
  }
  :global(.meeting-notes-page .meeting-notes-empty) {
    color: var(--color-ink-muted);
    padding: 2.5rem;
    text-align: center;
    font-size: 0.95rem;
  }
  :global(.meeting-notes-page .meeting-notes-entry-count) {
    font-weight: 400;
    color: var(--color-ink-muted);
    font-size: 0.95rem;
  }
</style>
