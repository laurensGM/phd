---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FieldJournalsSection, { type FieldJournalItem } from '../../components/FieldJournalsSection';
import fields from '../../data/fields.json';

export function getStaticPaths() {
  return fields.map((f: { id: string }) => ({ params: { id: f.id } }));
}

const { id } = Astro.params;
const field = fields.find((f: { id: string }) => f.id === id);
const base = import.meta.env.BASE_URL;

function categoryLabel(cat: string) {
  if (cat === 'primary') return 'Primary field';
  if (cat === 'secondary') return 'Secondary field';
  if (cat === 'peripheral') return 'Peripheral field';
  return cat;
}

type JournalEntry =
  | string
  | {
      name: string;
      url?: string;
      note?: string;
      matchNames?: string[];
    };

function normalizeJournalEntry(entry: JournalEntry): FieldJournalItem {
  if (typeof entry === 'string') return { name: entry };
  return {
    name: entry.name,
    url: entry.url,
    note: entry.note,
    matchNames: entry.matchNames,
  };
}

if (!field) {
  return Astro.redirect(`${base}fields/`);
}

const journalItems: FieldJournalItem[] = (field.journals ?? []).map(normalizeJournalEntry);
---

<BaseLayout title={field.name} description={field.description}>
  <article class="field-detail">
    <header>
      <a href={`${base}fields/`} class="back-link">← All Fields</a>
      <h1>{field.name}</h1>
      <span class="field-detail-category field-detail-category--{field.category}">{categoryLabel(field.category)}</span>
    </header>

    <section class="field-description">
      {field.description.split('\n\n').map((paragraph: string) => (
        <p>{paragraph}</p>
      ))}
    </section>

    {journalItems.length > 0 && (
      <FieldJournalsSection client:load journals={journalItems} base={base} />
    )}
  </article>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }
  .back-link { color: var(--color-maroon); }

  .field-detail header {
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .field-detail h1 {
    margin: 0 0 0.5rem 0;
    font-size: 1.75rem;
  }

  .field-detail-category {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    border-radius: 6px;
  }
  .field-detail-category--primary {
    background: rgba(92, 29, 42, 0.12);
    color: var(--color-maroon);
  }
  .field-detail-category--secondary {
    background: var(--color-bg-alt);
    color: var(--color-ink-muted);
  }
  .field-detail-category--peripheral {
    background: var(--color-bg-alt);
    color: var(--color-ink-muted);
  }

  .field-description {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-ink);
  }
  .field-description p {
    margin: 0;
  }
  .field-description p + p {
    margin-top: 1.25rem;
  }

  :global(.field-journals) {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }
  :global(.field-journals h2) {
    font-size: 1.2rem;
    color: var(--color-maroon);
    margin: 0 0 0.75rem 0;
  }
  :global(.journals-list) {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  :global(.journal-entry) {
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  :global(.journal-entry:last-child) {
    border-bottom: none;
  }
  :global(.journal-entry-header) {
    margin-bottom: 0.35rem;
  }
  :global(.journal-link),
  :global(.journal-name) {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-maroon);
  }
  :global(.journal-link) {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    text-decoration: none;
  }
  :global(.journal-link:hover) {
    text-decoration: underline;
  }
  :global(.journal-link-icon) {
    font-size: 0.85rem;
    opacity: 0.75;
  }
  :global(.journal-note) {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
  }

  :global(.journal-saved-papers) {
    margin-top: 0.75rem;
  }
  :global(.journal-saved-papers-toggle) {
    padding: 0.35rem 0.75rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-maroon);
    background: rgba(92, 29, 42, 0.06);
    border: 1px solid rgba(92, 29, 42, 0.18);
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }
  :global(.journal-saved-papers-toggle:hover) {
    background: rgba(92, 29, 42, 0.1);
    border-color: var(--color-maroon-muted);
  }
  :global(.journal-saved-papers-panel) {
    margin-top: 0.65rem;
    padding: 0.75rem 0.9rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }
  :global(.journal-saved-papers-loading),
  :global(.journal-saved-papers-empty) {
    margin: 0;
    font-size: 0.88rem;
    color: var(--color-ink-muted);
  }
  :global(.journal-saved-papers-error) {
    margin: 0;
    font-size: 0.88rem;
    color: #b42318;
  }
  :global(.journal-saved-papers-list) {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  :global(.journal-saved-papers-item) {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.55rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  :global(.journal-saved-papers-item:last-child) {
    border-bottom: none;
    padding-bottom: 0;
  }
  :global(.journal-saved-papers-item:first-child) {
    padding-top: 0;
  }
  :global(.journal-saved-paper-status) {
    align-self: flex-start;
    padding: 0.12rem 0.45rem;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    border-radius: 999px;
    border: 1px solid transparent;
  }
  :global(.journal-saved-paper-status-not-read) { background: #e2e8f0; color: #475569; border-color: #cbd5e1; }
  :global(.journal-saved-paper-status-1st-reading) { background: #dbeafe; color: #1e40af; border-color: #bfdbfe; }
  :global(.journal-saved-paper-status-2nd-reading) { background: #e0e7ff; color: #3730a3; border-color: #c7d2fe; }
  :global(.journal-saved-paper-status-read) { background: #fef9c3; color: #854d0e; border-color: #fde68a; }
  :global(.journal-saved-paper-status-completed) { background: #dcfce7; color: #166534; border-color: #bbf7d0; }
  :global(.journal-saved-paper-status-archive) { background: #f3e8ff; color: #6b21a8; border-color: #e9d5ff; }
  :global(.journal-saved-papers-link) {
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-ink);
    text-decoration: none;
  }
  :global(.journal-saved-papers-link:hover) {
    color: var(--color-maroon);
    text-decoration: underline;
  }
  :global(.journal-saved-papers-meta) {
    font-size: 0.82rem;
    color: var(--color-ink-muted);
  }
  :global(.journal-saved-papers-matched-as) {
    font-size: 0.78rem;
    color: var(--color-ink-muted);
    font-style: italic;
  }
</style>
