---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FieldsGrid from '../../components/FieldsGrid';
import FieldPaperAllocator from '../../components/FieldPaperAllocator';
import fields from '../../data/fields.json';

const base = import.meta.env.BASE_URL;

const categoryOrder = ['primary', 'secondary', 'peripheral'] as const;

const categoryMeta: Record<
  (typeof categoryOrder)[number],
  { label: string; desc: string }
> = {
  primary: {
    label: 'Primary',
    desc: 'Core disciplinary homes — where most of your theory and citations live.',
  },
  secondary: {
    label: 'Secondary',
    desc: 'Adjacent fields that inform context, methods, or application.',
  },
  peripheral: {
    label: 'Peripheral',
    desc: 'Supporting or occasional reference fields.',
  },
};

const groupedSections = categoryOrder.map((category) => ({
  category,
  ...categoryMeta[category],
  fields: fields.filter((field: { category: string }) => field.category === category),
}));
---

<BaseLayout title="Fields" description="Disciplinary fields relevant to your research - IS, ICT4D, agritech and more">
  <h1>Fields</h1>
  <p class="page-desc">Disciplinary and contextual fields that shape your thesis. Click a card for more detail.</p>

  <FieldPaperAllocator client:load fields={fields} base={base} />

  <FieldsGrid client:load sections={groupedSections} base={base} />
</BaseLayout>

<style>
  .page-desc {
    color: var(--color-ink-muted);
    margin-bottom: 2.5rem;
  }

  :global(.fields-grid-error) {
    margin: 0 0 1.5rem;
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
    color: #b42318;
    background: #fef3f2;
    border: 1px solid #fecdca;
    border-radius: 8px;
  }

  :global(.fields-section) {
    margin-bottom: 3rem;
  }

  :global(.fields-section:last-child) {
    margin-bottom: 0;
  }

  :global(.fields-section-header) {
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  :global(.fields-section--primary .fields-section-header) {
    border-bottom: 2px solid var(--color-maroon);
    padding-bottom: 1rem;
    margin-bottom: 1.5rem;
  }

  :global(.fields-section--peripheral .fields-section-header) {
    border-bottom-color: transparent;
    opacity: 0.85;
  }

  :global(.fields-section-title) {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 1.35rem;
    color: var(--color-ink);
  }

  :global(.fields-section--primary .fields-section-title) {
    font-size: 1.6rem;
    color: var(--color-maroon);
  }

  :global(.fields-section--peripheral .fields-section-title) {
    font-size: 1.15rem;
    color: var(--color-ink-muted);
  }

  :global(.fields-section-desc) {
    margin: 0.35rem 0 0;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--color-ink-muted);
  }

  :global(.fields-section--primary .fields-section-desc) {
    color: var(--color-ink);
    max-width: 42rem;
  }

  :global(.fields-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  :global(.fields-section--primary .fields-grid) {
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.75rem;
  }

  :global(.fields-section--peripheral .fields-grid) {
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  :global(.field-card) {
    padding: 1.35rem 1.5rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  :global(.field-card:hover) {
    transform: translateY(-1px);
  }

  :global(.field-card--primary) {
    padding: 2rem;
    background: linear-gradient(135deg, #fff 0%, rgba(92, 29, 42, 0.04) 100%);
    border: 1px solid rgba(92, 29, 42, 0.22);
    border-left: 6px solid var(--color-maroon);
    box-shadow: var(--shadow-md);
  }

  :global(.field-card--primary:hover) {
    border-color: var(--color-maroon-muted);
    box-shadow: 0 6px 20px rgba(92, 29, 42, 0.12);
    transform: translateY(-3px);
  }

  :global(.field-card--secondary) {
    border-left: 3px solid #b8a89a;
    background: #fff;
  }

  :global(.field-card--secondary:hover) {
    border-color: #c8b8aa;
    box-shadow: var(--shadow-sm);
  }

  :global(.field-card--peripheral) {
    padding: 1.1rem 1.25rem;
    background: var(--color-bg-alt);
    border: 1px dashed var(--color-border);
    border-left: 2px solid #d4d0cb;
  }

  :global(.field-card--peripheral:hover) {
    border-style: solid;
    background: #fff;
  }

  :global(.field-card h3) {
    margin: 0.5rem 0 0;
    font-size: 1.15rem;
    line-height: 1.3;
  }

  :global(.field-card--primary h3) {
    font-size: 1.4rem;
  }

  :global(.field-card--peripheral h3) {
    font-size: 1.05rem;
  }

  :global(.field-card h3 a) {
    color: inherit;
    text-decoration: none;
  }

  :global(.field-card--primary h3 a) {
    color: var(--color-maroon);
  }

  :global(.field-card h3 a:hover) {
    text-decoration: underline;
  }

  :global(.field-category) {
    display: inline-block;
    padding: 0.2rem 0.65rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 999px;
  }

  :global(.field-category--primary) {
    background: var(--color-maroon);
    color: #fff;
  }

  :global(.field-category--secondary) {
    background: #ebe6e0;
    color: #6b5f55;
  }

  :global(.field-category--peripheral) {
    background: transparent;
    color: var(--color-ink-muted);
    border: 1px solid var(--color-border);
    font-weight: 600;
  }

  :global(.field-library-counts) {
    margin: 0.45rem 0 0;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-maroon);
    letter-spacing: 0.01em;
  }

  :global(.field-card--peripheral .field-library-counts) {
    color: var(--color-ink-muted);
  }

  :global(.field-teaser) {
    font-size: 0.9rem;
    margin: 0.75rem 0 0;
    line-height: 1.55;
    color: var(--color-ink);
  }

  :global(.field-card--primary .field-teaser) {
    font-size: 0.95rem;
  }

  :global(.field-card--peripheral .field-teaser) {
    font-size: 0.85rem;
    color: var(--color-ink-muted);
  }

  :global(.field-allocator) {
    margin-bottom: 2.5rem;
    padding: 1.5rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    border-left: 4px solid var(--color-maroon);
  }

  :global(.field-allocator-title) {
    margin: 0 0 0.35rem 0;
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--color-ink);
  }

  :global(.field-allocator-intro),
  :global(.field-allocator-muted),
  :global(.field-allocator-hint) {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--color-ink-muted);
  }

  :global(.field-allocator-intro) {
    margin-bottom: 1rem;
  }

  :global(.field-allocator-success) {
    margin: 0;
    font-size: 0.9rem;
    color: #166534;
  }

  :global(.field-allocator-error) {
    margin: 0 0 1rem 0;
    padding: 0.75rem 1rem;
    font-size: 0.88rem;
    color: #b42318;
    background: #fef3f2;
    border: 1px solid #fecdca;
    border-radius: 8px;
  }

  :global(.field-allocator-list) {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  :global(.field-allocator-item) {
    padding: 1rem 1.15rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 10px;
  }

  :global(.field-allocator-paper-title) {
    font-weight: 600;
    color: var(--color-maroon);
    text-decoration: none;
    line-height: 1.35;
  }

  :global(.field-allocator-paper-title:hover) {
    text-decoration: underline;
  }

  :global(.field-allocator-paper-journal) {
    margin: 0.25rem 0 0;
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    font-style: italic;
  }

  :global(.field-allocator-fields) {
    margin-top: 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  :global(.field-allocator-fields-label) {
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-ink-muted);
  }

  :global(.field-allocator-chips) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  :global(.field-allocator-chip) {
    padding: 0.35rem 0.75rem;
    font-size: 0.8rem;
    font-weight: 500;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: #fff;
    color: var(--color-ink);
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
  }

  :global(.field-allocator-chip:hover:not(:disabled)) {
    border-color: var(--color-maroon-muted);
  }

  :global(.field-allocator-chip-selected) {
    background: var(--color-maroon);
    border-color: var(--color-maroon);
    color: #fff;
  }

  :global(.field-allocator-chip:disabled) {
    opacity: 0.6;
    cursor: not-allowed;
  }

  :global(.field-allocator-save) {
    align-self: flex-start;
    margin-top: 0.25rem;
    padding: 0.4rem 0.9rem;
    font-size: 0.85rem;
    font-weight: 600;
    border: none;
    border-radius: 8px;
    background: var(--color-maroon);
    color: #fff;
    cursor: pointer;
  }

  :global(.field-allocator-save:hover:not(:disabled)) {
    background: var(--color-maroon-dark);
  }

  :global(.field-allocator-save:disabled) {
    opacity: 0.5;
    cursor: not-allowed;
  }

  :global(.field-allocator-hint) {
    margin-top: 1rem;
  }
</style>
