---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fields from '../../data/fields.json';
const base = import.meta.env.BASE_URL;

const categoryOrder = ['primary', 'secondary', 'peripheral'] as const;

const categoryMeta: Record<
  (typeof categoryOrder)[number],
  { label: string; desc: string }
> = {
  primary: {
    label: 'Primary',
    desc: 'Core disciplinary homes — where most of your theory and citations live.',
  },
  secondary: {
    label: 'Secondary',
    desc: 'Adjacent fields that inform context, methods, or application.',
  },
  peripheral: {
    label: 'Peripheral',
    desc: 'Supporting or occasional reference fields.',
  },
};

const groupedSections = categoryOrder.map((category) => ({
  category,
  ...categoryMeta[category],
  fields: fields.filter((field: { category: string }) => field.category === category),
}));
---

<BaseLayout title="Fields" description="Disciplinary fields relevant to your research - IS, ICT4D, agritech and more">
  <h1>Fields</h1>
  <p class="page-desc">Disciplinary and contextual fields that shape your thesis. Click a card for more detail.</p>

  {groupedSections.map((section) => (
    <section class={`fields-section fields-section--${section.category}`}>
      <header class="fields-section-header">
        <h2 class="fields-section-title">{section.label}</h2>
        <p class="fields-section-desc">{section.desc}</p>
      </header>

      <div class="fields-grid">
        {section.fields.map((field: { id: string; name: string; category: string; description: string }) => (
          <article class={`field-card field-card--${field.category}`}>
            <span class="field-category field-category--{field.category}">{section.label}</span>
            <h3><a href={`${base}fields/${field.id}/`}>{field.name}</a></h3>
            <p class="field-teaser">{field.description.slice(0, 140)}{field.description.length > 140 ? '…' : ''}</p>
          </article>
        ))}
      </div>
    </section>
  ))}
</BaseLayout>

<style>
  .page-desc {
    color: var(--color-ink-muted);
    margin-bottom: 2.5rem;
  }

  .fields-section {
    margin-bottom: 3rem;
  }

  .fields-section:last-child {
    margin-bottom: 0;
  }

  .fields-section-header {
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .fields-section--primary .fields-section-header {
    border-bottom: 2px solid var(--color-maroon);
    padding-bottom: 1rem;
    margin-bottom: 1.5rem;
  }

  .fields-section--peripheral .fields-section-header {
    border-bottom-color: transparent;
    opacity: 0.85;
  }

  .fields-section-title {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 1.35rem;
    color: var(--color-ink);
  }

  .fields-section--primary .fields-section-title {
    font-size: 1.6rem;
    color: var(--color-maroon);
  }

  .fields-section--peripheral .fields-section-title {
    font-size: 1.15rem;
    color: var(--color-ink-muted);
  }

  .fields-section-desc {
    margin: 0.35rem 0 0;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--color-ink-muted);
  }

  .fields-section--primary .fields-section-desc {
    color: var(--color-ink);
    max-width: 42rem;
  }

  .fields-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .fields-section--primary .fields-grid {
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.75rem;
  }

  .fields-section--peripheral .fields-grid {
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  .field-card {
    padding: 1.35rem 1.5rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .field-card:hover {
    transform: translateY(-1px);
  }

  .field-card--primary {
    padding: 2rem;
    background: linear-gradient(135deg, #fff 0%, rgba(92, 29, 42, 0.04) 100%);
    border: 1px solid rgba(92, 29, 42, 0.22);
    border-left: 6px solid var(--color-maroon);
    box-shadow: var(--shadow-md);
  }

  .field-card--primary:hover {
    border-color: var(--color-maroon-muted);
    box-shadow: 0 6px 20px rgba(92, 29, 42, 0.12);
    transform: translateY(-3px);
  }

  .field-card--secondary {
    border-left: 3px solid #b8a89a;
    background: #fff;
  }

  .field-card--secondary:hover {
    border-color: #c8b8aa;
    box-shadow: var(--shadow-sm);
  }

  .field-card--peripheral {
    padding: 1.1rem 1.25rem;
    background: var(--color-bg-alt);
    border: 1px dashed var(--color-border);
    border-left: 2px solid #d4d0cb;
  }

  .field-card--peripheral:hover {
    border-style: solid;
    background: #fff;
  }

  .field-card h3 {
    margin: 0.5rem 0 0;
    font-size: 1.15rem;
    line-height: 1.3;
  }

  .field-card--primary h3 {
    font-size: 1.4rem;
  }

  .field-card--peripheral h3 {
    font-size: 1.05rem;
  }

  .field-card h3 a {
    color: inherit;
    text-decoration: none;
  }

  .field-card--primary h3 a {
    color: var(--color-maroon);
  }

  .field-card h3 a:hover {
    text-decoration: underline;
  }

  .field-category {
    display: inline-block;
    padding: 0.2rem 0.65rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 999px;
  }

  .field-category--primary {
    background: var(--color-maroon);
    color: #fff;
  }

  .field-category--secondary {
    background: #ebe6e0;
    color: #6b5f55;
  }

  .field-category--peripheral {
    background: transparent;
    color: var(--color-ink-muted);
    border: 1px solid var(--color-border);
    font-weight: 600;
  }

  .field-teaser {
    font-size: 0.9rem;
    margin: 0.75rem 0 0;
    line-height: 1.55;
    color: var(--color-ink);
  }

  .field-card--primary .field-teaser {
    font-size: 0.95rem;
  }

  .field-card--peripheral .field-teaser {
    font-size: 0.85rem;
    color: var(--color-ink-muted);
  }
</style>
