---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fields from '../../data/fields.json';
const base = import.meta.env.BASE_URL;

function categoryLabel(cat: string) {
  if (cat === 'primary') return 'Primary';
  if (cat === 'secondary') return 'Secondary';
  if (cat === 'peripheral') return 'Peripheral';
  return cat;
}
---

<BaseLayout title="Fields" description="Disciplinary fields relevant to your research - IS, ICT4D, agritech and more">
  <h1>Fields</h1>
  <p class="page-desc">Disciplinary and contextual fields that shape your thesis. Click a card for more detail.</p>

  <div class="fields-grid">
    {fields.map((field: { id: string; name: string; category: string; description: string }) => (
      <article class="field-card">
        <h2><a href={`${base}fields/${field.id}/`}>{field.name}</a></h2>
        <span class="field-category field-category--{field.category}">{categoryLabel(field.category)}</span>
        <p class="field-teaser">{field.description.slice(0, 140)}{field.description.length > 140 ? '…' : ''}</p>
      </article>
    ))}
  </div>
</BaseLayout>

<style>
  .page-desc { color: var(--color-ink-muted); margin-bottom: 2rem; }

  .fields-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .field-card {
    padding: 1.5rem;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    border-left: 4px solid var(--color-maroon);
  }

  .field-card h2 { margin-top: 0; font-size: 1.25rem; }
  .field-category {
    display: inline-block;
    margin: 0.5rem 0;
    padding: 0.2rem 0.6rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    border-radius: 4px;
  }
  .field-category--primary {
    background: rgba(92, 29, 42, 0.12);
    color: var(--color-maroon);
  }
  .field-category--secondary {
    background: var(--color-bg-alt);
    color: var(--color-ink-muted);
  }
  .field-category--peripheral {
    background: var(--color-bg-alt);
    color: var(--color-ink-muted);
    opacity: 0.9;
  }
  .field-teaser { font-size: 0.9rem; margin: 0.75rem 0 0; line-height: 1.5; color: var(--color-ink); }
</style>
