---
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Literature" description="Redirect to Papers">
  <meta http-equiv="refresh" content={`0;url=${base}papers/`} />
  <article class="redirect-page">
    <h1>Literature</h1>
    <p>This page has moved. <a href={`${base}papers/`}>Go to Papers →</a></p>
  </article>
</BaseLayout>

<style>
  .redirect-page { padding: 2rem 0; }
  .redirect-page a { font-weight: 600; }
</style>
