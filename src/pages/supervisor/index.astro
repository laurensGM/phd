---
import BaseLayout from '../../layouts/BaseLayout.astro';
import supervisors from '../../data/supervisor.json';

type Supervisor = {
  name: string;
  initials?: string;
  title: string;
  profileUrl: string;
  orcidId: string;
  publicationsUrl: string;
  linkedInUrl?: string;
  researchGateUrl?: string;
  email?: string;
  bio: string[];
  expertise: string[];
  education: string[];
  keyPublications: { title: string; citation: string; url?: string }[];
};

const list = supervisors as Supervisor[];
const names = list.map((s) => s.name).join(' & ');
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Supervisors" description={`PhD supervisors — ${names}, Stellenbosch Business School`}>
  <article class="supervisor-page">
    <p class="back-link"><a href={`${base}manager/`}>← Manager</a></p>
    <header class="supervisor-header">
      <h1>PhD Supervisors</h1>
      <p class="supervisor-intro">
        Stellenbosch Business School — AACSB, EQUIS and AMBA accredited.
      </p>
    </header>

    {list.map((supervisor) => {
      const orcidUrl = `https://orcid.org/${supervisor.orcidId}`;
      const profileUrl = supervisor.profileUrl;
      const publicationsUrl = supervisor.publicationsUrl;
      const linkedInUrl = supervisor.linkedInUrl || '';
      const researchGateUrl = supervisor.researchGateUrl || '';
      return (
        <section class="supervisor-card">
          <header class="supervisor-card-head">
            <h2 class="supervisor-name">{supervisor.name}</h2>
            <p class="supervisor-title">{supervisor.title}</p>
          </header>

          <div class="supervisor-section">
            <h3>Profile &amp; biography</h3>
            {supervisor.bio.map((para) => (
              <p>{para}</p>
            ))}
            <p>
              <a href={profileUrl} target="_blank" rel="noopener" class="supervisor-link">
                View full profile on Stellenbosch Business School →
              </a>
            </p>
          </div>

          <div class="supervisor-section">
            <h3>Research interests &amp; expertise</h3>
            <ul class="expertise-list">
              {supervisor.expertise.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>

          <div class="supervisor-section">
            <h3>Education</h3>
            <ul class="education-list">
              {supervisor.education.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>

          <div class="supervisor-section">
            <h3>Links</h3>
            <ul class="links-list">
              <li>
                <a href={profileUrl} target="_blank" rel="noopener">Stellenbosch Business School profile</a>
              </li>
              <li>
                <a href={orcidUrl} target="_blank" rel="noopener">ORCID ({supervisor.orcidId})</a>
              </li>
              <li>
                <a href={publicationsUrl} target="_blank" rel="noopener">Stellenbosch University research profile</a>
              </li>
              {supervisor.email && (
                <li>
                  <a href={`mailto:${supervisor.email}`}>Email ({supervisor.email})</a>
                </li>
              )}
              {linkedInUrl && (
                <li>
                  <a href={linkedInUrl} target="_blank" rel="noopener">LinkedIn</a>
                </li>
              )}
              {researchGateUrl && (
                <li>
                  <a href={researchGateUrl} target="_blank" rel="noopener">ResearchGate</a>
                </li>
              )}
            </ul>
          </div>

          {supervisor.keyPublications.length > 0 && (
            <div class="supervisor-section">
              <h3>Key publications &amp; articles</h3>
              <p class="section-note">
                A full list is available on the{' '}
                <a href={publicationsUrl} target="_blank" rel="noopener">university research profile</a>.
              </p>
              <ul class="publications-list">
                {supervisor.keyPublications.map((pub) => (
                  <li>
                    <em>{pub.title}</em>
                    {pub.citation && ` — ${pub.citation}`}
                    {pub.url && (
                      <>
                        {' '}
                        <a href={pub.url} target="_blank" rel="noopener">Link</a>
                      </>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          )}
        </section>
      );
    })}
  </article>
</BaseLayout>

<style>
  .back-link {
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }
  .back-link a {
    color: var(--color-maroon);
  }
  .supervisor-page {
    max-width: 720px;
  }

  .supervisor-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .supervisor-intro {
    margin: 0.5rem 0 0;
    color: var(--color-ink-muted);
    font-size: 0.95rem;
  }

  .supervisor-card {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .supervisor-card:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .supervisor-card-head {
    margin-bottom: 1.25rem;
  }

  .supervisor-name {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0 0 0.25rem 0;
    color: var(--color-ink);
  }

  .supervisor-title {
    font-size: 1rem;
    color: var(--color-ink-muted);
    margin: 0;
  }

  .supervisor-section {
    margin-bottom: 1.5rem;
  }

  .supervisor-section h3 {
    font-size: 1.05rem;
    margin: 0 0 0.65rem 0;
    color: var(--color-ink);
  }

  .supervisor-section p {
    margin: 0 0 0.75rem 0;
    line-height: 1.65;
  }

  .supervisor-link {
    font-weight: 600;
  }

  .expertise-list,
  .education-list,
  .links-list,
  .publications-list {
    margin: 0;
    padding-left: 1.25rem;
    line-height: 1.8;
  }

  .expertise-list li,
  .education-list li,
  .links-list li,
  .publications-list li {
    margin-bottom: 0.35rem;
  }

  .section-note {
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    margin-bottom: 1rem !important;
  }

  .publications-list li {
    margin-bottom: 0.75rem;
  }
</style>
