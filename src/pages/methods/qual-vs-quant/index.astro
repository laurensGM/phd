---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

const secondaryCriteria = [
  'Complete',
  'Precise',
  'Accurate',
  'Timely',
  'Relevant',
  'Consistent',
  'Transparent',
];
---

<BaseLayout
  title="Qual vs Quant"
  description="Qualitative vs quantitative research — definitions, distinctions, and quality criteria"
>
  <p class="back-link"><a href={`${base}methods/`}>← Methods</a></p>
  <h1>Qual vs Quant</h1>
  <p class="page-desc">
    A side-by-side comparison of qualitative and quantitative approaches — without the detail covered on the{' '}
    <a href={`${base}methods/qual/`}>Qual</a> and <a href={`${base}methods/quant/`}>Quant</a> pages.
  </p>

  <section class="qvq-section" aria-label="Definitions">
    <h2 class="qvq-heading">Qualitative data and quantitative data</h2>
    <p class="qvq-prose">
      Quantitative research refers to research methods applied to gather data that can be analysed using mathematical
      analysis to test hypotheses to ultimately reveal statistically significant differences or relations, whereas
      qualitative data is research data that are not subjected to quantification or quantitative analysis.
    </p>
  </section>

  <section class="qvq-section" aria-label="Qualitative vs quantitative vs mixed methods">
    <h2 class="qvq-heading">Qualitative vs quantitative vs mixed methods</h2>
    <div class="qvq-methods-grid">
      <div class="qvq-methods-col qvq-methods-col--qual">
        <h3 class="qvq-methods-title">Qualitative research</h3>
        <p class="qvq-methods-def">
          Research that <strong>leads</strong> observations <strong>into</strong> a theory.
        </p>
        <dl class="qvq-methods-dl">
          <dt>Approach</dt>
          <dd>Inductive*</dd>
          <dt>Goal</dt>
          <dd>Depth, generate hypotheses</dd>
          <dt>Setting</dt>
          <dd>Natural</dd>
          <dt>Sampling</dt>
          <dd>Purposeful</dd>
          <dt>Data collection</dt>
          <dd>Interview guides, observation tools</dd>
          <dt>Data analysis</dt>
          <dd>Iterative interpretation</dd>
        </dl>
        <p class="qvq-methods-footnote">*From Latin <em>inducere</em> = to lead into</p>
      </div>

      <div class="qvq-methods-col qvq-methods-col--mixed">
        <h3 class="qvq-methods-title">Mixed methods</h3>
        <ul class="qvq-methods-mixed-list">
          <li>Integrates both approaches</li>
          <li>Enhances depth and generalizability</li>
          <li>Useful for triangulation and validation</li>
        </ul>
      </div>

      <div class="qvq-methods-col qvq-methods-col--quant">
        <h3 class="qvq-methods-title">Quantitative research</h3>
        <p class="qvq-methods-def">
          Research that <strong>leads from</strong> established theory down to test cases.
        </p>
        <dl class="qvq-methods-dl">
          <dt>Approach</dt>
          <dd>Deductive*</dd>
          <dt>Goal</dt>
          <dd>Breadth, test hypotheses</dd>
          <dt>Setting</dt>
          <dd>Experimental / quasi</dd>
          <dt>Sampling</dt>
          <dd>Random</dd>
          <dt>Data collection</dt>
          <dd>Surveys, data</dd>
          <dt>Data analysis</dt>
          <dd>Statistical tests, modeling</dd>
        </dl>
        <p class="qvq-methods-footnote">*From Latin <em>deducere</em> = to lead down/away</p>
      </div>
    </div>
  </section>

  <section class="qvq-section" aria-label="Key distinctions">
    <h2 class="qvq-heading">Key qualitative and quantitative distinctions</h2>
    <div class="qvq-table-wrap">
      <table class="qvq-table">
        <thead>
          <tr>
            <th scope="col" class="qvq-table-corner">
              <span class="qvq-table-axis">Analysis</span>
              <span class="qvq-table-axis qvq-table-axis--data">Data</span>
            </th>
            <th scope="col">Quantitative (data)</th>
            <th scope="col">Qualitative (data)</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <th scope="row">Quantitative (analysis)</th>
            <td>Statistical and mathematical analysis of the numerical data as presented</td>
            <td>
              Assigning meaning of words based on scoring system. E.g. content analysis, word counts, free lists, pile
              sorts
            </td>
          </tr>
          <tr>
            <th scope="row">Qualitative (analysis)</th>
            <td>Search for and presentation of meaning in results of quantitative processing</td>
            <td>Interpretative test studies. E.g. hermeneutics, grounded theory, phenomenology</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="qvq-credit">&copy; J. Loke 2014</p>
  </section>

  <section class="qvq-section" aria-label="The necessity of the researcher's voice">
    <h2 class="qvq-heading">The necessity of the researcher&rsquo;s voice</h2>
    <div class="qvq-table-wrap">
      <table class="qvq-table qvq-voice-table">
        <thead>
          <tr>
            <th scope="col"></th>
            <th scope="col">Traditional quantitative stance</th>
            <th scope="col" class="qvq-voice-qual-col">Strong qualitative stance</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <th scope="row">Goal</th>
            <td>Objectivity and detachment</td>
            <td class="qvq-voice-qual-col">Reflexivity and authenticity</td>
          </tr>
          <tr>
            <th scope="row">Format</th>
            <td>Third-person narrative</td>
            <td class="qvq-voice-qual-col">First-person narrative</td>
          </tr>
          <tr>
            <th scope="row">Focus</th>
            <td>Numbers, charts, and isolating variables</td>
            <td class="qvq-voice-qual-col">The interaction between the researcher and the phenomenon</td>
          </tr>
          <tr>
            <th scope="row">Role</th>
            <td>The researcher is removed from the text</td>
            <td class="qvq-voice-qual-col">The researcher&rsquo;s role in outcomes is acknowledged and highly visible</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="qvq-voice-note">
      Qualitative data cannot be easily reduced. The reader experiences the &ldquo;Aha!&rdquo; moment through the
      researcher&rsquo;s eyes.
    </p>
    <p class="qvq-credit">
      Bansal, P. and Corley, K. (2011). The coming of age for qualitative research: Embracing the diversity of
      qualitative methods. <em>Academy of Management Journal</em>, 54(2), 233&ndash;237.
    </p>
  </section>

  <section class="qvq-section" aria-label="Quality criteria">
    <div class="qvq-quality-grid">
      <div class="qvq-quality-col">
        <h2 class="qvq-heading">Quantitative data (numbers)</h2>
        <p class="qvq-subheading">Reliability and validity</p>
        <div class="qvq-targets">
          <figure class="qvq-target">
            <div class="qvq-target-ring" aria-hidden="true">
              <span class="qvq-dot" style="--x: 68%; --y: 32%"></span>
              <span class="qvq-dot" style="--x: 72%; --y: 38%"></span>
              <span class="qvq-dot" style="--x: 65%; --y: 42%"></span>
              <span class="qvq-dot" style="--x: 70%; --y: 28%"></span>
            </div>
            <figcaption>Reliable, not valid</figcaption>
            <p class="qvq-target-note">Consistent shots, but off target.</p>
          </figure>
          <figure class="qvq-target">
            <div class="qvq-target-ring" aria-hidden="true">
              <span class="qvq-dot" style="--x: 38%; --y: 55%"></span>
              <span class="qvq-dot" style="--x: 62%; --y: 44%"></span>
              <span class="qvq-dot" style="--x: 48%; --y: 62%"></span>
              <span class="qvq-dot" style="--x: 55%; --y: 35%"></span>
            </div>
            <figcaption>Valid, not reliable</figcaption>
            <p class="qvq-target-note">On target on average, but scattered.</p>
          </figure>
          <figure class="qvq-target">
            <div class="qvq-target-ring" aria-hidden="true">
              <span class="qvq-dot" style="--x: 18%; --y: 22%"></span>
              <span class="qvq-dot" style="--x: 78%; --y: 70%"></span>
              <span class="qvq-dot" style="--x: 30%; --y: 75%"></span>
              <span class="qvq-dot" style="--x: 82%; --y: 25%"></span>
            </div>
            <figcaption>Neither reliable nor valid</figcaption>
            <p class="qvq-target-note">Scattered and off target.</p>
          </figure>
          <figure class="qvq-target">
            <div class="qvq-target-ring" aria-hidden="true">
              <span class="qvq-dot" style="--x: 49%; --y: 49%"></span>
              <span class="qvq-dot" style="--x: 52%; --y: 47%"></span>
              <span class="qvq-dot" style="--x: 47%; --y: 52%"></span>
              <span class="qvq-dot" style="--x: 51%; --y: 51%"></span>
            </div>
            <figcaption>Both reliable &amp; valid</figcaption>
            <p class="qvq-target-note">Tight cluster in the bullseye.</p>
          </figure>
        </div>
      </div>

      <div class="qvq-quality-col">
        <h2 class="qvq-heading">Qualitative data (words)</h2>
        <p class="qvq-subheading">Credible and trustworthy</p>
        <div class="qvq-rigour">
          <p class="qvq-rigour-title">Rigour in qualitative research</p>
          <div class="qvq-rigour-grid">
            <div class="qvq-rigour-block">
              <h3 class="qvq-rigour-label">Internal</h3>
              <ul class="qvq-rigour-list">
                <li class="qvq-rigour-emphasis">Credibility</li>
                <li>Neutrality</li>
                <li>Confirmability</li>
              </ul>
            </div>
            <div class="qvq-rigour-block">
              <h3 class="qvq-rigour-label">External</h3>
              <ul class="qvq-rigour-list">
                <li class="qvq-rigour-emphasis">Dependability</li>
              </ul>
            </div>
          </div>
          <div class="qvq-trustworthiness">
            <h3 class="qvq-trustworthiness-label">Trustworthiness</h3>
            <ul class="qvq-trustworthiness-list">
              <li>Consistency</li>
              <li>Dependability</li>
              <li>Applicability</li>
              <li>Transferability</li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <div class="qvq-secondary">
      <h3 class="qvq-secondary-title">Secondary data set(s) should be:</h3>
      <ul class="qvq-checklist">
        {secondaryCriteria.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .back-link {
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }
  .back-link a {
    color: var(--color-maroon);
  }

  .page-desc {
    color: var(--color-ink-muted);
    margin-bottom: 2rem;
    line-height: 1.6;
    max-width: 44rem;
  }

  .page-desc a {
    font-weight: 600;
  }

  .qvq-section {
    max-width: 52rem;
    margin-bottom: 2rem;
    padding: 1.5rem 1.75rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    border-left: 4px solid var(--color-maroon);
  }

  .qvq-heading {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    color: var(--color-maroon);
    margin: 0 0 0.85rem 0;
  }

  .qvq-subheading {
    margin: 0 0 1rem 0;
    font-weight: 600;
    color: var(--color-ink);
    font-size: 0.95rem;
  }

  .qvq-prose {
    margin: 0;
    line-height: 1.65;
    color: var(--color-ink);
    font-size: 0.98rem;
  }

  .qvq-methods-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1rem;
    align-items: start;
  }

  .qvq-methods-col {
    padding: 1rem 1.1rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .qvq-methods-col--qual {
    background: rgba(113, 32, 56, 0.06);
    border-top: 3px solid var(--color-maroon-muted);
  }

  .qvq-methods-col--mixed {
    background: rgba(230, 160, 90, 0.12);
    border-top: 3px solid #d4985a;
  }

  .qvq-methods-col--quant {
    background: rgba(140, 160, 80, 0.1);
    border-top: 3px solid #8a9a50;
  }

  .qvq-methods-title {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--color-maroon);
    margin: 0 0 0.65rem 0;
  }

  .qvq-methods-def {
    margin: 0 0 0.85rem 0;
    line-height: 1.55;
    color: var(--color-ink);
  }

  .qvq-methods-dl {
    margin: 0;
  }

  .qvq-methods-dl dt {
    font-weight: 700;
    color: var(--color-ink);
    margin-top: 0.55rem;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .qvq-methods-dl dt:first-child {
    margin-top: 0;
  }

  .qvq-methods-dl dd {
    margin: 0.15rem 0 0 0;
    color: var(--color-ink);
  }

  .qvq-methods-footnote {
    margin: 0.85rem 0 0 0;
    font-size: 0.78rem;
    color: var(--color-ink-muted);
    font-style: italic;
  }

  .qvq-methods-mixed-list {
    margin: 0;
    padding-left: 1.15rem;
    color: var(--color-ink);
  }

  .qvq-methods-mixed-list li {
    margin-bottom: 0.5rem;
  }

  .qvq-methods-mixed-list li:last-child {
    margin-bottom: 0;
  }

  .qvq-table-wrap {
    overflow-x: auto;
    margin-bottom: 0.75rem;
  }

  .qvq-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.92rem;
    line-height: 1.5;
  }

  .qvq-table th,
  .qvq-table td {
    border: 1px solid var(--color-border);
    padding: 0.75rem 0.85rem;
    text-align: left;
    vertical-align: top;
  }

  .qvq-table thead th {
    background: rgba(113, 32, 56, 0.08);
    color: var(--color-maroon);
    font-weight: 700;
  }

  .qvq-table tbody th {
    background: rgba(113, 32, 56, 0.05);
    font-weight: 600;
    white-space: nowrap;
  }

  .qvq-table-corner {
    min-width: 7rem;
    position: relative;
  }

  .qvq-table-axis {
    display: block;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .qvq-table-axis--data {
    margin-top: 0.35rem;
    text-align: right;
  }

  .qvq-credit {
    margin: 0;
    text-align: right;
    font-size: 0.82rem;
    color: var(--color-ink-muted);
  }

  .qvq-voice-qual-col {
    background: rgba(255, 220, 100, 0.2);
  }

  .qvq-voice-note {
    margin: 1rem 0 0.75rem 0;
    padding: 0.85rem 1rem;
    line-height: 1.6;
    font-size: 0.92rem;
    color: var(--color-ink);
    background: rgba(255, 220, 100, 0.12);
    border-left: 3px solid rgba(200, 160, 40, 0.6);
    border-radius: 0 6px 6px 0;
    max-width: 36rem;
  }

  .qvq-quality-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .qvq-targets {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .qvq-target {
    margin: 0;
    text-align: center;
  }

  .qvq-target-ring {
    position: relative;
    width: 5.5rem;
    height: 5.5rem;
    margin: 0 auto 0.5rem;
    border-radius: 50%;
    border: 2px solid #ccc;
    background:
      radial-gradient(circle at center, #c44 0%, #c44 12%, transparent 13%),
      radial-gradient(circle at center, transparent 28%, #999 29%, #999 32%, transparent 33%),
      radial-gradient(circle at center, transparent 48%, #999 49%, #999 52%, transparent 53%),
      #f8f8f8;
  }

  .qvq-dot {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: 0.45rem;
    height: 0.45rem;
    margin: -0.225rem 0 0 -0.225rem;
    border-radius: 50%;
    background: #222;
  }

  .qvq-target figcaption {
    font-weight: 600;
    font-size: 0.82rem;
    color: var(--color-ink);
  }

  .qvq-target-note {
    margin: 0.2rem 0 0 0;
    font-size: 0.75rem;
    color: var(--color-ink-muted);
    line-height: 1.35;
  }

  .qvq-rigour {
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: rgba(113, 32, 56, 0.03);
  }

  .qvq-rigour-title {
    margin: 0 0 0.85rem 0;
    font-weight: 700;
    font-size: 0.9rem;
    text-align: center;
    color: var(--color-ink);
  }

  .qvq-rigour-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .qvq-rigour-block {
    padding: 0.65rem 0.75rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 6px;
  }

  .qvq-rigour-label {
    margin: 0 0 0.4rem 0;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-maroon);
  }

  .qvq-rigour-list {
    margin: 0;
    padding-left: 1.1rem;
    font-size: 0.85rem;
    line-height: 1.55;
  }

  .qvq-rigour-emphasis {
    font-weight: 700;
    color: var(--color-maroon);
  }

  .qvq-trustworthiness {
    padding: 0.75rem 1rem;
    border: 2px solid var(--color-maroon-muted);
    border-radius: 999px;
    text-align: center;
  }

  .qvq-trustworthiness-label {
    margin: 0 0 0.35rem 0;
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--color-maroon);
  }

  .qvq-trustworthiness-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.35rem 0.75rem;
    font-size: 0.82rem;
    color: var(--color-ink);
  }

  .qvq-secondary {
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
  }

  .qvq-secondary-title {
    margin: 0 0 0.85rem 0;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-ink);
  }

  .qvq-checklist {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(9rem, 1fr));
    gap: 0.5rem 1.5rem;
  }

  .qvq-checklist li::before {
    content: '✓ ';
    color: var(--color-maroon);
    font-weight: 700;
  }

  @media (max-width: 720px) {
    .qvq-quality-grid,
    .qvq-rigour-grid,
    .qvq-methods-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
