---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

type RigourRow = {
  critical: string;
  criteria: string;
  strategies: string[];
  techniques: string[];
};

const interviewRigour: RigourRow[] = [
  {
    critical: 'Credibility',
    criteria: 'Truth value',
    strategies: ['Field notes/memo', 'Tape recorder', 'Thematic log', 'Auditing transcript'],
    techniques: [
      'Purposeful/theoretical',
      'Negative/deviant case',
      'Constant comparison',
      'Member checking',
      'Triangulation',
      'Audit trial',
    ],
  },
  {
    critical: 'Transferability',
    criteria: 'Applicability',
    strategies: ['Data display', 'Simultaneous', 'Field notes/memo'],
    techniques: ['Purposeful/theoretical', 'Thick description'],
  },
  {
    critical: 'Dependability',
    criteria: 'Consistency',
    strategies: [
      'Tape recorder',
      'Thematic log',
      'Auditing transcript',
      "Researcher's story",
      'Reflexivity',
    ],
    techniques: ['Negative/deviant case', 'Member checking', 'Triangulation', 'Audit trial'],
  },
  {
    critical: 'Confirmability',
    criteria: 'Neutrality',
    strategies: ['Field notes/memo'],
    techniques: ['Audit trial'],
  },
];
---

<BaseLayout title="Qual" description="Qualitative methods — interviews, focus groups, observation, and thematic analysis">
  <div class="qual-layout">
    <nav class="qual-toc" aria-label="On this page">
      <h2 class="qual-toc-title">On this page</h2>
      <ol class="qual-toc-list">
        <li><a href="#intro">Introduction</a></li>
        <li>
          <a href="#method">Method</a>
          <ol>
            <li><a href="#interviews">Interviews</a></li>
            <li><a href="#focus-groups">Focus groups</a></li>
            <li><a href="#observation">Observation</a></li>
            <li><a href="#themes">Themes</a></li>
            <li><a href="#projective-technique">Projective technique</a></li>
            <li><a href="#sentence-completion">Sentence completion</a></li>
          </ol>
        </li>
        <li><a href="#measurement">Measurement</a></li>
        <li><a href="#sampling">Sampling</a></li>
        <li><a href="#data-analysis">Data analysis</a></li>
      </ol>
    </nav>

    <article class="qual-article">
      <p class="back-link"><a href={`${base}methods/`}>← Methods</a></p>
      <h1 id="intro">Qual</h1>
      <p class="qual-lead">
        Non-numerical data (words): interviews, focus groups, observation, and document analysis to understand meaning
        and build themes. <strong>Data is always contextual. Not theory (content).</strong>
      </p>
      <p class="qual-lead">Qualitative data is to help understand, to give meaning.</p>

      <div class="qual-intro-block">
        <h2 class="qual-intro-heading">Defining qualitative research</h2>
        <ul class="qual-intro-list">
          <li>
            Qualitative research is an <strong>umbrella term</strong> for a family of approaches.
          </li>
          <li>
            It focuses on understanding <strong>participants&rsquo; points of view</strong>.
          </li>
          <li>
            Aims to generate rich insights (<strong>rather than confirming hypotheses</strong>) and develop theoretical
            contributions from empirical data.
          </li>
          <li>
            Concerned with <strong>diverse approaches</strong> shaped by distinct purposes and methodologies.
          </li>
          <li>
            Often applied when phenomena are new and <strong>theorizing is nascent</strong>.
          </li>
        </ul>
        <blockquote class="qual-quote">
          <p>
            &ldquo;Qualitative research is a situated activity that locates the observer in the world. It consists of a set
            of interpretive, material practices that make the world visible. These practices transform the world. They turn
            the world into a series of representations, including field notes, interviews, conversations, photographs,
            recordings, and memos to the self. At this level, qualitative research involves an interpretive, naturalistic
            approach to the world. This means that qualitative researchers study things in their{' '}
            <strong>natural settings</strong>, attempting to make sense of, or interpret, phenomena in terms of the
            meanings people bring to them.&rdquo;
          </p>
          <footer class="qual-quote-attribution">(Denzin &amp; Lincoln, 2005a, p. 3)</footer>
        </blockquote>
        <p class="qual-reference">
          Denzin, N.K. and Lincoln, Y.S. (2005) Introduction: The Discipline and Practice of Qualitative Research. In:
          Denzin, N.K. and Lincoln, Y.S., Eds., <em>Handbook of Qualitative Research</em>, 3rd Edition, Sage, Thousand
          Oaks, 1&ndash;32.
        </p>
      </div>

      <section id="method" class="qual-section">
        <h2>Method</h2>
        <p>Primary qualitative data collection techniques covered below.</p>

        <section id="interviews" class="qual-subsection">
          <h3>Interviews</h3>
          <p><strong>Semi structured:</strong> somewhat experts, 30 minutes. Not probing, 12 questions. You need &gt;12 ×
          3. ×3 because of triangulation. Need to repeat 3 times to ensure it&rsquo;s credible.</p>
          <p>
            <strong>In depth:</strong> with experts, 60 to 90 minutes. 5 questions: allow for follow up, probing. Needs
            &gt;7 × 3, also need to repeat 3 times.
          </p>

          <h4 class="qual-table-heading">Interviews (primary, qualitative)</h4>
          <div class="qual-table-wrap">
            <table class="qual-rigour-table">
              <thead>
                <tr>
                  <th scope="col">Rigour critical</th>
                  <th scope="col">Criteria for rigour</th>
                  <th scope="col">Research strategy</th>
                  <th scope="col">Techniques to insure rigour</th>
                </tr>
              </thead>
              <tbody>
                {interviewRigour.map((row) => (
                  <tr>
                    <th scope="row">{row.critical}</th>
                    <td>{row.criteria}</td>
                    <td>
                      <ul>
                        {row.strategies.map((item) => (
                          <li>{item}</li>
                        ))}
                      </ul>
                    </td>
                    <td>
                      <ul>
                        {row.techniques.map((item) => (
                          <li>{item}</li>
                        ))}
                      </ul>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="qual-source">Liamputtong and Ezzy (2009)</p>
        </section>

        <section id="focus-groups" class="qual-subsection">
          <h3>Focus groups</h3>
          <p>
            6&ndash;8 people online. 10&ndash;12 people in person. Need to run 3 to 5 focus groups.
          </p>
        </section>

        <section id="observation" class="qual-subsection">
          <h3>Observation</h3>
          <p>
            Camera, to see <em>how</em> they behave (not count how many). Can also be document analysis.
          </p>
        </section>

        <section id="themes" class="qual-subsection">
          <h3>Themes</h3>
          <p>
            Content analysis, coding into themes. Also narrative analysis leading to themes. Themes lead to a conceptual
            model.
          </p>
        </section>

        <section id="projective-technique" class="qual-subsection">
          <h3>Projective technique</h3>
          <p>Would you recommend X to someone else?</p>
        </section>

        <section id="sentence-completion" class="qual-subsection">
          <h3>Sentence completion</h3>
          <p>I love X because &hellip;</p>
        </section>
      </section>

      <section id="measurement" class="qual-section">
        <h2>Measurement</h2>
        <p>Interviewer manual</p>
      </section>

      <section id="sampling" class="qual-section">
        <h2>Sampling</h2>
        <p>Target population</p>
      </section>

      <section id="data-analysis" class="qual-section">
        <h2>Data analysis</h2>
        <p>Content and narrative analysis &mdash; coding into themes that can inform a conceptual model.</p>

        <h3 class="qual-subheading">Qualitative data</h3>
        <p>Work through the analysis in this order:</p>
        <ol class="qual-analysis-steps">
          <li><strong>Describe sample</strong> &mdash; describe the realised sample that took part in the study.</li>
          <li>
            <strong>Discuss themes</strong> &mdash; identify themes in the data, then discuss them using direct quotes from
            participants as the primary source of evidence.
          </li>
          <li><strong>Draw conclusion</strong> &mdash; draw conclusions from the sample description and thematic discussion.</li>
        </ol>
        <p>
          At the heart of the analysis: <strong>describe the realised sample</strong> and <strong>identify themes</strong>{' '}
          before you move on to interpretation and conclusions.
        </p>
      </section>
    </article>
  </div>
</BaseLayout>

<style is:global>
  html {
    scroll-behavior: smooth;
    scroll-padding-top: 6rem;
  }
</style>

<style>
  .back-link {
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }
  .back-link a {
    color: var(--color-maroon);
  }

  .qual-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
    max-width: 1100px;
  }

  @media (min-width: 900px) {
    .qual-layout {
      grid-template-columns: min(240px, 26%) 1fr;
    }
  }

  .qual-toc {
    position: sticky;
    top: 5.5rem;
    z-index: 1;
    padding: 1rem 1.1rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    border-left: 4px solid var(--color-maroon);
    font-size: 0.88rem;
    line-height: 1.45;
    max-height: calc(100vh - 6rem);
    overflow-y: auto;
  }

  .qual-toc-title {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-ink-muted);
    margin: 0 0 0.65rem 0;
  }

  .qual-toc-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .qual-toc-list > li {
    margin-bottom: 0.45rem;
  }

  .qual-toc-list ol {
    margin: 0.35rem 0 0.5rem 0;
    padding-left: 1rem;
    list-style: none;
    border-left: 2px solid var(--color-border);
  }

  .qual-toc-list ol li {
    margin-bottom: 0.3rem;
  }

  .qual-toc a {
    color: var(--color-maroon);
    text-decoration: none;
  }

  .qual-toc a:hover {
    text-decoration: underline;
  }

  .qual-article {
    min-width: 0;
  }

  .qual-article h1 {
    font-family: var(--font-serif);
    font-size: clamp(1.45rem, 3vw, 1.85rem);
    color: var(--color-maroon);
    margin: 0 0 1rem 0;
    scroll-margin-top: 5.5rem;
  }

  .qual-lead {
    margin: 0 0 1rem 0;
    line-height: 1.7;
    color: var(--color-ink);
    max-width: 42rem;
  }

  .qual-intro-block {
    margin-bottom: 1.5rem;
    max-width: 42rem;
  }

  .qual-intro-heading {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    color: var(--color-maroon);
    margin: 0 0 0.85rem 0;
  }

  .qual-intro-list {
    margin: 0 0 1.25rem 0;
    padding-left: 1.5rem;
    line-height: 1.7;
    color: var(--color-ink);
  }

  .qual-intro-list li {
    margin-bottom: 0.55rem;
  }

  .qual-quote {
    margin: 0 0 1rem 0;
    padding: 0 0 0 1rem;
    border-left: 3px solid var(--color-maroon-muted);
  }

  .qual-quote p {
    margin: 0 0 0.65rem 0;
    line-height: 1.65;
    color: var(--color-ink);
    font-size: 0.95rem;
  }

  .qual-quote-attribution {
    font-size: 0.88rem;
    color: var(--color-ink-muted);
    font-style: italic;
  }

  .qual-reference {
    margin: 0;
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
  }

  .qual-section {
    margin-top: 2.5rem;
    scroll-margin-top: 5.5rem;
  }

  .qual-section > h2 {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    color: var(--color-maroon);
    margin: 0 0 1rem 0;
    line-height: 1.3;
    scroll-margin-top: 5.5rem;
  }

  .qual-subsection {
    margin-top: 1.75rem;
    scroll-margin-top: 5.5rem;
  }

  .qual-subsection > h3 {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--color-ink);
    margin: 0 0 0.75rem 0;
    scroll-margin-top: 5.5rem;
  }

  .qual-table-heading {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 1.5rem 0 0.75rem 0;
  }

  .qual-subheading {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: var(--color-ink);
    margin: 1.25rem 0 0.75rem 0;
  }

  .qual-section p,
  .qual-subsection p {
    margin: 0 0 1rem 0;
    line-height: 1.7;
    color: var(--color-ink);
    max-width: 42rem;
  }

  .qual-analysis-steps {
    margin: 0 0 1rem 0;
    padding-left: 1.5rem;
    line-height: 1.75;
    max-width: 42rem;
  }

  .qual-analysis-steps li {
    margin-bottom: 0.65rem;
  }

  .qual-table-wrap {
    overflow-x: auto;
    margin: 0 0 0.5rem 0;
    max-width: 100%;
  }

  .qual-rigour-table {
    width: 100%;
    min-width: 36rem;
    border-collapse: collapse;
    font-size: 0.88rem;
    line-height: 1.45;
  }

  .qual-rigour-table th,
  .qual-rigour-table td {
    border: 1px solid var(--color-border);
    padding: 0.65rem 0.75rem;
    text-align: left;
    vertical-align: top;
  }

  .qual-rigour-table thead th {
    background: rgba(113, 32, 56, 0.08);
    color: var(--color-maroon);
    font-weight: 700;
  }

  .qual-rigour-table tbody th {
    background: rgba(113, 32, 56, 0.05);
    font-weight: 600;
    white-space: nowrap;
  }

  .qual-rigour-table ul {
    margin: 0;
    padding-left: 1.1rem;
  }

  .qual-rigour-table li {
    margin-bottom: 0.25rem;
  }

  .qual-rigour-table li:last-child {
    margin-bottom: 0;
  }

  .qual-source {
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    font-style: italic;
  }
</style>
