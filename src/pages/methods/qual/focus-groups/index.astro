---
import QualMethodLayout from '../../../../components/QualMethodLayout.astro';
---

<QualMethodLayout title="Focus groups" description="Qualitative focus groups — group dynamics, narrative data, and facilitation">
  <h1>Focus groups</h1>
  <p>
    A group of people (5&ndash;10) with certain characteristics generate narrative data in a focused discussion.
  </p>

  <section class="fg-section">
    <h2>Interaction and group dynamics are essential</h2>
    <ul class="fg-list">
      <li>Widens range of responses</li>
      <li>Activates forgotten details</li>
      <li>Releases inhibitions</li>
      <li>Eddying</li>
    </ul>
  </section>

  <section class="fg-section">
    <h2>Facilitation</h2>
    <p>Avoid power differentials.</p>
  </section>

  <section class="fg-section">
    <h2>Practical notes</h2>
    <ul class="fg-list">
      <li>6&ndash;8 people online</li>
      <li>10&ndash;12 people in person</li>
      <li>Need to run 3 to 5 focus groups</li>
      <li>Generate unique insights into shared experiences and social norms</li>
    </ul>
  </section>
</QualMethodLayout>

<style>
  .fg-section {
    margin-top: 1.75rem;
  }

  .fg-section h2 {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-maroon);
    margin: 0 0 0.75rem 0;
  }

  .fg-list {
    margin: 0;
    padding-left: 1.25rem;
    line-height: 1.7;
    color: var(--color-ink);
  }

  .fg-list li {
    margin-bottom: 0.35rem;
  }

  .fg-list li:last-child {
    margin-bottom: 0;
  }
</style>
