---
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

const onionCx = 410;
const onionCy = 470;

type OnionRing = {
  rx: number;
  ry: number;
  fill: string;
  stroke: string;
  title: string;
  items: string[];
  itemFontSize?: number;
};

const onionRings: OnionRing[] = [
  {
    rx: 370,
    ry: 410,
    fill: '#e8e8e8',
    stroke: '#c8c8c8',
    title: 'Research philosophy',
    items: ['Positivism', 'Critical realism', 'Interpretivism', 'Postmodernism', 'Pragmatism'],
  },
  {
    rx: 310,
    ry: 345,
    fill: '#ebe3d4',
    stroke: '#d4c8b4',
    title: 'Research approach',
    items: ['Inductive', 'Deductive', 'Abductive'],
  },
  {
    rx: 252,
    ry: 282,
    fill: '#dce8cc',
    stroke: '#c0d4a8',
    title: 'Methodological choice',
    items: ['Qualitative', 'Mixed methods', 'Quantitative'],
  },
  {
    rx: 196,
    ry: 220,
    fill: '#b8d4a4',
    stroke: '#9ec088',
    title: 'Research strategy',
    items: [
      'Experimental',
      'Survey',
      'Case study',
      'Ethnography',
      'Narrative',
      'Grounded theory',
      'Action research',
      'Archival research',
    ],
    itemFontSize: 10,
  },
  {
    rx: 142,
    ry: 160,
    fill: '#c8deb8',
    stroke: '#aac894',
    title: 'Time horizon',
    items: ['Cross-sectional', 'Longitudinal'],
  },
];

const onionCore = { rx: 88, ry: 98, fill: '#d4e0ea', stroke: '#a8bcc8', label: 'Data collection and analysis' };

function bandPoint(
  angleDeg: number,
  rxOuter: number,
  ryOuter: number,
  rxInner: number,
  ryInner: number,
  bias: 'mid' | 'outer' | 'title' = 'mid',
) {
  const biasMap = { mid: 0.5, outer: 0.72, title: 0.84 };
  const t = biasMap[bias];
  const rx = rxInner + (rxOuter - rxInner) * t;
  const ry = ryInner + (ryOuter - ryInner) * t;
  const rad = ((angleDeg - 90) * Math.PI) / 180;
  return { x: onionCx + rx * Math.cos(rad), y: onionCy + ry * Math.sin(rad) };
}

function spreadAngles(count: number, startDeg: number, endDeg: number) {
  if (count <= 1) return [(startDeg + endDeg) / 2];
  const step = (endDeg - startDeg) / (count - 1);
  return Array.from({ length: count }, (_, i) => startDeg + step * i);
}

type OnionLabel = {
  text: string;
  x: number;
  y: number;
  kind: 'title' | 'item';
  fontSize?: number;
  textAnchor?: 'start' | 'middle' | 'end';
};

/** Stagger ring titles on the upper-left arc — avoids stacking on the horizontal midline (angle −90). */
const titleAngles = [-46, -54, -62, -70, -78];

function itemAngles(count: number, fullCircle: boolean) {
  if (fullCircle) {
    const step = 360 / count;
    const offset = -90 + step / 2;
    return Array.from({ length: count }, (_, i) => offset + step * i);
  }
  return spreadAngles(count, -165, 20);
}

const onionLabels: OnionLabel[] = [];

onionRings.forEach((ring, index) => {
  const inner = index < onionRings.length - 1 ? onionRings[index + 1] : onionCore;
  const titlePos = bandPoint(titleAngles[index], ring.rx, ring.ry, inner.rx, inner.ry, 'title');
  onionLabels.push({
    text: ring.title,
    x: titlePos.x,
    y: titlePos.y,
    kind: 'title',
    textAnchor: 'end',
  });

  const fullCircle = ring.items.length >= 6;
  const angles = itemAngles(ring.items.length, fullCircle);

  ring.items.forEach((item, itemIndex) => {
    const pos = bandPoint(angles[itemIndex], ring.rx, ring.ry, inner.rx, inner.ry, 'mid');
    onionLabels.push({ text: item, x: pos.x, y: pos.y, kind: 'item', fontSize: ring.itemFontSize });
  });
});
---

<BaseLayout title="Methods" description="Data collection and analysis — quantitative and qualitative approaches">
  <h1>Methods</h1>
  <p class="page-desc">
    The method implies getting data and using data (analysis). There are two types of data: numerical and
    non-numerical (words). Your research objective dictates whether you need numbers, words, or both. There are three
    different ways of getting the data.
  </p>
  <p class="methods-note"><strong>Data is always contextual. Not theory (content).</strong></p>

  <section class="methods-literature" aria-label="The scientific method">
    <h2 class="methods-literature-title">The scientific method</h2>
    <ul class="methods-scientific-list">
      <li>
        Science and the application of the scientific method provide for a{' '}
        <strong>robust, systematic, and objective approach to addressing inquiries</strong> where{' '}
        <strong>decisions made within the process are justified and based on evidence.</strong>
      </li>
      <li>
        Information and/or data that are:
        <ol class="methods-scientific-criteria">
          <li>Transparent</li>
          <li>Replicable</li>
          <li>Reliable (i.e. the degree to which an execution produces the same results)</li>
          <li>Valid (i.e. whether what was attempted to be measured was measured).</li>
          <li>Open to scrutiny</li>
        </ol>
      </li>
    </ul>
  </section>

  <section class="methods-literature" aria-label="What sources to include">
    <h2 class="methods-literature-title">What sources to include?</h2>
    <p>
      <strong>Seminal and most cited.</strong> Seminal works deal with fundamental concepts — the papers cited most often.
      Academics also look at <strong>recency</strong>.
      Why are so many papers slightly dated? You need far more references from the <strong>last five years</strong>.
    </p>
    <p>
      You want some fundamental works, but <strong>err on the side of recency</strong>. For methods and techniques too: what
      have people done in the last five years? Academics are very interested in what is <strong>new</strong> and what is
      <strong>evolving</strong>. Recency matters — spend a lot of time in recent work. Or you may find that people still do
      it the same way.
    </p>
  </section>

  <section class="methods-onion-section" aria-label="Research onion">
    <h2 class="methods-literature-title">Research onion</h2>
    <p class="methods-onion-intro">
      Saunders et al.&rsquo;s research onion — layers from research philosophy inward to data collection and analysis.
    </p>
    <figure class="methods-onion-figure">
      <svg
        class="methods-onion-svg"
        viewBox="0 0 820 900"
        role="img"
        aria-label="Research onion: research philosophy, approach, methodological choice, strategy, time horizon, and data collection and analysis"
      >
        {onionRings.map((ring) => (
          <ellipse cx={onionCx} cy={onionCy} rx={ring.rx} ry={ring.ry} fill={ring.fill} stroke={ring.stroke} stroke-width="1.5" />
        ))}
        <ellipse
          cx={onionCx}
          cy={onionCy}
          rx={onionCore.rx}
          ry={onionCore.ry}
          fill={onionCore.fill}
          stroke={onionCore.stroke}
          stroke-width="1.5"
        />
        {onionLabels.map((label) => (
          <text
            x={label.x}
            y={label.y}
            text-anchor={label.textAnchor ?? 'middle'}
            dominant-baseline="middle"
            class:list={[
              label.kind === 'title' ? 'onion-layer-title' : 'onion-layer-items',
              label.fontSize ? 'onion-layer-items--small' : null,
            ]}
            font-size={label.fontSize}
          >
            {label.text}
          </text>
        ))}
        <text x={onionCx} y={onionCy - 6} text-anchor="middle" dominant-baseline="middle" class="onion-core-title">
          <tspan x={onionCx} dy="0">Data collection</tspan>
          <tspan x={onionCx} dy="1.15em">and analysis</tspan>
        </text>
      </svg>
      <figcaption class="methods-onion-caption">Adapted from Saunders, Lewis &amp; Thornhill, <em>Research Methods for Business Students</em>.</figcaption>
    </figure>
  </section>

  <div class="methods-hub-grid">
    <a href={`${base}methods/qual-vs-quant/`} class="methods-hub-card">
      <span class="methods-hub-icon" aria-hidden="true">⚖️</span>
      <h2 class="methods-hub-title">Qual vs Quant</h2>
      <p class="methods-hub-desc">
        Side-by-side comparison — definitions, data/analysis distinctions, reliability, validity, and rigour.
      </p>
      <span class="methods-hub-link">Open qual vs quant →</span>
    </a>
    <a href={`${base}methods/quant/`} class="methods-hub-card">
      <span class="methods-hub-icon" aria-hidden="true">📊</span>
      <h2 class="methods-hub-title">Quant</h2>
      <p class="methods-hub-desc">
        Secondary and primary quantitative data — sources, operationalisation, model specification, surveys,
        experiments, measurement items, and inferential analysis.
      </p>
      <span class="methods-hub-link">Open quant →</span>
    </a>
    <a href={`${base}methods/qual/`} class="methods-hub-card">
      <span class="methods-hub-icon" aria-hidden="true">💬</span>
      <h2 class="methods-hub-title">Qual</h2>
      <p class="methods-hub-desc">
        Primary qualitative data — interviews, focus groups, observation, document analysis, coding, and thematic
        analysis.
      </p>
      <span class="methods-hub-link">Open qual →</span>
    </a>
    <a href={`${base}methods/secondary-data/`} class="methods-hub-card">
      <span class="methods-hub-icon" aria-hidden="true">🗄️</span>
      <h2 class="methods-hub-title">Secondary data</h2>
      <p class="methods-hub-desc">
        World Bank, IMF, company performance data, and other existing sources — a valid alternative to collecting primary
        data yourself.
      </p>
      <span class="methods-hub-link">Open secondary data →</span>
    </a>
    <a href={`${base}methods/sampling/`} class="methods-hub-card">
      <span class="methods-hub-icon" aria-hidden="true">🎯</span>
      <h2 class="methods-hub-title">Sampling</h2>
      <p class="methods-hub-desc">
        Probability and non-probability sampling — simple random, stratified, convenience, snowball, and more.
      </p>
      <span class="methods-hub-link">Open sampling →</span>
    </a>
    <a href={`${base}methods/theory-maturity/`} class="methods-hub-card">
      <span class="methods-hub-icon" aria-hidden="true">📐</span>
      <h2 class="methods-hub-title">Theory maturity</h2>
      <p class="methods-hub-desc">
        Nascent, intermediate, and mature theory — alignment of questions, data, analysis, and contribution.
      </p>
      <span class="methods-hub-link">Open theory maturity →</span>
    </a>
    <a href={`${base}methods/uoa/`} class="methods-hub-card">
      <span class="methods-hub-icon" aria-hidden="true">🔍</span>
      <h2 class="methods-hub-title">UoA</h2>
      <p class="methods-hub-desc">
        Unit of analysis — individuals, groups, organizations, social interactions, and artifacts.
      </p>
      <span class="methods-hub-link">Open UoA →</span>
    </a>
    <a href={`${base}methods/ethics/`} class="methods-hub-card">
      <span class="methods-hub-icon" aria-hidden="true">⚖️</span>
      <h2 class="methods-hub-title">Ethics</h2>
      <p class="methods-hub-desc">
        Ethical clearance before primary data collection — risk level, participant protection, anonymity, and data
        security.
      </p>
      <span class="methods-hub-link">Open ethics →</span>
    </a>
  </div>
</BaseLayout>

<style>
  .page-desc {
    color: var(--color-ink-muted);
    margin-bottom: 1rem;
    line-height: 1.6;
    max-width: 40rem;
  }

  .methods-note {
    margin: 0 0 1.5rem 0;
    max-width: 40rem;
    line-height: 1.6;
  }

  .methods-literature {
    max-width: 40rem;
    margin-bottom: 2.5rem;
    padding: 1.25rem 1.5rem;
    background: rgba(113, 32, 56, 0.06);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-maroon);
    border-radius: 8px;
  }

  .methods-literature-title {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--color-maroon);
    margin: 0 0 0.75rem 0;
  }

  .methods-literature p {
    margin: 0 0 0.75rem 0;
    line-height: 1.6;
    color: var(--color-ink);
    font-size: 0.95rem;
  }

  .methods-literature p:last-child {
    margin-bottom: 0;
  }

  .methods-scientific-list {
    margin: 0;
    padding-left: 1.25rem;
    line-height: 1.6;
    color: var(--color-ink);
    font-size: 0.95rem;
  }

  .methods-scientific-list > li {
    margin-bottom: 0.75rem;
  }

  .methods-scientific-list > li:last-child {
    margin-bottom: 0;
  }

  .methods-scientific-criteria {
    margin: 0.5rem 0 0 0;
    padding-left: 1.25rem;
    line-height: 1.55;
  }

  .methods-scientific-criteria li {
    margin-bottom: 0.35rem;
  }

  .methods-scientific-criteria li:last-child {
    margin-bottom: 0;
  }

  .methods-onion-section {
    max-width: 52rem;
    margin-bottom: 2.5rem;
    padding: 1.25rem 1.5rem;
    background: rgba(113, 32, 56, 0.04);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-maroon);
    border-radius: 8px;
  }

  .methods-onion-intro {
    margin: 0 0 1.25rem 0;
    line-height: 1.6;
    color: var(--color-ink-muted);
    font-size: 0.95rem;
    max-width: 40rem;
  }

  .methods-onion-figure {
    margin: 0;
  }

  .methods-onion-svg {
    display: block;
    width: 100%;
    max-width: 680px;
    height: auto;
    margin: 0 auto;
  }

  .methods-onion-svg :global(.onion-layer-title) {
    font-family: var(--font-serif);
    font-size: 13px;
    font-weight: 700;
    fill: var(--color-maroon);
  }

  .methods-onion-svg :global(.onion-layer-items) {
    font-family: var(--font-sans);
    font-size: 11.5px;
    fill: var(--color-ink);
  }

  .methods-onion-svg :global(.onion-layer-items--small) {
    font-size: 10px;
  }

  .methods-onion-svg :global(.onion-core-title) {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 700;
    fill: var(--color-ink);
  }

  .methods-onion-caption {
    margin-top: 0.75rem;
    font-size: 0.82rem;
    color: var(--color-ink-muted);
    text-align: center;
  }

  .methods-hub-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .methods-hub-card {
    display: flex;
    flex-direction: column;
    padding: 2rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    border-left: 4px solid var(--color-maroon);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .methods-hub-card:hover {
    border-color: var(--color-maroon-muted);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    text-decoration: none;
    color: inherit;
  }

  .methods-hub-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .methods-hub-title {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    margin: 0 0 0.5rem 0;
    color: var(--color-maroon);
  }

  .methods-hub-desc {
    flex: 1;
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--color-ink);
  }

  .methods-hub-link {
    margin-top: 1rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-maroon);
  }
</style>
