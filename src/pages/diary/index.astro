---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DiaryPage from '../../components/DiaryPage';
---

<BaseLayout title="Diary" description="Research diary - daily reflections, tags, linked constructs">
  <h1>Research Diary</h1>
  <p class="page-desc">Log what you did each day. Add entries below and browse your history—all saved to your Supabase database.</p>

  <DiaryPage client:load />
</BaseLayout>

<style>
  .page-desc {
    color: var(--color-ink-muted);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  /* Add-entry section */
  .diary-add-section {
    margin-bottom: 3rem;
    padding: 2rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    box-shadow: var(--shadow-sm);
  }

  .diary-add-btn {
    margin-bottom: 2rem;
    padding: 0.65rem 1.25rem;
    background: var(--color-maroon);
    color: #fff;
    border: 2px solid var(--color-gold);
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    font-size: 0.95rem;
    transition: background 0.2s, border-color 0.2s;
  }

  .diary-add-btn:hover {
    background: var(--color-maroon-dark);
    border-color: var(--color-gold-light);
  }

  /* Form container – wider for summary and details */
  .diary-form {
    max-width: 960px;
    padding: 2.5rem 3rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    border-left: 4px solid var(--color-maroon);
    box-shadow: var(--shadow-sm);
  }

  .diary-form-title {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    color: var(--color-ink);
    margin: 0 0 0.5rem 0;
  }

  .form-date-hint {
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    margin-bottom: 2.5rem;
  }

  /* Form fields: stacked, generous spacing */
  .diary-form-field {
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .diary-form-field-details {
    margin-bottom: 3.5rem;
    gap: 1rem;
  }

  .diary-form-field-details label {
    display: block;
    margin-bottom: 0.25rem;
  }

  .diary-form-field label,
  .diary-form-label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-ink);
  }

  .diary-input,
  .diary-textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 2px solid var(--color-border);
    border-radius: 8px;
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-ink);
    background: #fff;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .diary-input:focus,
  .diary-textarea:focus {
    outline: none;
    border-color: var(--color-maroon);
    box-shadow: 0 0 0 3px rgba(113, 32, 56, 0.12);
  }

  .diary-input::placeholder,
  .diary-textarea::placeholder {
    color: var(--color-ink-muted);
    opacity: 0.8;
  }

  .diary-textarea {
    min-height: 260px;
    resize: vertical;
    line-height: 1.6;
  }

  /* Tags – bigger chips, more space, nicer color */
  .tag-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  .tag-chip {
    padding: 0.6rem 1.2rem;
    border: 2px solid var(--color-border);
    background: var(--color-bg-alt);
    border-radius: 999px;
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-ink);
    transition: border-color 0.2s, background 0.2s, color 0.2s;
  }

  .tag-chip:hover {
    border-color: var(--color-maroon-muted);
    background: rgba(113, 32, 56, 0.06);
  }

  .tag-chip.selected {
    background: var(--color-maroon);
    color: #fff;
    border-color: var(--color-maroon);
  }

  /* Submit */
  .diary-submit {
    margin-top: 1.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--color-maroon);
    color: #fff;
    border: 2px solid var(--color-gold);
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    font-size: 1rem;
    transition: background 0.2s, border-color 0.2s;
  }

  .diary-submit:hover:not(:disabled) {
    background: var(--color-maroon-dark);
    border-color: var(--color-gold-light);
  }

  .diary-submit:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  /* Filters */
  .diary-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .diary-search {
    flex: 1;
    min-width: 200px;
    padding: 0.65rem 1rem;
    border: 2px solid var(--color-border);
    border-radius: 8px;
    font-size: 0.95rem;
  }

  .diary-search:focus {
    outline: none;
    border-color: var(--color-maroon);
  }

  .diary-select,
  .diary-date {
    padding: 0.65rem 1rem;
    border: 2px solid var(--color-border);
    border-radius: 8px;
    font-size: 0.95rem;
  }

  /* History */
  .diary-history-section {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .diary-history-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--color-border);
    color: var(--color-ink);
  }

  .diary-entries {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .diary-entry {
    padding: 1.5rem 1.75rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    box-shadow: var(--shadow-sm);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .diary-entry:hover {
    border-color: var(--color-maroon-muted);
    box-shadow: var(--shadow-md);
  }

  .entry-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .entry-header time {
    font-size: 0.9rem;
    color: var(--color-ink-muted);
  }

  .entry-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag-badge {
    padding: 0.25rem 0.6rem;
    background: var(--color-bg-alt);
    font-size: 0.75rem;
    border-radius: 6px;
    color: var(--color-ink-muted);
    border: 1px solid var(--color-border);
  }

  .diary-entry h4 {
    margin: 0.5rem 0 0.75rem 0;
    font-size: 1.1rem;
    color: var(--color-ink);
    line-height: 1.4;
  }

  .entry-reflection {
    margin: 0.5rem 0;
    color: var(--color-ink-muted);
    line-height: 1.6;
    font-size: 0.95rem;
  }

  .entry-constructs {
    font-size: 0.9rem;
    margin-top: 0.75rem;
    color: var(--color-ink-muted);
  }

  /* Setup / loading / empty / error */
  .diary-setup {
    max-width: 480px;
    padding: 2rem 2.5rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    border-left: 4px solid var(--color-gold);
  }

  .diary-setup-hint {
    font-size: 0.9rem;
    margin-top: 1rem;
    color: var(--color-ink-muted);
  }

  .diary-setup code,
  .diary-setup-hint code {
    background: var(--color-bg-alt);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-size: 0.85rem;
  }

  .diary-loading {
    padding: 2.5rem;
    color: var(--color-ink-muted);
    text-align: center;
  }

  .diary-error {
    color: var(--color-maroon);
    font-size: 0.95rem;
    margin-bottom: 1.25rem;
    padding: 1rem 1.25rem;
    background: rgba(113, 32, 56, 0.08);
    border-radius: 8px;
    border-left: 4px solid var(--color-maroon);
  }

  .diary-empty {
    color: var(--color-ink-muted);
    padding: 2.5rem;
    text-align: center;
    font-size: 0.95rem;
  }

  .entry-count {
    font-weight: 400;
    color: var(--color-ink-muted);
    font-size: 0.95rem;
  }
</style>
