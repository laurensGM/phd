---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DiaryPage from '../../components/DiaryPage';
---

<BaseLayout title="Diary" description="Research diary - daily reflections, tags, linked constructs">
  <h1>Research Diary</h1>
  <p class="page-desc">Log what you did each day. Add entries below and browse your history—all saved to your Supabase database.</p>

  <DiaryPage client:load />
</BaseLayout>

<style>
  .page-desc {
    color: var(--color-ink-muted);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  /* React-rendered diary content: use :global() so styles apply to component output */
  :global(.diary-page .diary-add-section) {
    margin-bottom: 1.5rem;
  }
  :global(.diary-page .diary-add-btn) {
    margin-bottom: 0;
    padding: 0.55rem 1.1rem;
    background: var(--color-maroon);
    color: #fff;
    border: 2px solid var(--color-gold);
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    font-size: 0.95rem;
    transition: background 0.2s, border-color 0.2s;
  }
  :global(.diary-page .diary-add-btn:hover) {
    background: var(--color-maroon-dark);
    border-color: var(--color-gold-light);
  }
  :global(.diary-page .diary-add-section:has(.diary-form) .diary-add-btn) {
    margin-bottom: 1rem;
  }

  :global(.diary-page .diary-form) {
    max-width: 960px;
    margin-top: 0;
    padding: 1.5rem 1.75rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    border-left: 4px solid var(--color-maroon);
    box-shadow: var(--shadow-sm);
  }
  :global(.diary-page .diary-form-title) {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    color: var(--color-ink);
    margin: 0 0 0.5rem 0;
  }
  :global(.diary-page .form-date-hint) {
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    margin-bottom: 2.5rem;
  }

  :global(.diary-page .diary-form-field) {
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  :global(.diary-page .diary-form-field-details) {
    margin-bottom: 3.5rem;
    gap: 1.25rem;
  }
  :global(.diary-page .diary-form-field-details label) {
    display: block;
    margin-bottom: 0;
    flex-shrink: 0;
  }

  :global(.diary-page .diary-format-hint) {
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    line-height: 1.45;
  }

  :global(.diary-page .diary-format-hint kbd) {
    display: inline-block;
    padding: 0.1rem 0.35rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: #f7f5f2;
    font-size: 0.8rem;
    font-family: var(--font-sans);
  }

  :global(.diary-page .diary-format-hint code) {
    font-size: 0.8rem;
    padding: 0.1rem 0.35rem;
    background: var(--color-bg-alt);
    border-radius: 4px;
  }

  :global(.diary-page .diary-form-field label),
  :global(.diary-page .diary-form-label) {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-ink);
  }

  :global(.diary-page .diary-input),
  :global(.diary-page .diary-textarea) {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 2px solid var(--color-border);
    border-radius: 8px;
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-ink);
    background: #fff;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }
  :global(.diary-page .diary-input:focus),
  :global(.diary-page .diary-textarea:focus) {
    outline: none;
    border-color: var(--color-maroon);
    box-shadow: 0 0 0 3px rgba(113, 32, 56, 0.12);
  }
  :global(.diary-page .diary-input::placeholder),
  :global(.diary-page .diary-textarea::placeholder) {
    color: var(--color-ink-muted);
    opacity: 0.8;
  }
  :global(.diary-page .diary-textarea) {
    min-height: 260px;
    resize: vertical;
    line-height: 1.6;
  }

  :global(.diary-page .tag-chips) {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  :global(.diary-page .tag-chip) {
    padding: 0.65rem 1.35rem;
    border: 2px solid var(--color-border);
    background: var(--color-bg-alt);
    border-radius: 999px;
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-ink);
    transition: border-color 0.2s, background 0.2s, color 0.2s;
  }
  :global(.diary-page .tag-chip:hover) {
    border-color: var(--color-maroon-muted);
    background: rgba(113, 32, 56, 0.06);
  }
  :global(.diary-page .tag-chip.selected) {
    background: var(--color-maroon);
    color: #fff;
    border-color: var(--color-maroon);
  }

  :global(.diary-page .diary-submit) {
    margin-top: 1.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--color-maroon);
    color: #fff;
    border: 2px solid var(--color-gold);
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    font-size: 1rem;
    transition: background 0.2s, border-color 0.2s;
  }
  :global(.diary-page .diary-submit:hover:not(:disabled)) {
    background: var(--color-maroon-dark);
    border-color: var(--color-gold-light);
  }
  :global(.diary-page .diary-submit:disabled) {
    opacity: 0.7;
    cursor: not-allowed;
  }

  :global(.diary-page .diary-filters) {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  :global(.diary-page .diary-search) {
    flex: 1;
    min-width: 200px;
    padding: 0.65rem 1rem;
    border: 2px solid var(--color-border);
    border-radius: 8px;
    font-size: 0.95rem;
  }
  :global(.diary-page .diary-search:focus) {
    outline: none;
    border-color: var(--color-maroon);
  }
  :global(.diary-page .diary-select),
  :global(.diary-page .diary-date) {
    padding: 0.65rem 1rem;
    border: 2px solid var(--color-border);
    border-radius: 8px;
    font-size: 0.95rem;
  }

  :global(.diary-page .diary-history-section) {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
  :global(.diary-page .diary-history-title) {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--color-border);
    color: var(--color-ink);
  }
  :global(.diary-page .diary-entries) {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  :global(.diary-page .diary-entry) {
    padding: 0;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    box-shadow: var(--shadow-sm);
    transition: border-color 0.2s, box-shadow 0.2s;
    overflow: hidden;
  }
  :global(.diary-page .diary-entry:hover),
  :global(.diary-page .diary-entry.is-open) {
    border-color: var(--color-maroon-muted);
    box-shadow: var(--shadow-md);
  }
  :global(.diary-page .diary-entry-summary) {
    display: grid;
    grid-template-columns: auto minmax(6.5rem, auto) minmax(0, 1fr);
    align-items: center;
    gap: 0.75rem 1rem;
    width: 100%;
    padding: 0.85rem 1.1rem;
    margin: 0;
    border: none;
    background: transparent;
    text-align: left;
    cursor: pointer;
    font: inherit;
    color: inherit;
  }
  :global(.diary-page .diary-entry-summary:hover) {
    background: rgba(113, 32, 56, 0.04);
  }
  :global(.diary-page .diary-entry-summary:focus-visible) {
    outline: 2px solid var(--color-maroon);
    outline-offset: -2px;
  }
  :global(.diary-page .diary-entry-chevron) {
    color: var(--color-maroon);
    font-size: 0.85rem;
    width: 1rem;
    text-align: center;
  }
  :global(.diary-page .diary-entry-date) {
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    white-space: nowrap;
  }
  :global(.diary-page .diary-entry-title) {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-ink);
    line-height: 1.35;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  :global(.diary-page .diary-entry-detail) {
    padding: 0 1.1rem 1.15rem;
    border-top: 1px solid var(--color-border);
  }
  :global(.diary-page .diary-entry-detail-bar) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-top: 0.85rem;
    margin-bottom: 0.75rem;
  }
  :global(.diary-page .diary-entry-empty-content) {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    font-style: italic;
  }

  :global(.diary-page .entry-header) {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  :global(.diary-page .entry-header-actions) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-left: auto;
  }

  :global(.diary-page .diary-btn-secondary) {
    padding: 0.35rem 0.75rem;
    font-size: 0.85rem;
    font-weight: 600;
    border-radius: 6px;
    cursor: pointer;
    font-family: var(--font-sans);
    border: 1px solid var(--color-border);
    background: #fff;
    color: var(--color-ink);
  }

  :global(.diary-page .diary-btn-secondary:hover) {
    border-color: var(--color-maroon-muted);
    background: rgba(113, 32, 56, 0.06);
  }

  :global(.diary-page .diary-edit-form) {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1.15rem 1.25rem;
  }

  :global(.diary-page .diary-edit-form .diary-form-field) {
    margin-bottom: 1.25rem;
  }

  :global(.diary-page .diary-edit-title) {
    margin: 0 0 0.75rem 0;
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: var(--color-maroon);
  }

  :global(.diary-page .diary-entry-actions) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  :global(.diary-page .diary-entry-actions .diary-submit) {
    margin-top: 0;
  }
  :global(.diary-page .entry-header time) {
    font-size: 0.9rem;
    color: var(--color-ink-muted);
  }
  :global(.diary-page .entry-tags) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  :global(.diary-page .tag-badge) {
    padding: 0.25rem 0.6rem;
    background: var(--color-bg-alt);
    font-size: 0.75rem;
    border-radius: 6px;
    color: var(--color-ink-muted);
    border: 1px solid var(--color-border);
  }
  :global(.diary-page .entry-reflection) {
    margin: 0;
    color: var(--color-ink-muted);
    line-height: 1.6;
    font-size: 0.95rem;
  }
  :global(.diary-page .entry-reflection .fmt-text-block) {
    display: block;
  }
  :global(.diary-page .entry-reflection .fmt-text-block + .fmt-bullet-list),
  :global(.diary-page .entry-reflection .fmt-bullet-list + .fmt-text-block) {
    margin-top: 0.5rem;
  }
  :global(.diary-page .entry-reflection .fmt-bullet-list) {
    margin: 0.35rem 0;
    padding-left: 1.25rem;
  }
  :global(.diary-page .entry-reflection .fmt-bullet-list ul) {
    margin: 0.2rem 0;
    padding-left: 1.15rem;
  }
  :global(.diary-page .entry-reflection .fmt-bullet-list li) {
    margin: 0.15rem 0;
  }

  :global(.diary-page .entry-reflection strong),
  :global(.diary-page .diary-entry-title strong) {
    font-weight: 700;
    color: var(--color-ink);
  }
  :global(.diary-page .entry-constructs) {
    font-size: 0.9rem;
    margin-top: 0.75rem;
    color: var(--color-ink-muted);
  }

  @media (max-width: 720px) {
    :global(.diary-page .diary-entry-summary) {
      grid-template-columns: auto 1fr;
      grid-template-areas:
        "chevron date"
        "chevron title";
      gap: 0.2rem 0.75rem;
    }
    :global(.diary-page .diary-entry-chevron) {
      grid-area: chevron;
      align-self: start;
      padding-top: 0.15rem;
    }
    :global(.diary-page .diary-entry-date) {
      grid-area: date;
    }
    :global(.diary-page .diary-entry-title) {
      grid-area: title;
      white-space: normal;
    }
  }

  :global(.diary-page .diary-setup) {
    max-width: 480px;
    padding: 2rem 2.5rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    border-left: 4px solid var(--color-gold);
  }
  :global(.diary-page .diary-setup-hint) {
    font-size: 0.9rem;
    margin-top: 1rem;
    color: var(--color-ink-muted);
  }
  :global(.diary-page .diary-setup code),
  :global(.diary-page .diary-setup-hint code) {
    background: var(--color-bg-alt);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-size: 0.85rem;
  }
  :global(.diary-page .diary-loading) {
    padding: 2.5rem;
    color: var(--color-ink-muted);
    text-align: center;
  }
  :global(.diary-page .diary-error) {
    color: var(--color-maroon);
    font-size: 0.95rem;
    margin-bottom: 1.25rem;
    padding: 1rem 1.25rem;
    background: rgba(113, 32, 56, 0.08);
    border-radius: 8px;
    border-left: 4px solid var(--color-maroon);
  }
  :global(.diary-page .diary-empty) {
    color: var(--color-ink-muted);
    padding: 2.5rem;
    text-align: center;
    font-size: 0.95rem;
  }
  :global(.diary-page .entry-count) {
    font-weight: 400;
    color: var(--color-ink-muted);
    font-size: 0.95rem;
  }
</style>
