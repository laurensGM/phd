---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ContributionsPage from '../../../components/ContributionsPage';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Contribution"
  description="Track your research contributions — theory, practice, and methodology"
>
  <p class="back-link"><a href={`${base}research-questions/`}>← Research</a></p>
  <h1>Contribution</h1>
  <p class="page-desc">
    Capture contribution statements as you refine your thesis. Label each as theoretical, methodological, or practical —
    you can change the label when you edit an entry.
  </p>

  <ContributionsPage client:load />
</BaseLayout>

<style>
  .back-link {
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }
  .back-link a {
    color: var(--color-maroon);
  }
  .page-desc {
    color: var(--color-ink-muted);
    margin-bottom: 2rem;
    line-height: 1.6;
    max-width: 40rem;
  }

  :global(.contributions-page) {
    max-width: 720px;
  }

  :global(.contributions-setup),
  :global(.contributions-loading),
  :global(.contributions-empty) {
    color: var(--color-ink-muted);
  }

  :global(.contributions-setup) {
    padding: 1.5rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    border-left: 4px solid var(--color-gold);
  }

  :global(.contributions-setup code) {
    font-size: 0.85rem;
    background: var(--color-bg-alt);
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
  }

  :global(.contributions-error) {
    color: var(--color-maroon);
    padding: 0.75rem;
    background: rgba(113, 32, 56, 0.08);
    border-radius: 6px;
    margin-bottom: 1rem;
  }

  :global(.contributions-add-section) {
    margin-bottom: 2.5rem;
  }

  :global(.contributions-add-toggle) {
    padding: 0.55rem 1.1rem;
    background: var(--color-maroon);
    color: #fff;
    border: 2px solid var(--color-gold);
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: 0.95rem;
  }

  :global(.contributions-add-toggle:hover) {
    background: var(--color-maroon-dark);
  }

  :global(.contributions-add-form) {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    border-left: 4px solid var(--color-maroon);
  }

  :global(.contributions-add-form label) {
    font-weight: 600;
    font-size: 0.95rem;
  }

  :global(.contributions-textarea) {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 2px solid var(--color-border);
    border-radius: 8px;
    font-size: 1rem;
    font-family: var(--font-sans);
    line-height: 1.5;
    resize: vertical;
    box-sizing: border-box;
  }

  :global(.contributions-textarea:focus) {
    outline: none;
    border-color: var(--color-maroon);
  }

  :global(.contributions-format-hint) {
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-ink-muted);
  }

  :global(.contributions-format-hint code) {
    font-size: 0.8rem;
    padding: 0.1rem 0.35rem;
    background: var(--color-bg-alt);
    border-radius: 4px;
  }

  :global(.contributions-submit) {
    padding: 0.55rem 1.1rem;
    background: var(--color-maroon);
    color: #fff;
    border: 2px solid var(--color-gold);
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    font-family: var(--font-sans);
  }

  :global(.contributions-submit:hover:not(:disabled)) {
    background: var(--color-maroon-dark);
  }

  :global(.contributions-submit:disabled) {
    opacity: 0.6;
    cursor: not-allowed;
  }

  :global(.contributions-list-title) {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--color-maroon);
    margin: 0 0 0.75rem 0;
  }

  :global(.contributions-filter-bar) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-bottom: 1.25rem;
  }

  :global(.contributions-filter-chip) {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.8rem;
    font-size: 0.85rem;
    font-weight: 600;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: #fff;
    color: var(--color-ink);
    cursor: pointer;
    font-family: var(--font-sans);
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }

  :global(.contributions-filter-chip:hover) {
    border-color: var(--color-maroon-muted);
    background: rgba(113, 32, 56, 0.04);
  }

  :global(.contributions-filter-chip--active) {
    background: var(--color-maroon);
    border-color: var(--color-gold);
    color: #fff;
  }

  :global(.contributions-filter-count) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.25rem;
    padding: 0.05rem 0.35rem;
    font-size: 0.72rem;
    font-weight: 700;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.08);
  }

  :global(.contributions-filter-chip--active .contributions-filter-count) {
    background: rgba(255, 255, 255, 0.2);
  }

  :global(.contributions-count) {
    font-weight: 400;
    font-size: 0.95rem;
    color: var(--color-ink-muted);
  }

  :global(.contributions-list) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  :global(.contribution-item) {
    padding: 1.25rem 1.5rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }

  :global(.contribution-type-field) {
    margin: 0;
    padding: 0;
    border: none;
  }

  :global(.contribution-type-legend) {
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 0.45rem;
    padding: 0;
  }

  :global(.contribution-type-toggles) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  :global(.contribution-type-chip) {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 0.8rem;
    font-size: 0.85rem;
    font-weight: 600;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: #fff;
    color: var(--color-ink);
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }

  :global(.contribution-type-chip:hover) {
    border-color: var(--color-maroon-muted);
    background: rgba(113, 32, 56, 0.04);
  }

  :global(.contribution-type-chip--active) {
    background: var(--color-maroon);
    border-color: var(--color-gold);
    color: #fff;
  }

  :global(.contribution-type-radio) {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  :global(.contribution-type-badge) {
    display: inline-block;
    margin-bottom: 0.65rem;
    padding: 0.2rem 0.6rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    border-radius: 999px;
    border: 1px solid transparent;
  }

  :global(.contribution-type-badge--theoretical) {
    color: #4a2860;
    background: #ede4f4;
    border-color: #d4c0e4;
  }

  :global(.contribution-type-badge--methodological) {
    color: #2a4a60;
    background: #e4edf4;
    border-color: #c0d4e4;
  }

  :global(.contribution-type-badge--practical) {
    color: #4a4020;
    background: #f4f0e4;
    border-color: #e4d8c0;
  }

  :global(.contribution-type-badge--unset) {
    color: var(--color-ink-muted);
    background: var(--color-bg-alt);
    border-color: var(--color-border);
    text-transform: none;
    font-weight: 600;
    letter-spacing: 0;
  }

  :global(.contribution-edit) {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  :global(.contribution-content) {
    margin: 0 0 0.75rem 0;
    line-height: 1.6;
    color: var(--color-ink);
  }

  :global(.contribution-content strong) {
    font-weight: 700;
  }

  :global(.contribution-linked-snippets) {
    margin: 0.75rem 0 0.25rem;
  }

  :global(.contributions-show-snippets-btn) {
    font-size: 0.82rem;
  }

  :global(.contribution-linked-snippets-list) {
    list-style: none;
    margin: 0.65rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  :global(.contribution-linked-snippet-item) {
    padding: 0.65rem 0.75rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }

  :global(.contribution-linked-snippet-link) {
    display: block;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--color-ink);
    text-decoration: none;
    font-weight: 500;
  }

  :global(.contribution-linked-snippet-link:hover) {
    color: var(--color-maroon);
    text-decoration: underline;
  }

  :global(.contribution-linked-snippet-paper) {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.78rem;
    color: var(--color-ink-muted);
  }

  :global(.contribution-meta) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: var(--color-ink-muted);
  }

  :global(.contribution-actions) {
    display: flex;
    gap: 0.5rem;
  }

  :global(.contributions-btn) {
    padding: 0.35rem 0.75rem;
    font-size: 0.85rem;
    font-weight: 600;
    border-radius: 6px;
    cursor: pointer;
    font-family: var(--font-sans);
    border: 1px solid var(--color-border);
    background: #fff;
    color: var(--color-ink);
  }

  :global(.contributions-btn-primary) {
    background: var(--color-maroon);
    color: #fff;
    border-color: var(--color-gold);
  }

  :global(.contributions-btn-secondary:hover) {
    border-color: var(--color-maroon-muted);
    background: rgba(113, 32, 56, 0.06);
  }

  :global(.contributions-btn-delete:hover:not(:disabled)) {
    border-color: var(--color-maroon);
    color: var(--color-maroon);
  }

  :global(.contributions-btn:disabled) {
    opacity: 0.6;
    cursor: not-allowed;
  }
</style>
