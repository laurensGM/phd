---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ContributionsPage from '../../../components/ContributionsPage';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Contribution"
  description="Track your research contributions — theory, practice, and methodology"
>
  <p class="back-link"><a href={`${base}research-questions/`}>← Research design</a></p>
  <h1>Contribution</h1>
  <p class="page-desc">
    Capture contribution statements as you refine your thesis. Each entry is a simple text note you can add, edit, or remove.
  </p>

  <ContributionsPage client:load />
</BaseLayout>

<style>
  .back-link {
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }
  .back-link a {
    color: var(--color-maroon);
  }
  .page-desc {
    color: var(--color-ink-muted);
    margin-bottom: 2rem;
    line-height: 1.6;
    max-width: 40rem;
  }

  :global(.contributions-page) {
    max-width: 720px;
  }

  :global(.contributions-setup),
  :global(.contributions-loading),
  :global(.contributions-empty) {
    color: var(--color-ink-muted);
  }

  :global(.contributions-setup) {
    padding: 1.5rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    border-left: 4px solid var(--color-gold);
  }

  :global(.contributions-setup code) {
    font-size: 0.85rem;
    background: var(--color-bg-alt);
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
  }

  :global(.contributions-error) {
    color: var(--color-maroon);
    padding: 0.75rem;
    background: rgba(113, 32, 56, 0.08);
    border-radius: 6px;
    margin-bottom: 1rem;
  }

  :global(.contributions-add-form) {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
    padding: 1.5rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    border-left: 4px solid var(--color-maroon);
  }

  :global(.contributions-add-form label) {
    font-weight: 600;
    font-size: 0.95rem;
  }

  :global(.contributions-textarea) {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 2px solid var(--color-border);
    border-radius: 8px;
    font-size: 1rem;
    font-family: var(--font-sans);
    line-height: 1.5;
    resize: vertical;
    box-sizing: border-box;
  }

  :global(.contributions-textarea:focus) {
    outline: none;
    border-color: var(--color-maroon);
  }

  :global(.contributions-format-hint) {
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-ink-muted);
  }

  :global(.contributions-format-hint code) {
    font-size: 0.8rem;
    padding: 0.1rem 0.35rem;
    background: var(--color-bg-alt);
    border-radius: 4px;
  }

  :global(.contributions-submit) {
    align-self: flex-start;
    padding: 0.55rem 1.1rem;
    background: var(--color-maroon);
    color: #fff;
    border: 2px solid var(--color-gold);
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    font-family: var(--font-sans);
  }

  :global(.contributions-submit:hover:not(:disabled)) {
    background: var(--color-maroon-dark);
  }

  :global(.contributions-submit:disabled) {
    opacity: 0.6;
    cursor: not-allowed;
  }

  :global(.contributions-list-title) {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--color-maroon);
    margin: 0 0 1rem 0;
  }

  :global(.contributions-count) {
    font-weight: 400;
    font-size: 0.95rem;
    color: var(--color-ink-muted);
  }

  :global(.contributions-list) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  :global(.contribution-item) {
    padding: 1.25rem 1.5rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }

  :global(.contribution-content) {
    margin: 0 0 0.75rem 0;
    line-height: 1.6;
    color: var(--color-ink);
  }

  :global(.contribution-content strong) {
    font-weight: 700;
  }

  :global(.contribution-meta) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: var(--color-ink-muted);
  }

  :global(.contribution-actions) {
    display: flex;
    gap: 0.5rem;
  }

  :global(.contributions-btn) {
    padding: 0.35rem 0.75rem;
    font-size: 0.85rem;
    font-weight: 600;
    border-radius: 6px;
    cursor: pointer;
    font-family: var(--font-sans);
    border: 1px solid var(--color-border);
    background: #fff;
    color: var(--color-ink);
  }

  :global(.contributions-btn-primary) {
    background: var(--color-maroon);
    color: #fff;
    border-color: var(--color-gold);
  }

  :global(.contributions-btn-secondary:hover) {
    border-color: var(--color-maroon-muted);
    background: rgba(113, 32, 56, 0.06);
  }

  :global(.contributions-btn-delete:hover:not(:disabled)) {
    border-color: var(--color-maroon);
    color: var(--color-maroon);
  }

  :global(.contributions-btn:disabled) {
    opacity: 0.6;
    cursor: not-allowed;
  }
</style>
