---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

const steps = [
  { id: 'choose-topic', title: 'Choose topic' },
  { id: 'literature', title: 'Review literature / theories' },
  { id: 'define-problem', title: 'Define the problem' },
  { id: 'methodology', title: 'Methodology and design', emphasis: true },
  { id: 'ethical-clearance', title: 'Ethical clearance' },
  { id: 'data-gathering', title: 'Data gathering' },
  { id: 'analysis', title: 'Analysis' },
  { id: 'reporting', title: 'Reporting' },
];
---

<BaseLayout title="Process" description="Research process — from topic choice through reporting">
  <div class="process-layout">
    <nav class="process-toc" aria-label="On this page">
      <h2 class="process-toc-title">On this page</h2>
      <ol class="process-toc-list">
        <li><a href="#intro">Introduction</a></li>
        <li><a href="#overview">Overview diagram</a></li>
        {steps.map((step) => (
          <li>
            <a href={`#${step.id}`} class:list={[{ 'process-toc-emphasis': step.emphasis }]}>
              {step.title}
            </a>
          </li>
        ))}
      </ol>
    </nav>

    <article class="process-article">
      <p class="back-link"><a href={`${base}research-questions/`}>← Research</a></p>
      <h1 id="intro">Research process</h1>
      <p class="process-lead">
        Standard research workflow (Stellenbosch Business School). Work through these stages in order as your study
        takes shape.
      </p>

      <section id="overview" class="process-section process-overview">
        <h2>Research topic / research title</h2>
        <div
          class="process-flow"
          role="img"
          aria-label="Research process from secondary research through problem statement, objectives, method, data, ethical clearance, gathering, analysis, and reporting"
        >
          <div class="process-flow-grid">
            <div class="process-flow-top">
              <div class="process-box process-box--main process-box--tall">
                <strong class="process-box-title">Secondary research</strong>
                <ol class="process-box-list">
                  <li>Lit review</li>
                  <li>Environmental scanning</li>
                  <li>Best practice</li>
                </ol>
                <div class="process-funnel" aria-hidden="true">
                  <span class="process-funnel-ring process-funnel-ring--outer">Construct</span>
                  <span class="process-funnel-ring process-funnel-ring--mid">Concept</span>
                  <span class="process-funnel-ring process-funnel-ring--inner">Variables</span>
                </div>
                <p class="process-box-note">
                  Relationship between Y<sub>1</sub> and X<sub>1</sub> and/or difference between X<sub>1</sub> and X<sub
                    >2</sub
                  >
                </p>
              </div>

              <div class="process-arrow" aria-hidden="true"></div>

              <div class="process-step-stack">
                <div class="process-box process-box--main process-box--tall">
                  <strong class="process-box-title">Problem statement</strong>
                </div>
                <div class="process-why" aria-hidden="true">
                  <span>Why should you do this research?</span>
                </div>
              </div>

              <div class="process-arrow" aria-hidden="true"></div>

              <div class="process-box process-box--main process-box--tall">
                <strong class="process-box-title">Research objectives</strong>
                <p class="process-box-note">
                  To assess / examine / explore relationship between Y<sub>1</sub> and X<sub>1</sub> and/or to assess /
                  examine / explore the difference between X<sub>1</sub> and X<sub>2</sub>
                </p>
              </div>

              <div class="process-arrow" aria-hidden="true"></div>

              <div class="process-box process-box--main process-box--tall process-box--method">
                <strong class="process-box-title">Research method</strong>
              </div>
            </div>

            <aside class="process-data-panel">
              <strong class="process-data-title">What data needed?</strong>
              <ul class="process-data-list">
                <li class="process-data-item">Secondary data (qualitative / quantitative)</li>
                <li class="process-data-item">Primary quantitative data</li>
                <li class="process-data-item process-data-item--alt">Primary qualitative data</li>
                <li class="process-data-item process-data-item--analysis">How will data be analysed?</li>
              </ul>
            </aside>

            <div class="process-flow-bottom">
              <div class="process-box process-box--main process-box--short">
                <strong class="process-box-title">Get ethical clearance</strong>
              </div>
              <div class="process-arrow" aria-hidden="true"></div>
              <div class="process-box process-box--main process-box--short">
                <strong class="process-box-title">Data gathering / admin</strong>
              </div>
              <div class="process-arrow" aria-hidden="true"></div>
              <div class="process-box process-box--main process-box--short">
                <strong class="process-box-title">Analyse data</strong>
              </div>
              <div class="process-arrow" aria-hidden="true"></div>
              <div class="process-box process-box--main process-box--short">
                <strong class="process-box-title">Report / article</strong>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="choose-topic" class="process-section">
        <h2>Choose topic</h2>
      </section>

      <section id="literature" class="process-section">
        <h2>Review literature / theories</h2>
        <p>
          Secondary research: literature review, environmental scanning, and best practice. Narrow from construct and
          concept toward variables and the relationship you want to study.
        </p>
      </section>

      <section id="define-problem" class="process-section">
        <h2>Define the problem</h2>
        <p>
          State the problem clearly and ask: why should you do this research? Turn the problem into{' '}
          <strong>researchable questions or a hypothesis</strong> that your study can answer.
        </p>
        <p>
          Set <strong>research objectives</strong> — e.g. to assess, examine, or explore a relationship between
          variables, or a difference between groups.
        </p>
      </section>

      <section id="methodology" class="process-section process-section--emphasis">
        <h2>Methodology and design</h2>
        <p>
          Choose your research method and decide what data you need: secondary (qualitative or quantitative), primary
          quantitative, primary qualitative, and how data will be analysed.
        </p>
        <p>
          Design for <strong>rigour, reliability, and contribution</strong> from the start — your method, sampling, and
          analysis choices should support trustworthy findings and a clear scholarly contribution.
        </p>
      </section>

      <section id="ethical-clearance" class="process-section">
        <h2>Ethical clearance</h2>
        <p>
          See <a href={`${base}methods/ethics/`}>Methods → Ethics</a> for notes on ethical clearance before primary data
          collection.
        </p>
      </section>

      <section id="data-gathering" class="process-section">
        <h2>Data gathering</h2>
      </section>

      <section id="analysis" class="process-section">
        <h2>Analysis</h2>
        <p>
          Look at an example of how someone else has done it: look at a paper from a renowned academic and see how they
          did it. This can be an example for you to replicate. Look at one I like.
        </p>
        <p>
          There is a TON of options for analyzing data. The amount of tooling is insane. Look for papers in the last 3
          years — how people combine academic rigour with modern tooling that is well grounded and justified. That
          makes it easier for you. It also makes it novel!
        </p>
        <p>
          <strong>Don&rsquo;t</strong> consult textbooks or consulting firms. Don&rsquo;t reference a McKinsey paper.
          Reference peer-reviewed articles only. Choose something you&rsquo;re interested in.
        </p>
      </section>

      <section id="reporting" class="process-section">
        <h2>Reporting</h2>
        <p>
          Relate findings back to your research objectives and question. Know this upfront &mdash; before you analyse
          data, be clear how reporting will loop back to what you set out to answer.
        </p>
        <p>
          After data analysis, each of your stated objectives has to talk back to the results. For each objective: on
          this objective, these are the things the data told me.
        </p>
      </section>

      <p class="process-note">
        See also <a href={`${base}writing/lr-process/`}>Writing → LR process</a> for the literature-review workflow in
        this app.
      </p>
    </article>
  </div>
</BaseLayout>

<style is:global>
  html {
    scroll-behavior: smooth;
    scroll-padding-top: 6rem;
  }
</style>

<style>
  .back-link {
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }
  .back-link a {
    color: var(--color-maroon);
  }

  .process-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
    max-width: 1100px;
  }

  @media (min-width: 900px) {
    .process-layout {
      grid-template-columns: min(260px, 28%) 1fr;
    }
  }

  .process-toc {
    position: sticky;
    top: 5.5rem;
    z-index: 1;
    padding: 1rem 1.1rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    border-left: 4px solid var(--color-maroon);
    font-size: 0.88rem;
    line-height: 1.45;
    max-height: calc(100vh - 6rem);
    overflow-y: auto;
  }

  .process-toc-title {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-ink-muted);
    margin: 0 0 0.65rem 0;
  }

  .process-toc-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .process-toc-list > li {
    margin-bottom: 0.45rem;
  }

  .process-toc a {
    color: var(--color-maroon);
    text-decoration: none;
  }

  .process-toc a:hover {
    text-decoration: underline;
  }

  .process-toc-emphasis {
    font-weight: 700;
  }

  .process-article {
    min-width: 0;
  }

  .process-article h1 {
    font-family: var(--font-serif);
    font-size: clamp(1.45rem, 3vw, 1.85rem);
    color: var(--color-maroon);
    margin: 0 0 1rem 0;
    scroll-margin-top: 5.5rem;
  }

  .process-lead {
    margin: 0 0 1.5rem 0;
    line-height: 1.7;
    color: var(--color-ink-muted);
    max-width: 42rem;
  }

  .process-section {
    margin-top: 2rem;
    scroll-margin-top: 5.5rem;
  }

  .process-section > h2 {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    color: var(--color-maroon);
    margin: 0 0 0.75rem 0;
    line-height: 1.35;
    scroll-margin-top: 5.5rem;
  }

  .process-section--emphasis > h2 {
    font-weight: 700;
  }

  .process-section p {
    margin: 0 0 1rem 0;
    line-height: 1.7;
    color: var(--color-ink);
    max-width: 42rem;
  }

  .process-section a {
    font-weight: 600;
  }

  .process-overview {
    margin-top: 1.5rem;
  }

  .process-flow {
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: linear-gradient(160deg, #f8f6f4 0%, #f3f0ec 100%);
    overflow-x: auto;
  }

  .process-flow-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    min-width: min(100%, 52rem);
  }

  @media (min-width: 880px) {
    .process-flow-grid {
      grid-template-columns: 1fr min(11rem, 22%);
      grid-template-rows: auto auto;
      align-items: stretch;
    }

    .process-flow-top {
      grid-column: 1;
      grid-row: 1;
    }

    .process-data-panel {
      grid-column: 2;
      grid-row: 1 / 3;
    }

    .process-flow-bottom {
      grid-column: 1;
      grid-row: 2;
    }
  }

  .process-flow-top,
  .process-flow-bottom {
    display: flex;
    align-items: stretch;
    gap: 0.5rem;
  }

  .process-flow-bottom {
    padding-top: 1.25rem;
    border-top: 1px solid rgba(113, 32, 56, 0.12);
  }

  .process-arrow {
    flex: 0 0 1.25rem;
    align-self: center;
    position: relative;
    height: 2px;
    background: var(--color-maroon-muted);
    opacity: 0.45;
  }

  .process-arrow::after {
    content: '';
    position: absolute;
    right: -1px;
    top: 50%;
    transform: translateY(-50%);
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
    border-left: 7px solid var(--color-maroon-muted);
    opacity: 0.7;
  }

  .process-step-stack {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.5rem;
    flex: 1 1 5.5rem;
    min-width: 5rem;
    max-width: 7.5rem;
  }

  .process-step-stack .process-box--tall {
    flex: 1;
    min-height: 8.5rem;
  }

  .process-box {
    border-radius: 8px;
    font-size: 0.76rem;
    line-height: 1.45;
    color: #fff;
    box-shadow: 0 2px 8px rgba(113, 32, 56, 0.12);
  }

  .process-box--main {
    flex: 1 1 5.5rem;
    min-width: 5rem;
    max-width: 7.5rem;
    padding: 0.85rem 0.75rem;
    background: linear-gradient(180deg, #8a2844 0%, var(--color-maroon) 100%);
    border: 1px solid rgba(255, 255, 255, 0.12);
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .process-box--tall {
    min-height: 13.5rem;
  }

  .process-box--short {
    min-height: 5.5rem;
    justify-content: center;
    text-align: center;
  }

  .process-box-title {
    display: block;
    font-family: var(--font-serif);
    font-size: 0.82rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  }

  .process-box-list {
    margin: 0;
    padding-left: 1rem;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.92);
  }

  .process-box-list li {
    margin-bottom: 0.2rem;
  }

  .process-box-list li::marker {
    color: var(--color-gold);
  }

  .process-box-note {
    margin: auto 0 0 0;
    font-size: 0.68rem;
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.88);
  }

  .process-box-note sub {
    color: rgba(255, 255, 255, 0.95);
  }

  .process-funnel {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    margin: 0.25rem 0;
  }

  .process-funnel-ring {
    display: block;
    text-align: center;
    font-size: 0.64rem;
    font-weight: 600;
    color: var(--color-maroon);
    background: rgba(255, 255, 255, 0.95);
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: 999px;
    padding: 0.18rem 0.45rem;
  }

  .process-funnel-ring--outer {
    width: 100%;
  }

  .process-funnel-ring--mid {
    width: 82%;
  }

  .process-funnel-ring--inner {
    width: 62%;
  }

  .process-why {
    flex-shrink: 0;
    border-radius: 999px;
    background: #f8d4da;
    border: 1px solid #e8a8b4;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0.45rem 0.55rem;
    font-size: 0.62rem;
    font-weight: 600;
    line-height: 1.3;
    color: #5c2030;
    box-shadow: 0 1px 4px rgba(113, 32, 56, 0.08);
  }

  .process-data-panel {
    display: flex;
    flex-direction: column;
    padding: 0.9rem;
    border: 2px solid #a8c894;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.75);
    box-shadow: inset 0 0 0 1px rgba(168, 200, 148, 0.35);
  }

  .process-data-title {
    display: block;
    font-family: var(--font-serif);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-maroon);
    margin-bottom: 0.65rem;
    text-align: center;
  }

  .process-data-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    flex: 1;
  }

  .process-data-item {
    padding: 0.55rem 0.65rem;
    border-radius: 6px;
    font-size: 0.72rem;
    line-height: 1.35;
    font-weight: 600;
    text-align: center;
    background: linear-gradient(180deg, #8a2844 0%, var(--color-maroon) 100%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #fff;
    box-shadow: 0 1px 4px rgba(113, 32, 56, 0.1);
  }

  .process-data-item--alt {
    background: linear-gradient(180deg, #f0e6d6 0%, #e4d6c0 100%);
    border-color: #d4c4a8;
    color: #4a3020;
    font-weight: 600;
  }

  .process-data-item--analysis {
    margin-top: auto;
    background: linear-gradient(180deg, #d4e8c4 0%, #b8d4a4 100%);
    border-color: #9ec088;
    border-radius: 999px;
    color: #2d4a22;
  }

  @media (max-width: 879px) {
    .process-flow-top,
    .process-flow-bottom {
      flex-wrap: wrap;
      justify-content: center;
    }

    .process-arrow {
      flex: 0 0 100%;
      width: 2px;
      height: 1.25rem;
      margin: 0 auto;
      background: linear-gradient(180deg, var(--color-maroon-muted), transparent);
      opacity: 0.4;
    }

    .process-arrow::after {
      right: auto;
      left: 50%;
      top: auto;
      bottom: -1px;
      transform: translateX(-50%);
      border-left: 5px solid transparent;
      border-right: 5px solid transparent;
      border-top: 7px solid var(--color-maroon-muted);
      border-bottom: none;
    }

    .process-box--main,
    .process-step-stack {
      flex: 1 1 8rem;
      max-width: 10rem;
    }

    .process-box--tall {
      min-height: 11rem;
    }

    .process-data-panel {
      max-width: 14rem;
      margin: 0 auto;
    }
  }

  .process-note {
    margin: 2.5rem 0 0 0;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    max-width: 42rem;
  }

  .process-note a {
    font-weight: 600;
  }
</style>
