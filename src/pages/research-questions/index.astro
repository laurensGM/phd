---
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Research questions"
  description="Track your RQ versions and guidance on conceptualising a strong research question."
>
  <h1>Research questions</h1>
  <p class="page-desc">
    Your question timeline, plus structured notes on how to sharpen and justify a research question.
  </p>

  <div class="rq-hub-grid">
    <a href={`${base}research-questions/questions/`} class="rq-hub-card">
      <span class="rq-hub-icon" aria-hidden="true">❓</span>
      <h2 class="rq-hub-title">Questions</h2>
      <p class="rq-hub-desc">Versions of your research question, status, comments, and supervisory feedback.</p>
      <span class="rq-hub-link">Open questions →</span>
    </a>
    <a href={`${base}research-questions/must-dos/`} class="rq-hub-card">
      <span class="rq-hub-icon" aria-hidden="true">✓</span>
      <h2 class="rq-hub-title">10 must do&rsquo;s</h2>
      <p class="rq-hub-desc">Must-do aspects for conceptualising a research question (building up over time).</p>
      <span class="rq-hub-link">Open 10 must do&rsquo;s →</span>
    </a>
  </div>
</BaseLayout>

<style>
  .page-desc {
    color: var(--color-ink-muted);
    margin-bottom: 2rem;
    line-height: 1.6;
    max-width: 40rem;
  }
  .rq-hub-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .rq-hub-card {
    display: flex;
    flex-direction: column;
    padding: 2rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    border-left: 4px solid var(--color-maroon);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .rq-hub-card:hover {
    border-color: var(--color-maroon-muted);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    text-decoration: none;
    color: inherit;
  }
  .rq-hub-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }
  .rq-hub-title {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    margin: 0 0 0.5rem 0;
    color: var(--color-maroon);
  }
  .rq-hub-desc {
    flex: 1;
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--color-ink);
  }
  .rq-hub-link {
    margin-top: 1rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-maroon);
  }
</style>
