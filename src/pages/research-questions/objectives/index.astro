---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ObjectiveCard, { type Objective } from '../../../components/ObjectiveCard.astro';
import researchObjectives from '../../../data/research-objectives.json';

const base = import.meta.env.BASE_URL;

const allObjectives = researchObjectives as Objective[];

const primaryObjectives = allObjectives
  .filter((o) => o.type === 'primary')
  .sort((a, b) => (b.date || '').localeCompare(a.date || ''));

const secondaryObjectives = allObjectives
  .filter((o) => o.type === 'secondary')
  .sort((a, b) => {
    const dateCmp = (b.date || '').localeCompare(a.date || '');
    if (dateCmp !== 0) return dateCmp;
    return (a.secondaryNumber ?? 0) - (b.secondaryNumber ?? 0);
  });

const primaryCurrent = primaryObjectives.filter((o) => o.status === 'current');
const primaryArchived = primaryObjectives.filter((o) => o.status !== 'current');

const secondaryCurrent = secondaryObjectives
  .filter((o) => o.status === 'current')
  .sort((a, b) => (a.secondaryNumber ?? 0) - (b.secondaryNumber ?? 0));

const secondaryArchived = secondaryObjectives
  .filter((o) => o.status !== 'current')
  .sort((a, b) => {
    const versionCmp = (b.version || '').localeCompare(a.version || '');
    if (versionCmp !== 0) return versionCmp;
    return (a.secondaryNumber ?? 0) - (b.secondaryNumber ?? 0);
  });

function primaryLabel(objective: Objective): string {
  return `Primary ${objective.version.toUpperCase()}`;
}

function secondaryLabel(objective: Objective): string {
  if (objective.secondaryNumber != null) {
    return `Secondary objective ${objective.secondaryNumber} (${objective.version.toUpperCase()})`;
  }
  return `Secondary ${objective.version.toUpperCase()}`;
}
---

<BaseLayout title="Objectives" description="Primary and secondary objective evolution - versions, changes, supervisory feedback">
  <p class="back-link"><a href={`${base}research-questions/`}>← Research</a></p>
  <h1>Objectives</h1>
  <p class="page-desc">
    Track the evolution of your primary and secondary research objectives, including status, rationale for changes, and supervisory feedback.
  </p>

  <aside class="objectives-guidance" aria-label="Guidance on research objectives">
    <h2 class="objectives-guidance-title">How to think about objectives</h2>
    <p>
      <strong>Research objective:</strong> one carefully crafted sentence — fairly high level and generic. You have one main
      objective, with secondary objectives beneath it.
    </p>
    <p>
      <strong>Secondary research objectives</strong> should link to the activities you will actually do. It helps to tie each
      secondary objective to clear data collection and analysis activities.
    </p>
  </aside>

  <section class="objectives-section">
    <h2>Primary research objective</h2>
    <div class="objectives-timeline">
      {primaryCurrent.map((objective) => (
        <ObjectiveCard objective={objective} versionLabel={primaryLabel(objective)} />
      ))}
    </div>
    {primaryArchived.length > 0 && (
      <details class="objectives-archive">
        <summary class="objectives-archive-summary">
          Previous primary versions ({primaryArchived.length})
        </summary>
        <div class="objectives-timeline objectives-timeline--nested">
          {primaryArchived.map((objective) => (
            <ObjectiveCard objective={objective} versionLabel={primaryLabel(objective)} />
          ))}
        </div>
      </details>
    )}
  </section>

  <section class="objectives-section">
    <h2>Secondary research objectives</h2>
    <div class="objectives-timeline">
      {secondaryCurrent.map((objective) => (
        <ObjectiveCard objective={objective} versionLabel={secondaryLabel(objective)} />
      ))}
    </div>
    {secondaryArchived.length > 0 && (
      <details class="objectives-archive">
        <summary class="objectives-archive-summary">
          Previous secondary versions ({secondaryArchived.length})
        </summary>
        <div class="objectives-timeline objectives-timeline--nested">
          {secondaryArchived.map((objective) => (
            <ObjectiveCard objective={objective} versionLabel={secondaryLabel(objective)} />
          ))}
        </div>
      </details>
    )}
  </section>
</BaseLayout>

<style>
  .back-link {
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }
  .back-link a {
    color: var(--color-maroon);
  }
  .page-desc {
    color: var(--color-ink-muted);
    margin-bottom: 1.5rem;
  }

  .objectives-guidance {
    max-width: 40rem;
    margin-bottom: 2.5rem;
    padding: 1.25rem 1.5rem;
    background: rgba(113, 32, 56, 0.06);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-maroon);
    border-radius: 8px;
  }

  .objectives-guidance-title {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--color-maroon);
    margin: 0 0 0.75rem 0;
  }

  .objectives-guidance p {
    margin: 0 0 0.75rem 0;
    line-height: 1.6;
    color: var(--color-ink);
    font-size: 0.95rem;
  }

  .objectives-guidance p:last-child {
    margin-bottom: 0;
  }

  .objectives-section + .objectives-section {
    margin-top: 2.5rem;
  }

  .objectives-timeline {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .objectives-timeline--nested {
    margin-top: 1rem;
  }

  .objectives-archive {
    margin-top: 1.5rem;
    padding: 0.75rem 1rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }

  .objectives-archive-summary {
    cursor: pointer;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-ink-muted);
    list-style: none;
    user-select: none;
  }

  .objectives-archive-summary::-webkit-details-marker {
    display: none;
  }

  .objectives-archive-summary::before {
    content: '▸ ';
    display: inline-block;
    transition: transform 0.15s ease;
  }

  .objectives-archive[open] .objectives-archive-summary::before {
    transform: rotate(90deg);
  }

  .objectives-archive-summary:hover {
    color: var(--color-maroon);
  }

  :global(.objective-card) {
    padding: 1.5rem;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    border-left: 4px solid var(--color-border);
  }

  :global(.objective-card.current) {
    border-left-color: var(--color-accent);
  }

  :global(.objective-header) {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  :global(.objective-version) {
    font-weight: 600;
    color: var(--color-accent);
  }
  :global(.objective-date) {
    font-size: 0.875rem;
    color: var(--color-ink-muted);
  }
  :global(.objective-status-badge) {
    padding: 0.2rem 0.5rem;
    font-size: 0.75rem;
    background: var(--color-bg-alt);
    border-radius: 4px;
    text-transform: capitalize;
  }

  :global(.objective-text) {
    margin: 0.5rem 0 0 0;
    font-size: 1.05rem;
    line-height: 1.6;
  }

  :global(.objective-card section) {
    margin-top: 1rem;
  }
  :global(.objective-card h3) {
    font-size: 0.95rem;
    margin-bottom: 0.25rem;
  }
  :global(.objective-card .feedback) {
    padding: 1rem;
    background: var(--color-bg-alt);
    border-radius: 6px;
  }
</style>
