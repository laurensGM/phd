---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

const proposalBlueprint = [
  'Describes the background of the problem',
  'Provides theoretical context',
  'Summarises the research problem',
  'Specifies the research objectives',
  'Explains the research method — research context, research design, data analysis',
  'Shows how ethical aspects of the research are mitigated while conducting the research',
];

const qualityCriteria = [
  {
    text: 'Does not read like a consulting pitch, but follows the logic (and rigour) of the research process.',
  },
  {
    text: 'Has scientific-based evidence (i.e. a detailed literature study) to support all claims, notions, and opinions.',
  },
  {
    text: 'Has a problem statement based on one knowledge-based research question that also serves as a conclusion for the literature study.',
    emphasis: 'one',
  },
  {
    text: 'Has a clear, unambiguous main research objective with (perhaps) some secondary research objectives.',
  },
  {
    text: 'Shows how the research will be conducted by stipulating the research design, as well as the probable data analyses.',
  },
  {
    text: 'Is written in an argumentative style, with no ambiguity or emotive-style writing.',
  },
  {
    text: 'Uses a scientific referencing style to support the nature of the document.',
  },
];

const dissertationChapters = [
  { label: 'Introduction', inProposal: true },
  { label: 'Literature study', inProposal: true },
  { label: 'Problem statement and research objectives', inProposal: true },
  { label: 'Research method', inProposal: true },
  { label: 'Results / findings', inProposal: false },
  { label: 'Discussion and managerial implications', inProposal: false },
];

const phdOutline = [
  {
    id: 'outline-overview',
    title: 'Overview',
    items: ['Set the scene from your abstract — what the study is about and why it matters.'],
  },
  {
    id: 'outline-literature',
    title: 'Literature',
    items: [
      'Key theoretical perspectives, conceptual frameworks and prior empirical findings — what is the question in the literature?',
      'Identify the scientific conversation — briefly position your proposed research in those frameworks.',
    ],
  },
  {
    id: 'outline-problem',
    title: 'Problem statement',
    items: ['State the problem your research will address.'],
  },
  {
    id: 'outline-objectives',
    title: 'Research objectives',
    items: ['Specify what the study aims to achieve.'],
  },
  {
    id: 'outline-questions',
    title: 'Your research questions',
    items: [
      'Based on the scientific background — what will be addressed?',
      'What are the aims that follow from the literature and problem?',
    ],
  },
  {
    id: 'outline-method',
    title: 'Research method',
    items: [
      'Design and implementation phases.',
      'Clear link between the objectives, methods and techniques in this section and the aims previously defined.',
      'Discuss study designs and research paradigms, where relevant.',
      'Data collection — primary vs secondary — clear indication.',
    ],
  },
  {
    id: 'outline-contribution',
    title: 'Contribution',
    items: [
      'Change, challenge, or advance scholars\u2019 understanding.',
      'What is new? A new theoretical perspective, a new approach or method, the construction of new data/method, or a new context.',
    ],
  },
  {
    id: 'outline-time-ethics',
    title: 'Time frame / ethical considerations',
    items: [
      'Indicate the time frame for the study.',
      'Address ethical aspects of conducting the research.',
    ],
  },
];
---

<BaseLayout title="Proposal" description="Research proposal — definition, components, quality criteria, and the 3 C's rule">
  <div class="prop-layout">
    <nav class="prop-toc" aria-label="On this page">
      <h2 class="prop-toc-title">On this page</h2>
      <ol class="prop-toc-list">
        <li><a href="#intro">Introduction</a></li>
        <li><a href="#what-is">What is a proposal?</a></li>
        <li><a href="#demonstrate">What it must demonstrate</a></li>
        <li><a href="#blueprint">Blueprint</a></li>
        <li>
          <a href="#outline">PhD proposal outline</a>
          <ol>
            {phdOutline.map((block) => (
              <li>
                <a href={`#${block.id}`}>{block.title}</a>
              </li>
            ))}
          </ol>
        </li>
        <li><a href="#quality">Quality criteria</a></li>
        <li><a href="#dissertation">Proposal vs dissertation</a></li>
        <li><a href="#three-cs">The 3 C&rsquo;s rule</a></li>
      </ol>
    </nav>

    <article class="prop-article">
      <p class="back-link"><a href={`${base}research-questions/`}>← Research</a></p>
      <h1 id="intro">Research proposal</h1>
      <p class="prop-lead">
        Notes on what a research proposal is, what it should contain, and how to judge whether yours is strong enough to
        submit.
      </p>

      <section id="what-is" class="prop-section">
        <h2>A research proposal</h2>
        <ul class="prop-list">
          <li>A <strong>written document</strong></li>
          <li>
            It specifies:
            <ul>
              <li><strong>What</strong> the proposed research is about</li>
              <li>
                <strong>Why</strong> one should use resources to do it — significance
              </li>
              <li><strong>How</strong> it will be done — roadmap, methods</li>
            </ul>
          </li>
          <li>Essentially it &ldquo;makes a case&rdquo; for the proposed research</li>
        </ul>
      </section>

      <section id="demonstrate" class="prop-section">
        <h2>A good research proposal</h2>
        <p>Your proposal needs to demonstrate:</p>
        <ul class="prop-list">
          <li>That you are capable of <strong>independent critical thinking and analysis</strong></li>
          <li>That you are capable of <strong>communicating your ideas clearly</strong></li>
        </ul>
      </section>

      <section id="blueprint" class="prop-section">
        <h2>The research proposal as blueprint</h2>
        <p>
          A research proposal is a <strong>blueprint of the planned research</strong>. It should cover:
        </p>
        <ul class="prop-list">
          {proposalBlueprint.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </section>

      <section id="outline" class="prop-section">
        <h2>PhD proposal outline</h2>
        <p>Section-by-section guide for structuring the proposal document.</p>
        <div class="prop-outline">
          {phdOutline.map((block) => (
            <section id={block.id} class="prop-outline-block">
              <h3 class="prop-outline-title">{block.title}</h3>
              <ul class="prop-list">
                {block.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </section>
          ))}
        </div>
        <p class="prop-note">
          See also <a href={`${base}research-questions/questions/`}>Research questions</a>,{' '}
          <a href={`${base}research-questions/objectives/`}>Objectives</a>,{' '}
          <a href={`${base}research-questions/contribution/`}>Contribution</a>,{' '}
          <a href={`${base}methods/`}>Methods</a>, and <a href={`${base}methods/ethics/`}>Ethics</a>.
        </p>
      </section>

      <section id="quality" class="prop-section">
        <h2>Quality criteria</h2>
        <p>A strong proposal typically meets all of the following:</p>
        <ul class="prop-checklist">
          {qualityCriteria.map((item) => (
            <li>
              {item.emphasis ? (
                <>
                  Has a problem statement based on <strong><em>one</em></strong> knowledge-based research question that
                  also serves as a conclusion for the literature study.
                </>
              ) : (
                item.text
              )}
            </li>
          ))}
        </ul>
      </section>

      <section id="dissertation" class="prop-section">
        <h2>Components of the PhD dissertation</h2>
        <p>
          The full dissertation has six main components. The first four together form the{' '}
          <strong>research proposal</strong>.
        </p>
        <div
          class="prop-dissertation"
          role="img"
          aria-label="Six dissertation chapters; the first four form the research proposal"
        >
          <div class="prop-proposal-wrap">
            <ol class="prop-chapter-list">
              {dissertationChapters
                .filter((chapter) => chapter.inProposal)
                .map((chapter, index) => (
                  <li class="prop-chapter--proposal">
                    <span class="prop-chapter-num">{index + 1}</span>
                    <span class="prop-chapter-label">{chapter.label}</span>
                  </li>
                ))}
            </ol>
            <div class="prop-proposal-bracket" aria-hidden="true">
              <span class="prop-bracket-line"></span>
              <span class="prop-bracket-label">= Research proposal</span>
            </div>
          </div>
          <ol class="prop-chapter-list prop-chapter-list--rest">
            {dissertationChapters
              .filter((chapter) => !chapter.inProposal)
              .map((chapter, index) => (
                <li>
                  <span class="prop-chapter-num">{index + 5}</span>
                  <span class="prop-chapter-label">{chapter.label}</span>
                </li>
              ))}
          </ol>
        </div>
        <p class="prop-note">
          Results and discussion come after the proposal stage — but your proposal should already signal how findings
          will be analysed and reported.
        </p>
      </section>

      <section id="three-cs" class="prop-section">
        <h2>Align with the 3 C&rsquo;s rule</h2>
        <p>Every proposal should be clear, concise, and coherent.</p>
        <div class="prop-three-cs" role="img" aria-label="Proposal connected to clear, concise, and coherent">
          <div class="prop-cs-node prop-cs-node--top">Clear</div>
          <div class="prop-cs-hub">Proposal</div>
          <div class="prop-cs-row">
            <div class="prop-cs-node prop-cs-node--left">Concise</div>
            <div class="prop-cs-node prop-cs-node--right">Coherent</div>
          </div>
        </div>
        <ul class="prop-list">
          <li><strong>Clear</strong> — the reader understands what you will study, why, and how</li>
          <li><strong>Concise</strong> — no padding; every section earns its place</li>
          <li><strong>Coherent</strong> — problem, objectives, literature, and method align logically</li>
        </ul>
        <p class="prop-note">
          See also <a href={`${base}research-questions/process/`}>Research → Process</a> for the workflow your proposal
          should follow.
        </p>
      </section>
    </article>
  </div>
</BaseLayout>

<style is:global>
  html {
    scroll-behavior: smooth;
    scroll-padding-top: 6rem;
  }
</style>

<style>
  .back-link {
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }
  .back-link a {
    color: var(--color-maroon);
  }

  .prop-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
    max-width: 1100px;
  }

  @media (min-width: 900px) {
    .prop-layout {
      grid-template-columns: min(240px, 26%) 1fr;
    }
  }

  .prop-toc {
    position: sticky;
    top: 5.5rem;
    z-index: 1;
    padding: 1rem 1.1rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    border-left: 4px solid var(--color-maroon);
    font-size: 0.88rem;
    line-height: 1.45;
    max-height: calc(100vh - 6rem);
    overflow-y: auto;
  }

  .prop-toc-title {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-ink-muted);
    margin: 0 0 0.65rem 0;
  }

  .prop-toc-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .prop-toc-list li {
    margin-bottom: 0.4rem;
  }

  .prop-toc-list ol {
    margin: 0.35rem 0 0.5rem 0;
    padding-left: 1rem;
    list-style: none;
    border-left: 2px solid var(--color-border);
  }

  .prop-toc-list ol li {
    margin-bottom: 0.3rem;
    font-size: 0.84rem;
  }

  .prop-toc a {
    color: var(--color-maroon);
    text-decoration: none;
  }

  .prop-toc a:hover {
    text-decoration: underline;
  }

  .prop-article {
    min-width: 0;
  }

  .prop-article h1 {
    font-family: var(--font-serif);
    font-size: clamp(1.45rem, 3vw, 1.85rem);
    color: var(--color-maroon);
    margin: 0 0 1rem 0;
    scroll-margin-top: 5.5rem;
  }

  .prop-lead {
    margin: 0 0 1.5rem 0;
    line-height: 1.7;
    color: var(--color-ink-muted);
    max-width: 44rem;
  }

  .prop-section {
    margin-top: 2.25rem;
    scroll-margin-top: 5.5rem;
  }

  .prop-section > h2 {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--color-maroon);
    margin: 0 0 0.85rem 0;
  }

  .prop-section p {
    margin: 0 0 1rem 0;
    line-height: 1.7;
    color: var(--color-ink);
    max-width: 44rem;
  }

  .prop-list {
    margin: 0 0 1rem 0;
    padding-left: 1.35rem;
    line-height: 1.7;
    max-width: 44rem;
  }

  .prop-list li {
    margin-bottom: 0.5rem;
  }

  .prop-list ul {
    margin-top: 0.35rem;
  }

  .prop-checklist {
    margin: 0;
    padding: 0;
    list-style: none;
    max-width: 44rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .prop-checklist li {
    padding: 0.75rem 1rem 0.75rem 2.25rem;
    background: rgba(113, 32, 56, 0.06);
    border: 1px solid rgba(113, 32, 56, 0.15);
    border-left: 4px solid var(--color-maroon);
    border-radius: 0 8px 8px 0;
    line-height: 1.55;
    font-size: 0.95rem;
    position: relative;
  }

  .prop-checklist li::before {
    content: '✓';
    position: absolute;
    left: 0.75rem;
    top: 0.75rem;
    font-weight: 700;
    color: var(--color-gold);
    font-size: 0.9rem;
  }

  .prop-outline {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    max-width: 44rem;
    margin: 1rem 0;
  }

  .prop-outline-block {
    padding: 0.85rem 1rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-maroon);
    border-radius: 0 8px 8px 0;
    scroll-margin-top: 5.5rem;
  }

  .prop-outline-title {
    margin: 0 0 0.5rem 0;
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-maroon);
  }

  .prop-outline-block .prop-list {
    margin-bottom: 0;
  }

  .prop-dissertation {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    max-width: 28rem;
    margin: 1rem 0;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: #fafafa;
  }

  .prop-proposal-wrap {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.75rem;
    align-items: stretch;
  }

  .prop-chapter-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .prop-chapter-list li {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.55rem 0.75rem;
    border-radius: 999px;
    background: #f4e8ea;
    border: 1px solid #e8d0d4;
    font-size: 0.88rem;
    line-height: 1.35;
    transform: translateX(calc(var(--i, 0) * 0.5rem));
  }

  .prop-proposal-wrap .prop-chapter-list li:nth-child(1) { --i: 0; }
  .prop-proposal-wrap .prop-chapter-list li:nth-child(2) { --i: 1; }
  .prop-proposal-wrap .prop-chapter-list li:nth-child(3) { --i: 2; }
  .prop-proposal-wrap .prop-chapter-list li:nth-child(4) { --i: 3; }

  .prop-chapter-list--rest li:nth-child(1) { --i: 4; }
  .prop-chapter-list--rest li:nth-child(2) { --i: 5; }

  .prop-chapter--proposal {
    background: #f4e0e4;
    border-color: rgba(113, 32, 56, 0.25);
  }

  .prop-chapter-num {
    flex-shrink: 0;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    background: var(--color-maroon);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .prop-proposal-bracket {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.15rem 0;
    min-width: 2.75rem;
  }

  .prop-bracket-line {
    display: block;
    flex: 1;
    width: 2.5rem;
    min-height: 10.5rem;
    border: 2px dashed #c9a227;
    border-left: none;
    border-radius: 0 14px 14px 0;
  }

  .prop-bracket-label {
    font-size: 0.78rem;
    font-weight: 700;
    color: #a88410;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    transform: rotate(180deg);
  }

  .prop-three-cs {
    display: grid;
    grid-template-rows: auto auto auto;
    justify-items: center;
    gap: 0.65rem;
    max-width: 16rem;
    margin: 1.25rem 0;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: #fff;
  }

  .prop-cs-node,
  .prop-cs-hub {
    padding: 0.55rem 1.1rem;
    border: 2px solid var(--color-maroon-muted);
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    text-align: center;
    min-width: 6rem;
  }

  .prop-cs-hub {
    background: rgba(113, 32, 56, 0.08);
    color: var(--color-maroon);
    border-color: var(--color-maroon);
  }

  .prop-cs-row {
    display: flex;
    gap: 2.5rem;
    justify-content: center;
    width: 100%;
  }

  .prop-note {
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    max-width: 44rem;
  }

  .prop-note a {
    font-weight: 600;
  }

  @media (max-width: 520px) {
    .prop-proposal-wrap {
      grid-template-columns: 1fr;
    }

    .prop-proposal-bracket {
      flex-direction: row;
      width: 100%;
      justify-content: center;
      order: 2;
      padding-top: 0.35rem;
    }

    .prop-bracket-line {
      flex: 1;
      width: auto;
      min-height: 0;
      height: 2px;
      min-width: 4rem;
      border: 2px dashed #c9a227;
      border-top: none;
      border-left: none;
      border-right: none;
      border-radius: 0;
    }

    .prop-bracket-label {
      writing-mode: horizontal-tb;
      transform: none;
      flex-shrink: 0;
    }

    .prop-cs-row {
      gap: 0.75rem;
    }
  }
</style>
