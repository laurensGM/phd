---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import nuggets from '../../../data/golden-nuggets.json';

const base = import.meta.env.BASE_URL;
const faq = nuggets.faq as { question: string; author: string | null }[];
const quotes = nuggets.quotes as { text: string; author: string | null }[];
---

<BaseLayout title="Golden nuggets" description="Key insights, quotes, and FAQs from your PhD journey">
  <p class="back-link"><a href={`${base}tools/`}>← Tools</a></p>
  <h1>Golden nuggets</h1>
  <p class="page-desc">Key insights, words of wisdom, and frequently asked questions — usually a quote or a question worth remembering.</p>

  <section class="nuggets-section">
    <h2 class="section-title">FAQ</h2>
    <ul class="nuggets-list faq-list">
      {faq.map((item) => (
        <li class="nugget-item faq-item">
          <span class="nugget-text">"{item.question}"</span>
          {item.author && <cite class="nugget-author">— {item.author}</cite>}
        </li>
      ))}
    </ul>
  </section>

  <section class="nuggets-section">
    <h2 class="section-title">Quotes &amp; insights</h2>
    <ul class="nuggets-list quotes-list">
      {quotes.map((item) => (
        <li class="nugget-item quote-item">
          <blockquote class="nugget-quote">
            <p class="nugget-text">{item.text}</p>
            {item.author && <footer><cite class="nugget-author">— {item.author}</cite></footer>}
          </blockquote>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .back-link {
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }
  .back-link a {
    color: var(--color-maroon);
  }
  .page-desc {
    color: var(--color-ink-muted);
    margin-bottom: 2.5rem;
    line-height: 1.6;
  }
  .nuggets-section {
    margin-bottom: 3rem;
  }
  .section-title {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    color: var(--color-maroon);
    margin: 0 0 1.25rem 0;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-border);
  }
  .nuggets-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nugget-item {
    margin-bottom: 1.25rem;
  }
  .faq-item {
    padding: 1rem 1.25rem;
    background: var(--color-bg-alt, #f8f6f4);
    border-left: 4px solid var(--color-maroon);
    border-radius: 0 8px 8px 0;
  }
  .faq-item .nugget-text {
    font-style: normal;
    font-weight: 500;
  }
  .quote-item {
    padding: 0;
  }
  .nugget-quote {
    margin: 0;
    padding: 1.25rem 1.5rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    position: relative;
  }
  .nugget-quote::before {
    content: '"';
    position: absolute;
    top: 0.5rem;
    left: 1rem;
    font-size: 2.5rem;
    font-family: var(--font-serif);
    color: var(--color-maroon-muted, rgba(92, 29, 42, 0.25));
    line-height: 1;
  }
  .nugget-quote .nugget-text {
    margin: 0 0 0.75rem 0;
    padding-left: 1.5rem;
    font-style: italic;
    line-height: 1.6;
    color: var(--color-ink);
  }
  .nugget-quote footer {
    padding-left: 1.5rem;
  }
  .nugget-author {
    font-style: normal;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-maroon);
  }
</style>
