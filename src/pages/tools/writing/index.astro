---

<BaseLayout
  title="Words"
  description="Adverbs, phrases, and reporting verbs for academic drafting and revision."
>
  <p class="back-link"><a href={`${base}writing/`}>← Writing</a></p>
  <h1>Words</h1>
  <p class="page-desc">
    Adverbial connectors, reusable sentence openers, and reporting verbs for drafts. Use the legend below to show only
    one type at a time.
  </p>

  <div class="writing-legend" role="group" aria-label="Filter by word type">
    <span class="writing-legend-label">Show:</span>
    <button type="button" class="writing-legend-btn is-active" data-writing-filter="all">
      <span class="writing-legend-swatch writing-legend-swatch--all" aria-hidden="true"></span>
      All
    </button>
    <button type="button" class="writing-legend-btn" data-writing-filter="adverbs">
      <span class="writing-legend-swatch writing-legend-swatch--adverb" aria-hidden="true"></span>
      Adverbs &amp; connectors
    </button>
    <button type="button" class="writing-legend-btn" data-writing-filter="phrases">
      <span class="writing-legend-swatch writing-legend-swatch--phrase" aria-hidden="true"></span>
      Phrases
    </button>
    <button type="button" class="writing-legend-btn" data-writing-filter="verbs">
      <span class="writing-legend-swatch writing-legend-swatch--verb" aria-hidden="true"></span>
      Verbs
    </button>
  </div>

  <div id="writing-tools-root" class="writing-page" data-filter="all">
    <div class="writing-groups">
      {
        groups.map((group) => (
          <section
            class:list={[
              'writing-group',
              group.kind === 'verb'
                ? 'writing-group--verb'
                : group.kind === 'phrase'
                  ? 'writing-group--phrase'
                  : 'writing-group--adverb',
            ]}
            data-kind={group.kind}
          >
            <h2 class="writing-group-title">
              <span class="writing-kind-badge">
                {group.kind === 'verb' ? 'Verb' : group.kind === 'phrase' ? 'Phrase' : 'Adverb'}
              </span>
              {group.title}
            </h2>
            <ul class="writing-list">
              {group.items.map((phrase) => (
                <li>{phrase}</li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </div>
</BaseLayout>

<script>
  const root = document.getElementById('writing-tools-root');
  const buttons = document.querySelectorAll('[data-writing-filter]');

  function setFilter(value: string) {
    if (!root) return;
    root.dataset.filter = value;
    buttons.forEach((btn) => {
      btn.classList.toggle('is-active', btn.dataset.writingFilter === value);
    });
  }

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const v = btn.dataset.writingFilter;
      if (v) setFilter(v);
    });
  });
</script>

<style>
  .back-link {
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }
  .back-link a {
    color: var(--color-maroon);
  }
  .page-desc {
    color: var(--color-ink-muted);
    margin-bottom: 1.25rem;
    line-height: 1.6;
    max-width: 42rem;
  }

  .writing-legend {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.75rem;
    margin-bottom: 1.75rem;
    padding: 0.85rem 1rem;
    background: #f7f4ef;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    max-width: 52rem;
  }
  .writing-legend-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-ink-muted);
    margin-right: 0.25rem;
  }
  .writing-legend-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.4rem 0.75rem;
    font-size: 0.9rem;
    font-family: inherit;
    cursor: pointer;
    border-radius: 999px;
    border: 1px solid #d1c9b8;
    background: #fff;
    color: var(--color-ink);
    transition:
      background 0.15s ease,
      border-color 0.15s ease,
      color 0.15s ease;
  }
  .writing-legend-btn:hover {
    border-color: var(--color-maroon);
    color: var(--color-maroon);
  }
  .writing-legend-btn.is-active {
    background: var(--color-maroon);
    border-color: var(--color-maroon);
    color: #fdf8f3;
  }
  .writing-legend-swatch {
    width: 0.65rem;
    height: 0.65rem;
    border-radius: 2px;
    flex-shrink: 0;
  }
  .writing-legend-swatch--all {
    background: linear-gradient(90deg, #1e5a7a 0 33%, #4a6b4e 33% 66%, #8b4d6b 66% 100%);
  }
  .writing-legend-swatch--adverb {
    background: #1e5a7a;
  }
  .writing-legend-swatch--phrase {
    background: #4a6b4e;
  }
  .writing-legend-swatch--verb {
    background: #8b4d6b;
  }

  .writing-groups {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
    gap: 1.25rem 1.5rem;
    align-items: start;
  }
  .writing-group {
    margin: 0;
    padding: 1.25rem 1.35rem;
    border-radius: 10px;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--color-border);
  }
  .writing-group--adverb {
    background: linear-gradient(to right, #e8f2f7 0%, #fff 12%);
    border-left: 4px solid #1e5a7a;
  }
  .writing-group--verb {
    background: linear-gradient(to right, #f5eaef 0%, #fff 12%);
    border-left: 4px solid #8b4d6b;
  }
  .writing-group--phrase {
    background: linear-gradient(to right, #eef4ee 0%, #fff 12%);
    border-left: 4px solid #4a6b4e;
  }
  .writing-group-title {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 600;
    margin: 0 0 0.75rem 0;
    letter-spacing: 0.02em;
    text-transform: capitalize;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem 0.5rem;
    line-height: 1.35;
  }
  .writing-group--adverb .writing-group-title {
    color: #143d52;
  }
  .writing-group--verb .writing-group-title {
    color: #5c2840;
  }
  .writing-group--phrase .writing-group-title {
    color: #2d4a32;
    text-transform: none;
  }
  .writing-kind-badge {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    font-family: var(--font-sans, system-ui, sans-serif);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    padding: 0.2rem 0.45rem;
    border-radius: 4px;
    flex-shrink: 0;
  }
  .writing-group--adverb .writing-kind-badge {
    background: #c5dde8;
    color: #143d52;
  }
  .writing-group--verb .writing-kind-badge {
    background: #e8d0da;
    color: #5c2840;
  }
  .writing-group--phrase .writing-kind-badge {
    background: #d4e5d6;
    color: #2d4a32;
  }
  .writing-list {
    margin: 0;
    padding-left: 1.15rem;
    line-height: 1.65;
    color: var(--color-ink);
    font-size: 0.95rem;
  }
  .writing-list li {
    margin-bottom: 0.35rem;
  }
  .writing-list li:last-child {
    margin-bottom: 0;
  }

  .writing-page[data-filter='verbs'] .writing-group--adverb,
  .writing-page[data-filter='verbs'] .writing-group--phrase {
    display: none;
  }
  .writing-page[data-filter='adverbs'] .writing-group--verb,
  .writing-page[data-filter='adverbs'] .writing-group--phrase {
    display: none;
  }
  .writing-page[data-filter='phrases'] .writing-group--adverb,
  .writing-page[data-filter='phrases'] .writing-group--verb {
    display: none;
  }
</style>
