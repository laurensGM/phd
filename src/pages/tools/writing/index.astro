      'question',
      'refute',
      'reject',
      'renounce',
      'repudiate',
      'dispute',
      'doubt',
      'challenge',
      'contest',
      'disprove',
    ],
  },
  {
    kind: 'verb',
    title: 'Making recommendations',
    items: [
      'advocate',
      'encourage',
      'plead',
      'warn',
      'call for',
      'exhort',
      'recommend',
      'suggest',
      'demand',
      'implore',
      'urge',
      'propose',
      'advise',
      'put forward',
