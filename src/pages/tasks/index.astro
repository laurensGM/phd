---
import BaseLayout from '../../layouts/BaseLayout.astro';
import KanbanBoard from '../../components/KanbanBoard';
---

<BaseLayout title="Tasks" description="Kanban board for PhD tasks - backlog, to do, in progress, done, archived" deferLoader>
  <h1>Tasks</h1>
  <p class="page-desc">Change a card’s status with the dropdown to move it between columns. Archive hides cards from the board — use Show archived to find them again. Add, edit, or delete tasks below (saved in Supabase).</p>

  <KanbanBoard client:load />
</BaseLayout>

<style>
  .page-desc {
    color: var(--color-ink-muted);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  /* Kanban board (React) */
  :global(.kanban-setup),
  :global(.kanban-loading) {
    color: var(--color-ink-muted);
    padding: 2rem;
  }
  :global(.kanban-error) {
    color: var(--color-maroon);
    font-size: 0.9rem;
    margin-bottom: 1rem;
    padding: 0.75rem;
    background: rgba(113, 32, 56, 0.08);
    border-radius: 6px;
  }
  :global(.kanban-board) {
    margin-bottom: 3rem;
  }
  :global(.kanban-actions) {
    margin-bottom: 1.5rem;
  }
  :global(.kanban-actions-row) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }
  :global(.kanban-add-btn) {
    padding: 0.5rem 1rem;
    background: var(--color-maroon);
    color: #fff;
    border: 2px solid var(--color-gold);
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
  }
  :global(.kanban-add-btn:hover) {
    background: var(--color-maroon-dark);
  }
  :global(.kanban-archived-toggle) {
    padding: 0.5rem 1rem;
    background: #fff;
    color: var(--color-ink);
    border: 2px solid var(--color-border);
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
  }
  :global(.kanban-archived-toggle:hover),
  :global(.kanban-archived-toggle.is-active) {
    border-color: var(--color-maroon-muted);
    background: rgba(92, 29, 42, 0.06);
    color: var(--color-maroon);
  }
  :global(.kanban-add-form) {
    margin-top: 1rem;
    padding: 1.25rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    max-width: 480px;
  }
  :global(.kanban-form-row) {
    margin-bottom: 0.75rem;
  }
  :global(.kanban-form-row label) {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
    color: var(--color-ink);
  }
  :global(.kanban-input),
  :global(.kanban-textarea),
  :global(.kanban-select) {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: 2px solid var(--color-border);
    border-radius: 6px;
    font-size: 1rem;
    font-family: var(--font-sans);
    color: var(--color-ink);
    background: #fff;
    box-sizing: border-box;
  }
  :global(.kanban-textarea) {
    resize: vertical;
    min-height: 60px;
  }
  :global(.kanban-select) {
    cursor: pointer;
    max-width: 200px;
  }
  :global(.kanban-submit) {
    margin-top: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--color-maroon);
    color: #fff;
    border: 2px solid var(--color-gold);
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
  }
  :global(.kanban-submit:hover:not(:disabled)) {
    background: var(--color-maroon-dark);
  }
  :global(.kanban-submit:disabled) {
    opacity: 0.7;
    cursor: not-allowed;
  }

  :global(.kanban-columns) {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.25rem;
    align-items: start;
  }
  @media (max-width: 1100px) {
    :global(.kanban-columns) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 600px) {
    :global(.kanban-columns) {
      grid-template-columns: minmax(0, 1fr);
    }
  }
  :global(.kanban-column) {
    background: var(--color-bg-alt);
    border: 2px solid var(--color-border);
    border-radius: 10px;
    padding: 1rem;
    min-height: 200px;
    min-width: 0;
  }
  :global(.kanban-column-backlog) {
    background: rgba(124, 58, 237, 0.08);
    border-color: rgba(124, 58, 237, 0.35);
  }
  :global(.kanban-column-backlog .kanban-column-title) {
    color: #6d28d9;
    border-bottom-color: rgba(124, 58, 237, 0.3);
  }
  :global(.kanban-column-todo) {
    background: rgba(202, 138, 4, 0.1);
    border-color: rgba(202, 138, 4, 0.4);
  }
  :global(.kanban-column-todo .kanban-column-title) {
    color: #a16207;
    border-bottom-color: rgba(202, 138, 4, 0.35);
  }
  :global(.kanban-column-in_progress) {
    background: rgba(37, 99, 235, 0.08);
    border-color: rgba(37, 99, 235, 0.35);
  }
  :global(.kanban-column-in_progress .kanban-column-title) {
    color: #1d4ed8;
    border-bottom-color: rgba(37, 99, 235, 0.3);
  }
  :global(.kanban-column-done) {
    background: rgba(22, 163, 74, 0.1);
    border-color: rgba(22, 163, 74, 0.4);
  }
  :global(.kanban-column-done .kanban-column-title) {
    color: #15803d;
    border-bottom-color: rgba(22, 163, 74, 0.35);
  }
  :global(.kanban-column-title) {
    font-size: 1.1rem;
    color: var(--color-maroon);
    margin: 0 0 0.75rem 0;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  :global(.kanban-column-count) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.5rem;
    height: 1.5rem;
    padding: 0 0.4rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 700;
    line-height: 1;
    background: rgba(0, 0, 0, 0.08);
    color: inherit;
  }
  :global(.kanban-cards) {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-width: 0;
  }
  :global(.kanban-card) {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    min-height: 140px;
    min-width: 0;
    overflow: hidden;
  }
  :global(.kanban-card-status) {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin: 0.35rem 0 0.15rem;
  }
  :global(.kanban-card-status-label),
  :global(.kanban-detail-status-label) {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }
  :global(.kanban-card-status-select) {
    width: 100%;
    max-width: 100%;
    padding: 0.35rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-size: 0.85rem;
    font-family: var(--font-sans);
    color: var(--color-ink);
    background: #fff;
    cursor: pointer;
  }
  :global(.kanban-card-status-select:hover:not(:disabled)),
  :global(.kanban-card-status-select:focus-visible) {
    border-color: var(--color-maroon-muted);
    outline: none;
  }
  :global(.kanban-card-status-select:disabled) {
    opacity: 0.7;
    cursor: wait;
  }
  :global(.kanban-card-top) {
    display: flex;
    align-items: flex-start;
    gap: 0.35rem;
    min-width: 0;
  }
  :global(.kanban-card-top .kanban-card-content) {
    flex: 1;
    min-width: 0;
  }
  :global(.kanban-card-reorder) {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    flex-shrink: 0;
  }
  :global(.kanban-reorder-btn) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.6rem;
    height: 1.35rem;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: #fff;
    color: var(--color-ink);
    font-size: 0.85rem;
    line-height: 1;
    cursor: pointer;
  }
  :global(.kanban-reorder-btn:hover:not(:disabled)) {
    border-color: var(--color-maroon-muted);
    background: rgba(92, 29, 42, 0.06);
    color: var(--color-maroon);
  }
  :global(.kanban-reorder-btn:disabled) {
    opacity: 0.35;
    cursor: not-allowed;
  }
  :global(.kanban-card-content) {
    flex: 1;
    min-height: 0;
    cursor: pointer;
    padding: 2px 0;
  }
  :global(.kanban-card-content:hover) {
    outline: none;
  }
  :global(.kanban-card-content:focus-visible) {
    outline: 2px solid var(--color-maroon);
    outline-offset: 2px;
    border-radius: 4px;
  }
  :global(.kanban-card-title) {
    font-size: 1rem;
    margin: 0 0 0.35rem 0;
    color: var(--color-ink);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.3;
    overflow-wrap: anywhere;
  }
  :global(.kanban-card-desc) {
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    margin: 0 0 0.5rem 0;
    line-height: 1.4;
    white-space: pre-wrap;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    overflow-wrap: anywhere;
  }
  :global(.kanban-card-desc-empty) {
    font-style: italic;
    color: var(--color-ink-muted);
    opacity: 0.8;
  }
  :global(.kanban-card-actions) {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
  }
  :global(.kanban-card-action) {
    padding: 0.2rem 0.5rem;
    font-size: 0.8rem;
    font-weight: 600;
    border: 1px solid var(--color-border);
    background: #fff;
    border-radius: 4px;
    cursor: pointer;
    color: var(--color-ink);
  }
  :global(.kanban-card-action:hover) {
    border-color: var(--color-maroon-muted);
    background: rgba(92, 29, 42, 0.06);
  }
  :global(.kanban-card-delete:hover) {
    border-color: var(--color-maroon);
    color: var(--color-maroon);
  }
  :global(.kanban-card-edit) {
    cursor: default;
  }
  :global(.kanban-card-edit .kanban-input),
  :global(.kanban-card-edit .kanban-textarea) {
    margin-bottom: 0.5rem;
  }
  :global(.kanban-btn) {
    padding: 0.35rem 0.75rem;
    font-size: 0.85rem;
    font-weight: 600;
    border-radius: 6px;
    cursor: pointer;
    border: 1px solid var(--color-border);
    background: #fff;
  }
  :global(.kanban-btn-primary) {
    background: var(--color-maroon);
    color: #fff;
    border-color: var(--color-maroon);
  }
  :global(.kanban-btn-primary:hover:not(:disabled)) {
    background: var(--color-maroon-dark);
  }
  :global(.kanban-btn-secondary:hover) {
    border-color: var(--color-ink-muted);
  }

  /* Detail modal */
  :global(.kanban-detail-overlay) {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    padding: 1.5rem;
  }
  :global(.kanban-detail-modal) {
    background: #fff;
    border-radius: 10px;
    box-shadow: var(--shadow-md);
    max-width: 520px;
    width: 100%;
    max-height: 85vh;
    overflow: auto;
    padding: 1.5rem;
  }
  :global(.kanban-detail-title) {
    font-size: 1.25rem;
    margin: 0 0 0.75rem 0;
    color: var(--color-ink);
    line-height: 1.35;
  }
  :global(.kanban-detail-meta) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    margin-bottom: 1rem;
  }
  :global(.kanban-detail-meta .kanban-card-status-select) {
    max-width: 11rem;
  }
  :global(.kanban-detail-description) {
    margin-bottom: 1.25rem;
    padding: 0.75rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  :global(.kanban-detail-description-text) {
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--color-ink);
    margin: 0;
    white-space: pre-wrap;
  }
  :global(.kanban-detail-description-empty) {
    margin: 0;
    font-style: italic;
    color: var(--color-ink-muted);
  }
  :global(.kanban-detail-actions) {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  :global(.kanban-detail-actions .kanban-btn) {
    margin: 0;
  }

  :global(.kanban-archived-section) {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 2px solid var(--color-border);
  }
  :global(.kanban-archived-heading) {
    font-size: 1.15rem;
    color: var(--color-maroon);
    margin: 0 0 1rem 0;
  }
  :global(.kanban-archived-empty) {
    color: var(--color-ink-muted);
    font-style: italic;
    margin: 0;
  }
  :global(.kanban-archived-grid) {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.25rem;
  }
  @media (max-width: 1100px) {
    :global(.kanban-archived-grid) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 600px) {
    :global(.kanban-archived-grid) {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>
