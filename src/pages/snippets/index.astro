---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SnippetsPage from '../../components/SnippetsPage';
---

<BaseLayout title="Snippets" description="Browse and manage conceptual snippets from your literature">
  <SnippetsPage client:visible />
</BaseLayout>

<style>
  :global(.snippets-page) {
    margin-top: 1rem;
  }
  :global(.snippets-page h1) {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    margin-bottom: 0.25rem;
  }
  :global(.snippets-intro) {
    color: var(--color-ink-muted);
    margin: 0 0 1rem 0;
  }
  :global(.snippets-header-actions) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
    align-items: center;
    margin-bottom: 1.25rem;
  }
  :global(.snippets-open-add-btn),
  :global(.snippets-backfill-btn),
  :global(.snippets-prompt-mode-btn),
  :global(.snippets-generate-prompt-btn) {
    padding: 0.55rem 1.2rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    border: 1px solid var(--color-border);
    background: #fff;
    color: var(--color-ink);
  }
  :global(.snippets-open-add-btn) {
    background: var(--color-maroon);
    color: #fff;
    border: none;
  }
  :global(.snippets-backfill-btn) {
    background: #fff7ed;
    border-color: #fdba74;
    color: #9a3412;
  }
  :global(.snippets-backfill-btn:disabled) {
    opacity: 0.65;
    cursor: not-allowed;
  }
  :global(.snippets-backfill-status) {
    margin: 0.35rem 0 0 0;
    font-size: 0.82rem;
    color: var(--color-ink-muted);
  }
  :global(.snippets-top-tabs) {
    display: inline-flex;
    gap: 0.45rem;
    margin-top: 0.8rem;
  }
  :global(.snippets-top-tab) {
    padding: 0.4rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: #fff;
    color: var(--color-ink);
    font-size: 0.84rem;
    font-weight: 600;
    cursor: pointer;
  }
  :global(.snippets-top-tab-active) {
    background: var(--color-maroon);
    color: #fff;
    border-color: var(--color-maroon);
  }
  :global(.snippets-prompt-mode-btn-active) {
    background: rgba(113, 32, 56, 0.12);
    border-color: var(--color-maroon);
    color: var(--color-maroon);
    font-weight: 600;
  }
  :global(.snippets-generate-prompt-btn:disabled) {
    opacity: 0.5;
    cursor: not-allowed;
  }

  :global(.snippets-layout) {
    display: grid;
    grid-template-columns: minmax(220px, 260px) minmax(0, 1fr);
    gap: 1.5rem;
    align-items: flex-start;
  }
  :global(.snippets-prompt-toolbar) {
    grid-column: 1 / -1;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1rem;
    padding: 0.65rem 1rem;
    background: rgba(113, 32, 56, 0.06);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    font-size: 0.88rem;
  }
  :global(.snippets-prompt-count) {
    font-weight: 600;
    color: var(--color-maroon);
    margin-right: 0.25rem;
  }
  :global(.snippets-prompt-toolbar-btn) {
    padding: 0.35rem 0.75rem;
    font-size: 0.82rem;
    border-radius: 6px;
    border: 1px solid var(--color-border);
    background: #fff;
    cursor: pointer;
  }
  :global(.snippets-filters) {
    padding: 1rem 1.25rem;
    background: var(--color-bg-alt);
    border-radius: 10px;
    border: 1px solid var(--color-border);
    position: sticky;
    top: 1rem;
    max-height: calc(100vh - 2rem);
    overflow-y: auto;
    overscroll-behavior: contain;
  }
  :global(.snippets-filter-row) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
    margin-bottom: 0.75rem;
  }
  :global(.snippets-filter-row:last-of-type) {
    margin-bottom: 0;
  }
  :global(.snippets-filter-row label) {
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  :global(.snippets-input) {
    width: 100%;
    max-width: 100%;
    padding: 0.45rem 0.6rem;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    background: #fff;
    font-size: 0.9rem;
  }
  :global(.snippets-search-label .snippets-input) {
    width: 100%;
  }
  :global(.snippets-search-mode) {
    display: inline-flex;
    align-items: flex-end;
    gap: 0.35rem;
  }
  :global(.snippets-search-mode-btn) {
    padding: 0.35rem 0.7rem;
    border: 1px solid var(--color-border);
    border-radius: 7px;
    background: #fff;
    color: var(--color-ink);
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
  }
  :global(.snippets-search-mode-btn-active) {
    background: var(--color-maroon);
    color: #fff;
    border-color: var(--color-maroon);
  }
  :global(.snippets-semantic-note) {
    margin: 0.1rem 0 0.75rem 0;
    font-size: 0.8rem;
    color: var(--color-ink-muted);
    line-height: 1.35;
  }
  :global(.snippets-semantic-controls) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 0.9rem;
    margin: 0.1rem 0 0.35rem 0;
  }
  :global(.snippets-semantic-control) {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    color: var(--color-ink-muted);
  }
  :global(.snippets-semantic-input) {
    width: 84px;
    padding: 0.3rem 0.45rem;
    font-size: 0.8rem;
  }
  :global(.snippets-help-tip) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    color: var(--color-maroon);
    font-size: 0.7rem;
    font-weight: 700;
    background: #fff;
    cursor: help;
  }
  :global(.snippets-input.snippets-construct-select) {
    border-color: #38bdf8;
    background: #f0f9ff;
  }
  :global(.snippets-input.snippets-model-select) {
    border-color: #4ade80;
    background: #ecfdf3;
  }
  :global(.snippets-input.snippets-journal-select) {
    border-color: #a78bfa;
    background: #f5f3ff;
  }
  :global(.snippets-input.snippets-snippet-type-select) {
    border-color: var(--color-maroon);
    background: rgba(113, 32, 56, 0.08);
  }
  :global(.snippets-clear-btn) {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    align-self: flex-end;
    padding: 0.4rem 0.9rem;
    font-size: 0.8rem;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    background: #fff;
    cursor: pointer;
    white-space: nowrap;
  }
  :global(.snippets-clear-icon) {
    font-size: 1.1rem;
    line-height: 1;
    font-weight: 700;
    opacity: 0.85;
  }

  :global(.snippets-add-section) {
    margin-bottom: 2rem;
  }
  :global(.snippets-section-title) {
    font-size: 1.1rem;
    margin: 0 0 0.75rem 0;
  }
  :global(.snippets-form) {
    padding: 1.5rem 1.75rem;
    background: #fff;
    border-radius: 12px;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  :global(.snippets-label) {
    font-size: 0.9rem;
    color: var(--color-ink);
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  :global(.snippets-textarea) {
    border-radius: 8px;
    border: 1px solid var(--color-border);
    padding: 0.6rem 0.7rem;
    font-size: 0.9rem;
    resize: vertical;
  }
  :global(.snippets-form-row) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1rem;
  }
  :global(.snippets-label-inline) {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: 0.85rem;
    color: var(--color-ink-muted);
  }
  :global(.snippets-input-inline) {
    min-width: 160px;
    padding: 0.45rem 0.6rem;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    background: #fff;
    font-size: 0.85rem;
  }
  :global(.snippets-input-page) {
    max-width: 80px;
  }
  :global(.snippets-add-btn) {
    align-self: flex-start;
    margin-top: 0.25rem;
    padding: 0.55rem 1.2rem;
    background: var(--color-maroon);
    color: #fff;
    border-radius: 8px;
    border: none;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
  }
  :global(.snippets-add-btn:disabled) {
    opacity: 0.6;
    cursor: default;
  }

  :global(.snippets-modal-overlay) {
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 50;
    padding: 1rem;
  }
  :global(.snippets-modal) {
    max-width: 720px;
    width: 100%;
    background: #fff;
    border-radius: 12px;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--color-border);
  }
  :global(.snippets-modal-header) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem 0.5rem 1.5rem;
  }
  :global(.snippets-modal-close) {
    border: none;
    background: transparent;
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
  }
  :global(.snippets-modal-actions) {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  :global(.snippets-list-section) {
    margin-bottom: 2rem;
  }
  :global(.snippets-list) {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  :global(.snippets-card) {
    padding: 1rem 1.15rem;
    background: #fff;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }
  :global(.snippets-card-header) {
    margin-bottom: 0.4rem;
  }
  :global(.snippets-card-selectable .snippets-card-header) {
    display: flex;
    gap: 0.65rem;
    align-items: flex-start;
  }
  :global(.snippets-card-checkbox-wrap) {
    flex-shrink: 0;
    padding-top: 0.1rem;
    cursor: pointer;
  }
  :global(.snippets-card-selectable .snippets-card-title-row) {
    flex: 1;
    min-width: 0;
  }
  :global(.snippets-card-title-row) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: baseline;
    justify-content: space-between;
  }
  :global(.snippets-card-title) {
    font-weight: 600;
    font-size: 0.95rem;
    margin: 0;
    white-space: pre-wrap;
  }
  :global(.snippets-card-toggle) {
    border: 1px solid var(--color-border);
    background: #fff;
    color: var(--color-maroon);
    border-radius: 999px;
    padding: 0.15rem 0.55rem;
    font-size: 0.72rem;
    font-weight: 600;
    cursor: pointer;
    flex-shrink: 0;
  }
  :global(.snippets-card-toggle:hover) {
    background: rgba(113, 32, 56, 0.08);
  }
  :global(.snippets-card-paper) {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-maroon);
    text-decoration: none;
  }
  :global(.snippets-card-paper:hover) {
    text-decoration: underline;
  }
  :global(.snippets-card-page) {
    font-size: 0.8rem;
    color: var(--color-ink-muted);
  }
  :global(.snippets-card-page-inline) {
    font-size: 0.8rem;
    color: var(--color-ink-muted);
  }
  :global(.snippets-card-journal) {
    font-size: 0.8rem;
    color: #6d28d9;
    background: #f5f3ff;
    border: 1px solid #a78bfa;
    padding: 0.15rem 0.45rem;
    border-radius: 6px;
    font-style: italic;
  }
  :global(.snippets-card-type) {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-maroon);
    text-transform: capitalize;
    margin-bottom: 0.35rem;
    padding: 0.15rem 0.5rem;
    background: rgba(113, 32, 56, 0.08);
    border-radius: 4px;
  }
  :global(.snippets-card-links) {
    margin-top: 0.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }
  :global(.snippets-chip) {
    font-size: 0.8rem;
    padding: 0.15rem 0.6rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: var(--color-bg-alt);
    color: var(--color-maroon);
    text-decoration: none;
  }
  :global(.snippets-chip:hover) {
    text-decoration: underline;
  }
  :global(.snippets-chip-construct) {
    background: #e0f2fe;
    border-color: #38bdf8;
    color: #0369a1;
  }
  :global(.snippets-chip-model) {
    background: #e5f9e7;
    border-color: #4ade80;
    color: #166534;
  }
  :global(.snippets-card-content) {
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0.3rem 0 0.4rem 0;
  }
  :global(.snippets-card-tags) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-bottom: 0.3rem;
  }
  :global(.snippets-tag) {
    font-size: 0.8rem;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
  }
  :global(.snippets-card-footer) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 0.2rem;
  }
  :global(.snippets-card-actions) {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
  :global(.snippets-card-date) {
    font-size: 0.8rem;
    color: var(--color-ink-muted);
  }
  :global(.snippets-delete-btn) {
    font-size: 0.8rem;
    border: none;
    background: transparent;
    color: var(--color-error, #b91c1c);
    cursor: pointer;
  }
  :global(.snippets-edit-btn),
  :global(.snippets-edit-save-btn),
  :global(.snippets-edit-cancel-btn) {
    font-size: 0.8rem;
    border-radius: 6px;
    border: 1px solid var(--color-border);
    background: var(--color-bg-alt);
    padding: 0.25rem 0.7rem;
    cursor: pointer;
  }
  :global(.snippets-edit-save-btn) {
    background: var(--color-maroon);
    color: #fff;
    border-color: var(--color-maroon);
  }
  :global(.snippets-edit-cancel-btn) {
    background: transparent;
  }
  :global(.snippets-loading),
  :global(.snippets-empty),
  :global(.snippets-error) {
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    margin-top: 1rem;
  }
  :global(.snippets-error) {
    color: var(--color-error, #b91c1c);
  }

  :global(.snippets-saved-prompts) {
    grid-column: 1 / -1;
    margin-top: 0.5rem;
    padding: 1.25rem 1.35rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    border-left: 4px solid var(--color-maroon);
  }
  :global(.snippets-saved-intro) {
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    line-height: 1.55;
    margin: 0 0 1rem 0;
  }
  :global(.snippets-saved-loading),
  :global(.snippets-saved-empty) {
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    margin: 0;
  }
  :global(.snippets-saved-list) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  :global(.snippets-saved-card) {
    padding: 1rem 1.15rem;
    background: #fff;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }
  :global(.snippets-saved-claim) {
    margin: 0 0 0.35rem 0;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--color-ink);
  }
  :global(.snippets-saved-meta) {
    margin: 0;
    font-size: 0.8rem;
    color: var(--color-ink-muted);
  }
  :global(.snippets-saved-details) {
    margin-top: 0.65rem;
    font-size: 0.85rem;
  }
  :global(.snippets-saved-details summary) {
    cursor: pointer;
    color: var(--color-maroon);
    font-weight: 600;
  }
  :global(.snippets-saved-snippet-list) {
    margin: 0.4rem 0 0 1.1rem;
    padding: 0;
    line-height: 1.45;
    font-size: 0.85rem;
    color: var(--color-ink);
  }
  :global(.snippets-saved-snippet-paper) {
    color: var(--color-ink-muted);
    font-style: italic;
  }
  :global(.snippets-saved-snippet-missing) {
    color: var(--color-ink-muted);
  }
  :global(.snippets-saved-prompt-pre) {
    margin: 0.4rem 0 0 0;
    padding: 0.75rem;
    background: var(--color-bg-alt);
    border-radius: 8px;
    font-size: 0.78rem;
    line-height: 1.45;
    white-space: pre-wrap;
    word-break: break-word;
    max-height: 240px;
    overflow: auto;
  }
  :global(.snippets-saved-label) {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-top: 0.85rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-ink);
  }
  :global(.snippets-saved-textarea) {
    width: 100%;
    padding: 0.6rem 0.75rem;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    font-size: 0.9rem;
    line-height: 1.5;
    resize: vertical;
    font-family: var(--font-sans);
  }
  :global(.snippets-saved-card-actions) {
    margin-top: 0.65rem;
  }
  :global(.snippets-saved-delete) {
    font-size: 0.8rem;
    border: none;
    background: transparent;
    color: var(--color-error, #b91c1c);
    cursor: pointer;
    padding: 0;
  }
  :global(.snippets-modal-wide) {
    max-width: min(720px, 100vw - 2rem);
    width: 100%;
  }
  :global(.snippets-prompt-modal-body) {
    padding: 0 1.5rem 1.25rem 1.5rem;
  }
  :global(.snippets-prompt-hint) {
    font-size: 0.88rem;
    color: var(--color-ink-muted);
    line-height: 1.55;
    margin: 0 0 0.75rem 0;
  }
  :global(.snippets-prompt-output) {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    line-height: 1.5;
  }
  :global(.snippets-prompt-back-btn) {
    padding: 0.55rem 1rem;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    background: #fff;
    cursor: pointer;
    font-size: 0.9rem;
  }
  :global(.snippets-modal-actions) {
    flex-wrap: wrap;
  }

  @media (max-width: 640px) {
    :global(.snippets-form) {
      padding: 1.25rem 1.1rem;
    }
    :global(.snippets-input),
    :global(.snippets-search-label .snippets-input) {
      min-width: 140px;
    }
  }
</style>

