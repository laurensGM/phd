---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ConstructsListPage from '../../components/ConstructsListPage';
import constructs from '../../data/constructs.json';
import umbrellaConstructs from '../../data/umbrella-constructs.json';
import models from '../../data/models.json';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Constructs" description="Theoretical constructs - definitions, measurement scales, sources">
  <h1>Constructs</h1>
  <p class="page-desc">Definitions, source papers, measurement items, and related models. Filter by umbrella construct to see constructs by category.</p>

  <ConstructsListPage
    client:load
    constructs={constructs}
    umbrellaConstructs={umbrellaConstructs}
    models={models}
  />
</BaseLayout>

<style>
  .page-desc { color: var(--color-ink-muted); margin-bottom: 2rem; }

  :global(.constructs-page) {
    background: #f7f4ef;
    padding: 1rem;
    border-radius: 12px;
    margin-bottom: 2rem;
  }

  :global(.constructs-letter-filter) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 0.85rem;
  }

  :global(.constructs-letter-label) {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-ink);
    margin-right: 0.2rem;
  }

  :global(.constructs-letter-chip) {
    padding: 0.22rem 0.5rem;
    border: 1px solid #d1c9b8;
    border-radius: 6px;
    background: #fff;
    font-size: 0.78rem;
    line-height: 1;
    cursor: pointer;
    color: #5a4a3a;
  }

  :global(.constructs-letter-chip:hover) {
    background: #faf8f3;
  }

  :global(.constructs-letter-chip.active) {
    background: #6b1a2a;
    border-color: #6b1a2a;
    color: #c9a84c;
    font-weight: 700;
  }

  :global(.constructs-umbrella-list) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  :global(.constructs-umbrella-label) {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-ink);
    margin-right: 0.25rem;
  }

  :global(.constructs-umbrella-chip) {
    padding: 0.35rem 0.75rem;
    border: 1px solid #d1c9b8;
    border-radius: 6px;
    background: white;
    font-size: 0.85rem;
    cursor: pointer;
    color: #5a4a3a;
  }

  :global(.constructs-umbrella-chip:hover) {
    background: #faf8f3;
  }

  :global(.constructs-umbrella-chip.active) {
    background: #6b1a2a;
    border-color: #6b1a2a;
    color: #c9a84c;
  }

  :global(.constructs-model-list) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.2rem;
  }

  :global(.constructs-model-label) {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-ink);
    margin-right: 0.25rem;
  }

  :global(.constructs-model-chip) {
    padding: 0.35rem 0.75rem;
    border: 1px solid #d1c9b8;
    border-radius: 6px;
    background: white;
    font-size: 0.85rem;
    cursor: pointer;
    color: #5a4a3a;
  }

  :global(.constructs-model-chip:hover) {
    background: #faf8f3;
  }

  :global(.constructs-model-chip.active) {
    background: #6b1a2a;
    border-color: #6b1a2a;
    color: #c9a84c;
  }

  :global(.constructs-importance-list) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  :global(.constructs-importance-label) {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-ink);
    margin-right: 0.25rem;
  }

  :global(.constructs-importance-chip) {
    padding: 0.35rem 0.75rem;
    border: 1px solid #d1c9b8;
    border-radius: 6px;
    background: white;
    font-size: 0.85rem;
    cursor: pointer;
    color: #5a4a3a;
  }

  :global(.constructs-importance-chip:hover) {
    background: #faf8f3;
  }

  :global(.constructs-importance-chip.active) {
    background: #6b1a2a;
    border-color: #6b1a2a;
    color: #c9a84c;
  }

  :global(.constructs-grid) {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  :global(.construct-card) {
    padding: 1.5rem;
    background: #fff;
    border: 0.5px solid #e0d8cc;
    border-left: 3px solid #e0d8cc;
    border-radius: 12px;
    position: relative;
    min-height: 210px;
    max-height: 210px;
    overflow: hidden;
  }

  :global(.construct-card.construct-card-top) {
    background: #fff;
    border-left-color: #c9a84c;
    color: #1c1008;
  }

  :global(.construct-card.construct-card-ci) {
    background: #fff;
    border-left-color: #6b1a2a;
    color: #1c1008;
  }

  :global(.construct-card.construct-card-secondary) {
    background: #fff;
    border-left-color: #e0d8cc;
  }

  :global(.construct-card.construct-card-top a),
  :global(.construct-card.construct-card-top .source),
  :global(.construct-card.construct-card-top .meta),
  :global(.construct-card.construct-card-top .abbrev),
  :global(.construct-card.construct-card-top .definition),
  :global(.construct-card.construct-card-ci a),
  :global(.construct-card.construct-card-ci .source),
  :global(.construct-card.construct-card-ci .meta),
  :global(.construct-card.construct-card-ci .abbrev),
  :global(.construct-card.construct-card-ci .definition) {
    color: inherit;
  }

  :global(.construct-card.construct-card-top .abbrev) {
    background: #fdf3dc;
    color: #7a5400;
  }

  :global(.construct-card.construct-card-ci .abbrev) {
    background: #f5e8ea;
    color: #6b1a2a;
  }

  :global(.construct-card.construct-card-secondary .abbrev) {
    background: #f0ece4;
    color: #5a4a3a;
  }

  :global(.construct-card-umbrella) {
    display: inline-block;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #9a8878;
    margin-bottom: 0.5rem;
  }

  :global(.construct-card h2) {
    margin-top: 0;
    font-size: 15px;
    font-weight: 500;
    color: #1c1008;
  }
  :global(.construct-card h2 a) {
    color: #1c1008;
    text-decoration: none;
  }
  :global(.construct-card .abbrev) {
    display: inline-block;
    margin-left: 0.5rem;
    padding: 0.16rem 0.52rem;
    font-size: 11px;
    font-weight: 600;
    border-radius: 999px;
    background: #f0ece4;
    color: #5a4a3a;
  }
  :global(.construct-card .definition) {
    font-size: 13px;
    color: #5a4a3a;
    line-height: 1.6;
    margin: 0.75rem 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  :global(.construct-card .source) {
    font-size: 11px;
    color: #9a8878;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  :global(.construct-card .meta) {
    font-size: 13px;
    color: #5a4a3a;
    margin-top: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  :global(.construct-card-theory-tags) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  :global(.construct-theory-tag) {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.5rem;
    background: #fff;
    border: 0.5px solid #d1c9b8;
    border-radius: 999px;
    color: #5a4a3a;
    font-size: 11px;
    line-height: 1.2;
    font-weight: 500;
  }
  :global(.construct-card .meta span) {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  :global(.constructs-empty) {
    color: var(--color-ink-muted);
    font-style: italic;
  }
</style>
