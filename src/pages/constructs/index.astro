---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ConstructsListPage from '../../components/ConstructsListPage';
import constructs from '../../data/constructs.json';
import umbrellaConstructs from '../../data/umbrella-constructs.json';
import models from '../../data/models.json';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Constructs" description="Theoretical constructs - definitions, measurement scales, sources">
  <h1>Constructs</h1>
  <p class="page-desc">Definitions, source papers, measurement items, and related models. Filter by umbrella construct to see constructs by category.</p>

  <ConstructsListPage
    client:load
    constructs={constructs}
    umbrellaConstructs={umbrellaConstructs}
    models={models}
  />
</BaseLayout>

<style>
  .page-desc { color: var(--color-ink-muted); margin-bottom: 2rem; }

  :global(.constructs-page) {
    margin-bottom: 2rem;
  }

  :global(.constructs-letter-filter) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 0.85rem;
  }

  :global(.constructs-letter-label) {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-ink);
    margin-right: 0.2rem;
  }

  :global(.constructs-letter-chip) {
    padding: 0.22rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: #fff;
    font-size: 0.78rem;
    line-height: 1;
    cursor: pointer;
    color: var(--color-ink);
  }

  :global(.constructs-letter-chip:hover) {
    background: var(--color-bg-alt);
  }

  :global(.constructs-letter-chip.active) {
    background: rgba(113, 32, 56, 0.12);
    border-color: var(--color-maroon);
    color: var(--color-maroon);
    font-weight: 700;
  }

  :global(.constructs-umbrella-list) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  :global(.constructs-umbrella-label) {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-ink);
    margin-right: 0.25rem;
  }

  :global(.constructs-umbrella-chip) {
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: white;
    font-size: 0.85rem;
    cursor: pointer;
    color: var(--color-ink);
  }

  :global(.constructs-umbrella-chip:hover) {
    background: var(--color-bg-alt);
  }

  :global(.constructs-umbrella-chip.active) {
    background: rgba(113, 32, 56, 0.12);
    border-color: var(--color-maroon);
    color: var(--color-maroon);
  }

  :global(.constructs-model-list) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.2rem;
  }

  :global(.constructs-model-label) {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-ink);
    margin-right: 0.25rem;
  }

  :global(.constructs-model-chip) {
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: white;
    font-size: 0.85rem;
    cursor: pointer;
    color: var(--color-ink);
  }

  :global(.constructs-model-chip:hover) {
    background: var(--color-bg-alt);
  }

  :global(.constructs-model-chip.active) {
    background: rgba(113, 32, 56, 0.12);
    border-color: var(--color-maroon);
    color: var(--color-maroon);
  }

  :global(.constructs-importance-list) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  :global(.constructs-importance-label) {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-ink);
    margin-right: 0.25rem;
  }

  :global(.constructs-importance-chip) {
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: white;
    font-size: 0.85rem;
    cursor: pointer;
    color: var(--color-ink);
  }

  :global(.constructs-importance-chip:hover) {
    background: var(--color-bg-alt);
  }

  :global(.constructs-importance-chip.active) {
    background: rgba(113, 32, 56, 0.12);
    border-color: var(--color-maroon);
    color: var(--color-maroon);
  }

  :global(.constructs-grid) {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  :global(.construct-card) {
    padding: 1.5rem;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    position: relative;
    min-height: 210px;
    max-height: 210px;
    overflow: hidden;
  }

  :global(.construct-card.construct-card-top) {
    background: linear-gradient(135deg, #e9d48a 0%, #d8bc67 100%);
    border-color: #b5953e;
    color: #3e2b09;
  }

  :global(.construct-card.construct-card-ci) {
    background: var(--color-maroon);
    border-color: var(--color-gold);
    color: #f7e6a3;
  }

  :global(.construct-card.construct-card-secondary) {
    background: #fff7de;
    border-color: #e0c773;
  }

  :global(.construct-card.construct-card-top a),
  :global(.construct-card.construct-card-top .source),
  :global(.construct-card.construct-card-top .meta),
  :global(.construct-card.construct-card-top .abbrev),
  :global(.construct-card.construct-card-top .definition),
  :global(.construct-card.construct-card-ci a),
  :global(.construct-card.construct-card-ci .source),
  :global(.construct-card.construct-card-ci .meta),
  :global(.construct-card.construct-card-ci .abbrev),
  :global(.construct-card.construct-card-ci .definition) {
    color: inherit;
  }

  :global(.construct-card.construct-card-top .abbrev) {
    background: rgba(62, 43, 9, 0.12);
    color: #3e2b09;
  }

  :global(.construct-card.construct-card-ci .abbrev) {
    background: rgba(247, 230, 163, 0.16);
    color: #f7e6a3;
  }

  :global(.construct-card.construct-card-top .construct-card-umbrella),
  :global(.construct-card.construct-card-ci .construct-card-umbrella) {
    color: #fff;
    background: rgba(255, 255, 255, 0.16);
  }

  :global(.construct-card.construct-card-top .construct-card-umbrella) {
    color: #3e2b09;
    background: rgba(62, 43, 9, 0.12);
  }

  :global(.construct-card-umbrella) {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-maroon);
    background: rgba(113, 32, 56, 0.08);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    margin-bottom: 0.5rem;
  }

  :global(.construct-card h2) { margin-top: 0; font-size: 1.25rem; }
  :global(.construct-card .abbrev) {
    display: inline-block;
    margin-left: 0.5rem;
    padding: 0.15rem 0.5rem;
    background: var(--color-bg-alt);
    font-size: 0.8rem;
    font-weight: 600;
    border-radius: 4px;
  }
  :global(.construct-card .definition) {
    font-style: italic;
    margin: 0.75rem 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  :global(.construct-card .source) {
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  :global(.construct-card .meta) {
    font-size: 0.85rem;
    margin-top: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  :global(.construct-card .meta span) {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  :global(.constructs-empty) {
    color: var(--color-ink-muted);
    font-style: italic;
  }
</style>
