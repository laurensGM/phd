---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ConstructsListPage from '../../components/ConstructsListPage';
import constructs from '../../data/constructs.json';
import umbrellaConstructs from '../../data/umbrella-constructs.json';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Constructs" description="Theoretical constructs - definitions, measurement scales, sources">
  <h1>Constructs</h1>
  <p class="page-desc">Definitions, source papers, measurement items, and related models. Filter by umbrella construct to see constructs by category.</p>

  <ConstructsListPage client:load constructs={constructs} umbrellaConstructs={umbrellaConstructs} />
</BaseLayout>

<style>
  .page-desc { color: var(--color-ink-muted); margin-bottom: 2rem; }

  :global(.constructs-page) {
    margin-bottom: 2rem;
  }

  :global(.constructs-letter-filter) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 0.85rem;
  }

  :global(.constructs-letter-label) {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-ink);
    margin-right: 0.2rem;
  }

  :global(.constructs-letter-chip) {
    padding: 0.22rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: #fff;
    font-size: 0.78rem;
    line-height: 1;
    cursor: pointer;
    color: var(--color-ink);
  }

  :global(.constructs-letter-chip:hover) {
    background: var(--color-bg-alt);
  }

  :global(.constructs-letter-chip.active) {
    background: rgba(113, 32, 56, 0.12);
    border-color: var(--color-maroon);
    color: var(--color-maroon);
    font-weight: 700;
  }

  :global(.constructs-umbrella-list) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  :global(.constructs-umbrella-label) {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-ink);
    margin-right: 0.25rem;
  }

  :global(.constructs-umbrella-chip) {
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: white;
    font-size: 0.85rem;
    cursor: pointer;
    color: var(--color-ink);
  }

  :global(.constructs-umbrella-chip:hover) {
    background: var(--color-bg-alt);
  }

  :global(.constructs-umbrella-chip.active) {
    background: rgba(113, 32, 56, 0.12);
    border-color: var(--color-maroon);
    color: var(--color-maroon);
  }

  :global(.constructs-filter-row) {
    margin-bottom: 1.5rem;
  }

  :global(.constructs-filter-row label) {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 0.35rem;
    color: var(--color-ink);
  }

  :global(.constructs-umbrella-select) {
    padding: 0.5rem 0.75rem;
    border: 2px solid var(--color-border);
    border-radius: 8px;
    font-size: 1rem;
    min-width: 260px;
    max-width: 100%;
  }

  :global(.constructs-grid) {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  :global(.construct-card) {
    padding: 1.5rem;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    position: relative;
    min-height: 210px;
    max-height: 210px;
    overflow: hidden;
  }

  :global(.construct-card-umbrella) {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-maroon);
    background: rgba(113, 32, 56, 0.08);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    margin-bottom: 0.5rem;
  }

  :global(.construct-card h2) { margin-top: 0; font-size: 1.25rem; }
  :global(.construct-card .abbrev) {
    display: inline-block;
    margin-left: 0.5rem;
    padding: 0.15rem 0.5rem;
    background: var(--color-bg-alt);
    font-size: 0.8rem;
    font-weight: 600;
    border-radius: 4px;
  }
  :global(.construct-card .definition) {
    font-style: italic;
    margin: 0.75rem 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  :global(.construct-card .source) {
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  :global(.construct-card .meta) {
    font-size: 0.85rem;
    margin-top: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  :global(.construct-card .meta span) {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  :global(.constructs-empty) {
    color: var(--color-ink-muted);
    font-style: italic;
  }
</style>
