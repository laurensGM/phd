---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ConstructNotes from '../../components/ConstructNotes';
import constructs from '../../data/constructs.json';
import models from '../../data/models.json';

export function getStaticPaths() {
  return constructs.map((c: { id: string }) => ({ params: { id: c.id } }));
}

const { id } = Astro.params;
const construct = constructs.find((c: { id: string }) => c.id === id);
const base = import.meta.env.BASE_URL;
if (!construct) {
  return Astro.redirect(`${base}constructs/`);
}

type ModelItem = {
  id: string;
  name?: string;
  abbreviation?: string;
  constructs?: string[];
};

const modelList = models as ModelItem[];

function canon(val: string): string {
  return val.trim().toLowerCase();
}

function modelMatchesLabel(model: ModelItem, label: string): boolean {
  const labelCanon = canon(label);
  if (!labelCanon) return false;
  return (
    canon(model.id) === labelCanon ||
    canon(model.name ?? '') === labelCanon ||
    canon(model.abbreviation ?? '') === labelCanon
  );
}

function resolveModelByLabel(label: string): ModelItem | undefined {
  return modelList.find((m) => modelMatchesLabel(m, label));
}

const relatedByConstructField = (construct.relatedModels ?? [])
  .map((label: string) => resolveModelByLabel(label))
  .filter(Boolean) as ModelItem[];

const relatedByModelMembership = modelList.filter((m) =>
  (m.constructs ?? []).some((name) => canon(name) === canon(construct.name))
);

const relatedModels = Array.from(
  new Map(
    [...relatedByConstructField, ...relatedByModelMembership].map((m) => [
      m.id,
      { id: m.id, label: m.abbreviation || m.name || m.id },
    ])
  ).values()
).sort((a, b) => a.label.localeCompare(b.label, undefined, { sensitivity: 'base' }));
---

<BaseLayout title={construct.name} description={construct.definition}>
  <article class="construct-detail">
    <header>
      <a href={`${base}constructs/`} class="back-link">← All Constructs</a>
      <h1>{construct.name}</h1>
      {construct.abbreviation && <span class="abbrev">{construct.abbreviation}</span>}
    </header>

    <section>
      <h2>Definition</h2>
      <p class="definition">{construct.definition}</p>
    </section>

    <section>
      <h2>Source</h2>
      <p>{construct.sourcePaper}</p>
      {construct.doi && (
        <p><a href={`https://doi.org/${construct.doi}`} target="_blank" rel="noopener">DOI: {construct.doi}</a></p>
      )}
    </section>

    <section>
      <h2>Measurement Scale</h2>
      <p>{construct.measurementScale}</p>
      {construct.measurementItems && construct.measurementItems.length > 0 && (
        <>
          <h3>Items</h3>
          <ol class="measurement-items">
            {construct.measurementItems.map((item: string) => (
              <li>{item}</li>
            ))}
          </ol>
        </>
      )}
    </section>

    <section>
      <h2>Theoretical Domain</h2>
      <p>{construct.theoreticalDomain}</p>
    </section>

    <section>
      <h2>Related Models</h2>
      <ul class="related-list">
        {relatedModels.length > 0 ? (
          relatedModels.map((m) => (
            <li><a href={`${base}models/${m.id}/`}>{m.label}</a></li>
          ))
        ) : (
          <li>No related models recorded yet.</li>
        )}
      </ul>
    </section>

    <section>
      <h2>Related Constructs</h2>
      <ul class="related-list">
        {construct.relatedConstructs?.map((c: string) => {
          const slug = constructs.find((x: any) => x.name === c)?.id;
          return <li><a href={slug ? `${base}constructs/${slug}/` : '#'}>{c}</a></li>;
        })}
      </ul>
    </section>

    <ConstructNotes client:load constructId={construct.id} staticNote={construct.notes} />
  </article>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  .abbrev {
    display: inline-block;
    margin-left: 0.5rem;
    padding: 0.25rem 0.75rem;
    background: var(--color-bg-alt);
    font-size: 1rem;
    font-weight: 600;
    border-radius: 4px;
  }

  .definition { font-size: 1.1rem; font-style: italic; }

  .measurement-items { margin: 0.5rem 0; }
  .measurement-items li { margin-bottom: 0.5rem; }

  .related-list { list-style: none; padding: 0; }
  .related-list li { margin-bottom: 0.5rem; }

  /* Construct notes (React) */
  :global(.construct-notes-section) {
    margin-top: 2rem;
    padding: 1.5rem;
    background: var(--color-bg-alt);
    border-radius: 8px;
    border-left: 4px solid var(--color-maroon);
  }
  :global(.construct-notes-title) {
    font-size: 1.25rem;
    margin: 0 0 1rem 0;
    color: var(--color-ink);
  }
  :global(.construct-notes-setup),
  :global(.construct-notes-static) {
    font-size: 0.95rem;
    color: var(--color-ink-muted);
    margin: 0.5rem 0;
  }
  :global(.construct-notes-error) {
    color: var(--color-maroon);
    font-size: 0.9rem;
    margin-bottom: 1rem;
    padding: 0.75rem;
    background: rgba(113, 32, 56, 0.08);
    border-radius: 6px;
  }
  :global(.construct-notes-add-form) {
    margin-bottom: 1.5rem;
  }
  :global(.construct-notes-textarea) {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 2px solid var(--color-border);
    border-radius: 8px;
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.5;
    color: var(--color-ink);
    background: #fff;
    resize: vertical;
    margin-bottom: 0.75rem;
    box-sizing: border-box;
  }
  :global(.construct-notes-textarea:focus) {
    outline: none;
    border-color: var(--color-maroon);
  }
  :global(.construct-notes-add-btn) {
    padding: 0.5rem 1.25rem;
    background: var(--color-maroon);
    color: #fff;
    border: 2px solid var(--color-gold);
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
  }
  :global(.construct-notes-add-btn:hover:not(:disabled)) {
    background: var(--color-maroon-dark);
  }
  :global(.construct-notes-add-btn:disabled) {
    opacity: 0.6;
    cursor: not-allowed;
  }
  :global(.construct-notes-loading),
  :global(.construct-notes-empty) {
    color: var(--color-ink-muted);
    font-size: 0.95rem;
    margin: 0.5rem 0;
  }
  :global(.construct-notes-list) {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  :global(.construct-notes-item) {
    padding: 1rem 1.25rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    margin-bottom: 0.75rem;
  }
  :global(.construct-notes-item-header) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }
  :global(.construct-notes-item-date) {
    font-size: 0.8rem;
    color: var(--color-ink-muted);
  }
  :global(.construct-notes-item-actions) {
    display: flex;
    gap: 0.5rem;
  }
  :global(.construct-notes-item-action) {
    padding: 0.25rem 0.6rem;
    font-size: 0.8rem;
    font-weight: 600;
    border: 1px solid var(--color-border);
    background: #fff;
    border-radius: 4px;
    cursor: pointer;
    color: var(--color-ink);
  }
  :global(.construct-notes-item-action:hover:not(:disabled)) {
    border-color: var(--color-maroon-muted);
    background: rgba(113, 32, 56, 0.06);
  }
  :global(.construct-notes-item-delete:hover:not(:disabled)) {
    border-color: var(--color-maroon);
    color: var(--color-maroon);
  }
  :global(.construct-notes-item-content) {
    margin: 0;
    white-space: pre-wrap;
    font-size: 0.95rem;
    line-height: 1.5;
  }
  :global(.construct-notes-edit-form) {
    margin-top: 0.25rem;
  }
  :global(.construct-notes-edit-form .construct-notes-textarea) {
    margin-bottom: 0.5rem;
  }
  :global(.construct-notes-edit-actions) {
    display: flex;
    gap: 0.5rem;
  }
  :global(.construct-notes-btn) {
    padding: 0.4rem 0.9rem;
    font-size: 0.85rem;
    font-weight: 600;
    border-radius: 6px;
    cursor: pointer;
    border: 2px solid transparent;
  }
  :global(.construct-notes-btn-primary) {
    background: var(--color-maroon);
    color: #fff;
    border-color: var(--color-gold);
  }
  :global(.construct-notes-btn-secondary) {
    background: var(--color-bg-alt);
    color: var(--color-ink);
    border-color: var(--color-border);
  }
</style>
