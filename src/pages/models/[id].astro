---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ModelDetailView from '../../components/ModelDetailView';
import models from '../../data/models.json';
import constructs from '../../data/constructs.json';

export function getStaticPaths() {
  return models.map((m: { id: string }) => ({ params: { id: m.id } }));
}

const { id } = Astro.params;
const base = import.meta.env.BASE_URL;
const model = models.find((m: { id: string }) => m.id === id);
const constructToSlug: Record<string, string> = {};
constructs.forEach((c: { name: string; id: string }) => {
  constructToSlug[c.name] = c.id;
});

if (!model) {
  return Astro.redirect(`${base}models/`);
}
---

<BaseLayout title={model.name} description={model.description}>
  <article class="model-detail-page">
    <a href={`${base}models/`} class="back-link">← All Models</a>
    <header class="model-detail-header">
      <h1>{model.name} ({model.abbreviation})</h1>
      <p class="model-meta">{model.authors?.length ? `Developed by: ${model.authors.join(', ')}` : ''}{model.year != null ? ` (${model.year})` : ''}{!model.authors?.length && model.year == null ? 'Your thesis model' : ''}</p>
    </header>

    <ModelDetailView client:load model={model} constructToSlug={constructToSlug} base={base} />
  </article>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  .model-detail-header {
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .model-detail-header h1 {
    margin: 0 0 0.35rem 0;
  }

  .model-meta {
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    margin: 0;
  }

  .model-detail-view .model-desc {
    margin-bottom: 1rem;
    line-height: 1.65;
    color: var(--color-ink);
  }

  /* Model notes (React): add, edit, delete */
  :global(.model-detail-view .model-notes-section) {
    margin: 1.5rem 0;
    padding: 1.5rem;
    background: var(--color-bg-alt);
    border-radius: 8px;
    border-left: 4px solid var(--color-maroon);
  }
  :global(.model-detail-view .model-notes-title) {
    font-size: 1rem;
    margin: 0 0 1rem 0;
    color: var(--color-ink);
  }
  :global(.model-detail-view .model-notes-setup),
  :global(.model-detail-view .model-notes-static) {
    font-size: 0.95rem;
    color: var(--color-ink-muted);
    margin: 0.5rem 0;
    white-space: pre-line;
  }
  :global(.model-detail-view .model-notes-error) {
    color: var(--color-maroon);
    font-size: 0.9rem;
    margin-bottom: 1rem;
    padding: 0.75rem;
    background: rgba(113, 32, 56, 0.08);
    border-radius: 6px;
  }
  :global(.model-detail-view .model-notes-add-form) {
    margin-bottom: 1rem;
  }
  :global(.model-detail-view .model-notes-textarea) {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 2px solid var(--color-border);
    border-radius: 8px;
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.5;
    color: var(--color-ink);
    background: #fff;
    resize: vertical;
    margin-bottom: 0.75rem;
    box-sizing: border-box;
  }
  :global(.model-detail-view .model-notes-textarea:focus) {
    outline: none;
    border-color: var(--color-maroon);
  }
  :global(.model-detail-view .model-notes-add-btn) {
    padding: 0.5rem 1.25rem;
    background: var(--color-maroon);
    color: #fff;
    border: 2px solid var(--color-gold);
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
  }
  :global(.model-detail-view .model-notes-add-btn:hover:not(:disabled)) {
    background: var(--color-maroon-dark);
  }
  :global(.model-detail-view .model-notes-add-btn:disabled) {
    opacity: 0.6;
    cursor: not-allowed;
  }
  :global(.model-detail-view .model-notes-loading),
  :global(.model-detail-view .model-notes-empty) {
    color: var(--color-ink-muted);
    font-size: 0.95rem;
    margin: 0.5rem 0;
  }
  :global(.model-detail-view .model-notes-list) {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  :global(.model-detail-view .model-notes-item) {
    padding: 1rem 1.25rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    margin-bottom: 0.75rem;
  }
  :global(.model-detail-view .model-notes-item-header) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }
  :global(.model-detail-view .model-notes-item-date) {
    font-size: 0.8rem;
    color: var(--color-ink-muted);
  }
  :global(.model-detail-view .model-notes-item-actions) {
    display: flex;
    gap: 0.4rem;
  }
  :global(.model-detail-view .model-notes-item-action) {
    padding: 0.25rem 0.6rem;
    font-size: 0.8rem;
    font-weight: 600;
    border: 1px solid var(--color-border);
    background: #fff;
    border-radius: 4px;
    cursor: pointer;
    color: var(--color-ink);
  }
  :global(.model-detail-view .model-notes-item-action:hover:not(:disabled)) {
    border-color: var(--color-maroon-muted);
    background: rgba(113, 32, 56, 0.06);
  }
  :global(.model-detail-view .model-notes-item-delete:hover:not(:disabled)) {
    border-color: var(--color-maroon);
    color: var(--color-maroon);
  }
  :global(.model-detail-view .model-notes-item-content) {
    margin: 0;
    white-space: pre-wrap;
    font-size: 0.95rem;
    line-height: 1.5;
  }
  :global(.model-detail-view .model-notes-edit-form) {
    margin-top: 0.25rem;
  }
  :global(.model-detail-view .model-notes-edit-form .model-notes-textarea) {
    margin-bottom: 0.5rem;
  }
  :global(.model-detail-view .model-notes-edit-actions) {
    display: flex;
    gap: 0.5rem;
  }
  :global(.model-detail-view .model-notes-btn) {
    padding: 0.4rem 0.9rem;
    font-size: 0.85rem;
    font-weight: 600;
    border-radius: 6px;
    cursor: pointer;
    border: 2px solid transparent;
  }
  :global(.model-detail-view .model-notes-btn-primary) {
    background: var(--color-maroon);
    color: #fff;
    border-color: var(--color-gold);
  }
  :global(.model-detail-view .model-notes-btn-secondary) {
    background: var(--color-bg-alt);
    color: var(--color-ink);
    border-color: var(--color-border);
  }

  .model-detail-view h3 {
    font-size: 1rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  :global(.model-detail-view .model-library-citations-heading) {
    font-size: 0.95rem;
    margin: 1.25rem 0 0.35rem 0;
    color: var(--color-ink);
  }

  :global(.model-detail-view .model-library-citations-desc) {
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    margin: 0 0 0.75rem 0;
    line-height: 1.5;
  }

  :global(.model-detail-view .model-paper-citations) {
    margin: 0 0 1rem 0;
    padding: 1rem 1.25rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }

  :global(.model-detail-view .model-paper-citations-setup .model-paper-citations-hint) {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-ink-muted);
  }

  :global(.model-detail-view .model-paper-citations-error) {
    color: var(--color-maroon);
    font-size: 0.875rem;
    margin: 0 0 0.75rem 0;
  }

  :global(.model-detail-view .model-paper-citations-label) {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 0.35rem;
    color: var(--color-ink);
  }

  :global(.model-detail-view .model-paper-citations-row) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  :global(.model-detail-view .model-paper-citations-select) {
    flex: 1;
    min-width: 200px;
    padding: 0.5rem 0.65rem;
    border: 2px solid var(--color-border);
    border-radius: 8px;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    background: #fff;
  }

  :global(.model-detail-view .model-paper-citations-select:focus) {
    outline: none;
    border-color: var(--color-maroon);
  }

  :global(.model-detail-view .model-paper-citations-add) {
    padding: 0.5rem 1rem;
    background: var(--color-maroon);
    color: #fff;
    border: 2px solid var(--color-gold);
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
  }

  :global(.model-detail-view .model-paper-citations-add:disabled) {
    opacity: 0.55;
    cursor: not-allowed;
  }

  :global(.model-detail-view .model-paper-citations-loading) {
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    margin: 0.5rem 0 0 0;
  }

  :global(.model-detail-view .model-paper-citations-empty) {
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    margin: 0.5rem 0 0 0;
  }

  :global(.model-detail-view .model-paper-citations-list) {
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 0.75rem;
  }

  :global(.model-detail-view .model-paper-citations-item) {
    margin: 0;
  }

  :global(.model-detail-view .model-paper-card) {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: #fff;
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    min-height: 126px;
  }

  :global(.model-detail-view .model-paper-card-header) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
  }

  :global(.model-detail-view .model-paper-status) {
    display: inline-block;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 600;
    line-height: 1;
    border: 1px solid transparent;
  }

  :global(.model-detail-view .model-paper-status-not-read) { background: #e2e8f0; color: #475569; border-color: #cbd5e1; }
  :global(.model-detail-view .model-paper-status-1st-reading) { background: #dbeafe; color: #1e40af; border-color: #bfdbfe; }
  :global(.model-detail-view .model-paper-status-2nd-reading) { background: #e0e7ff; color: #3730a3; border-color: #c7d2fe; }
  :global(.model-detail-view .model-paper-status-read) { background: #fef9c3; color: #854d0e; border-color: #fde68a; }
  :global(.model-detail-view .model-paper-status-completed) { background: #dcfce7; color: #166534; border-color: #bbf7d0; }
  :global(.model-detail-view .model-paper-status-archive) { background: #f3e8ff; color: #6b21a8; border-color: #e9d5ff; }

  :global(.model-detail-view .model-paper-card-title) {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.35;
  }

  :global(.model-detail-view .model-paper-citations-link) {
    color: var(--color-maroon);
    font-weight: 600;
    text-decoration: none;
    flex: 1;
  }

  :global(.model-detail-view .model-paper-citations-link:hover) {
    text-decoration: underline;
  }

  :global(.model-detail-view .model-paper-card-meta) {
    margin: 0;
    font-size: 0.82rem;
    color: var(--color-ink-muted);
    line-height: 1.45;
  }

  :global(.model-detail-view .model-paper-citations-remove) {
    flex-shrink: 0;
    padding: 0.2rem 0.5rem;
    font-size: 0.8rem;
    font-weight: 600;
    border: 1px solid var(--color-border);
    background: #fff;
    border-radius: 6px;
    cursor: pointer;
    color: var(--color-ink-muted);
  }

  :global(.model-detail-view .model-paper-citations-remove:hover:not(:disabled)) {
    border-color: var(--color-maroon);
    color: var(--color-maroon);
  }

  .model-detail-view .construct-list,
  .model-detail-view .relationship-list,
  .model-detail-view .citations-list {
    line-height: 1.8;
    margin: 0;
    padding-left: 1.25rem;
  }

  .model-detail-view .construct-list li,
  .model-detail-view .relationship-list li,
  .model-detail-view .citations-list li {
    margin-bottom: 0.35rem;
  }

  .model-graph-wrapper {
    margin: 1rem 0;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: var(--color-bg-alt);
    overflow: hidden;
    height: 480px;
  }

  /* React Flow needs its parent to have explicit dimensions */
  .model-graph-wrapper :global(.react-flow) {
    width: 100%;
    height: 100%;
    min-height: 400px;
  }

  .model-graph-wrapper :global(.react-flow__renderer),
  .model-graph-wrapper :global(.react-flow__viewport) {
    width: 100%;
    height: 100%;
  }

  .model-diagram-empty {
    padding: 2rem;
    text-align: center;
    color: var(--color-ink-muted);
  }

  /* Diagram: clear boxes for constructs, arrows between them (global so React-rendered nodes are styled) */
  .model-graph-wrapper :global(.model-diagram-box) {
    background: #fff;
    border: 2px solid var(--color-maroon);
    border-radius: 8px;
    padding: 0;
    min-width: 180px;
    min-height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-sm);
  }

  .model-graph-wrapper :global(.model-diagram-box-link) {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1rem;
    text-decoration: none;
    color: var(--color-ink);
    width: 100%;
    height: 100%;
    min-height: 56px;
    box-sizing: border-box;
  }

  .model-graph-wrapper :global(.model-diagram-box-link:hover) {
    background: var(--color-bg);
    color: var(--color-maroon);
    text-decoration: none;
  }

  .model-graph-wrapper :global(.model-diagram-box-abbrev) {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-maroon);
    display: block;
  }

  .model-graph-wrapper :global(.model-diagram-box-name) {
    font-size: 0.75rem;
    color: var(--color-ink-muted);
    text-align: center;
    line-height: 1.2;
    margin-top: 0.15rem;
    display: block;
  }

  .model-graph-wrapper :global(.model-diagram-handle) {
    width: 8px;
    height: 8px;
    background: var(--color-maroon);
    border: 2px solid #fff;
  }

  .model-graph-wrapper :global(.react-flow__edge-path) {
    stroke-width: 2;
  }

  /* Generic static diagram (other models) */
  .model-detail-view :global(.static-diagram) {
    margin: 1.5rem 0;
    padding: 1.5rem;
    background: var(--color-bg-alt);
    border-radius: 12px;
    border: 1px solid var(--color-border);
  }

  .model-detail-view :global(.static-diagram-hint) {
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    margin: 0 0 1rem 0;
  }

  .model-detail-view :global(.static-diagram-flow) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1rem;
  }

  .model-detail-view :global(.static-diagram-box) {
    display: flex;
    flex-direction: column;
    padding: 0.75rem 1rem;
    min-width: 180px;
    background: #fff;
    border-radius: 10px;
    border: 2px solid var(--color-border);
    text-decoration: none;
    color: var(--color-ink);
    box-shadow: var(--shadow-sm);
  }

  .model-detail-view :global(.static-diagram-box:hover) {
    border-color: var(--color-gold);
    text-decoration: none;
    color: var(--color-ink);
  }

  .model-detail-view :global(.static-diagram-box-prior) { border-color: var(--color-maroon-muted); }
  .model-detail-view :global(.static-diagram-box-postuse) { border-color: #6B9AC4; }
  .model-detail-view :global(.static-diagram-box-affective) { border-color: var(--color-gold); }
  .model-detail-view :global(.static-diagram-box-intention) { border-color: var(--color-gold-dark); }
  .model-detail-view :global(.static-diagram-box-behavior) { border-color: var(--color-maroon); }
  .model-detail-view :global(.static-diagram-box-generic) { border-color: var(--color-maroon); }

  .model-detail-view :global(.static-diagram-box-label) {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--color-ink-muted);
    margin-bottom: 0.25rem;
  }

  .model-detail-view :global(.static-diagram-box-name) {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-ink);
  }

  .model-detail-view :global(.static-diagram-box-desc) {
    font-size: 0.8rem;
    color: var(--color-ink-muted);
    margin-top: 0.25rem;
  }

  .model-detail-view :global(.static-diagram-box-abbrev) {
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--color-maroon);
  }

  .model-detail-view :global(.static-diagram-stack) {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .model-detail-view :global(.static-diagram-arrows-row) {
    display: flex;
    gap: 1rem;
  }

  .model-detail-view :global(.static-diagram-arrow-wrap) {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .model-detail-view :global(.static-diagram-arrow-label) {
    font-size: 0.75rem;
    color: var(--color-ink-muted);
    font-style: italic;
  }

  .model-detail-view :global(.static-diagram-arrow) {
    color: var(--color-maroon);
    font-size: 1.25rem;
  }

  .model-detail-view :global(.static-diagram-note) {
    margin: 1.25rem 0 0 0;
    padding: 0.75rem 1rem;
    background: #fff;
    border-left: 4px solid var(--color-gold);
    border-radius: 6px;
    font-size: 0.9rem;
  }

  .model-detail-view :global(.static-diagram-legend) {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1rem;
    font-size: 0.8rem;
    color: var(--color-ink-muted);
  }

  .model-detail-view :global(.static-diagram-legend-dot) {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 2px;
    margin-right: 0.35rem;
    vertical-align: middle;
  }

  .model-detail-view :global(.static-diagram-legend-dot.prior) { background: var(--color-maroon-muted); }
  .model-detail-view :global(.static-diagram-legend-dot.postuse) { background: #6B9AC4; }
  .model-detail-view :global(.static-diagram-legend-dot.affective) { background: var(--color-gold); }
  .model-detail-view :global(.static-diagram-legend-dot.intention) { background: var(--color-gold-dark); }
  .model-detail-view :global(.static-diagram-legend-dot.behavior) { background: var(--color-maroon); }

  .model-detail-view :global(.static-diagram-generic-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }

  .model-detail-view :global(.static-diagram-relationships) {
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .model-detail-view :global(.static-diagram-relationships h4) {
    font-size: 0.95rem;
    margin: 0 0 0.5rem 0;
  }

  .model-detail-view :global(.static-diagram-relationships ul) {
    margin: 0;
    padding-left: 1.25rem;
    line-height: 1.8;
  }

  /* Generic flow diagram (TAM2, UTAUT, etc.) */
  .model-detail-view :global(.flow-diagram-wrap) {
    margin: 1.5rem 0;
    padding: 1.5rem;
    background: var(--color-bg);
    border-radius: 12px;
    border: 1px solid var(--color-border);
  }

  .model-detail-view :global(.flow-diagram-hint) {
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    margin: 0 0 1rem 0;
  }

  .model-detail-view :global(.flow-diagram-inner) {
    position: relative;
    min-height: 120px;
    overflow: visible;
  }

  .model-detail-view :global(.flow-diagram-svg) {
    position: absolute;
    left: 0;
    top: 0;
    pointer-events: none;
    overflow: visible;
  }

  .model-detail-view :global(.flow-diagram-node) {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0.35rem 0.5rem;
    border: 1.5px solid var(--color-ink);
    border-radius: 8px;
    text-decoration: none;
    color: var(--color-ink);
    font-size: 0.8rem;
    line-height: 1.25;
    text-align: center;
    box-sizing: border-box;
    z-index: 1;
    background: #fff;
  }

  .model-detail-view :global(.flow-diagram-node:hover) {
    border-color: var(--color-gold);
    color: var(--color-ink);
    text-decoration: none;
  }

  .model-detail-view :global(.flow-diagram-node--social) {
    background: rgba(98, 33, 48, 0.12);
    border-color: var(--color-maroon-muted);
  }

  .model-detail-view :global(.flow-diagram-node--cognitive) {
    background: rgba(139, 112, 76, 0.15);
    border-color: var(--color-gold-dark);
  }

  .model-detail-view :global(.flow-diagram-node--neutral) {
    background: #fff;
  }

  .model-detail-view :global(.flow-diagram-node-abbrev) {
    font-weight: 700;
    font-size: 0.75rem;
    color: var(--color-maroon);
  }

  .model-detail-view :global(.flow-diagram-node-name) {
    font-weight: 500;
    font-size: 0.7rem;
    color: var(--color-ink);
    margin-top: 0.15rem;
    overflow: hidden;
