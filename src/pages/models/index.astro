---
import BaseLayout from '../../layouts/BaseLayout.astro';
import models from '../../data/models.json';
const base = import.meta.env.BASE_URL;

const thesisModelIds = new Set(['my-thesis-model', 'my-thesis-2']);
const keyModelIds = new Set(['utaut', 'ecm-is', 'tpc']);

const sortedModels = [...models].sort((a: any, b: any) =>
  String(a.name || '').localeCompare(String(b.name || ''), undefined, { sensitivity: 'base' })
);

const theoreticalModels = sortedModels.filter((model: any) => !thesisModelIds.has(model.id));
const thesisModels = sortedModels.filter((model: any) => thesisModelIds.has(model.id));

type TimelineModel = {
  id: string;
  abbreviation: string;
  year: number;
  authors?: string[];
};

const timelineModels = (theoreticalModels as TimelineModel[])
  .filter((model) => model.year != null && Number.isFinite(model.year))
  .sort(
    (a, b) =>
      a.year - b.year ||
      String(a.abbreviation || '').localeCompare(String(b.abbreviation || ''), undefined, {
        sensitivity: 'base',
      })
  );

const timelineByYear = timelineModels.reduce<Record<number, TimelineModel[]>>((acc, model) => {
  if (!acc[model.year]) acc[model.year] = [];
  acc[model.year].push(model);
  return acc;
}, {});

const timelineYears = Object.keys(timelineByYear)
  .map(Number)
  .sort((a, b) => a - b);

const modelComparison = [
  {
    id: 'tra',
    label: 'TRA',
    year: 1975,
    postAdoption: false,
    mandatoryUse: false,
    isSpecific: false,
    confirmation: false,
    parsimony: 4,
    dv: 'BI',
    fc: null,
  },
  {
    id: 'tpb',
    label: 'TPB',
    year: 1991,
    postAdoption: false,
    mandatoryUse: false,
    isSpecific: false,
    confirmation: false,
    parsimony: 5,
    dv: 'BI',
    fc: { label: 'PBC', constructId: 'perceived-behavioral-control' },
  },
  {
    id: 'tpc',
    label: 'TPC',
    year: 1995,
    postAdoption: true,
    mandatoryUse: true,
    isSpecific: true,
    confirmation: false,
    parsimony: 5,
    dv: 'U / PI',
    fc: { label: 'TTF', constructId: 'task-technology-fit' },
  },
  {
    id: 'utaut',
    label: 'UTAUT',
    year: 2003,
    postAdoption: true,
    mandatoryUse: true,
    isSpecific: true,
    confirmation: false,
    parsimony: 6,
    dv: 'UB',
    fc: { label: 'FC', constructId: 'facilitating-conditions' },
  },
  {
    id: 'ecm-is',
    label: 'ECM-IS',
    year: 2001,
    postAdoption: true,
    mandatoryUse: false,
    isSpecific: true,
    confirmation: true,
    parsimony: 6,
    dv: 'CI',
    fc: null,
  },
  {
    id: 'tam',
    label: 'TAM',
    year: 1989,
    postAdoption: false,
    mandatoryUse: false,
    isSpecific: true,
    confirmation: false,
    parsimony: 4,
    dv: 'BI',
    fc: { label: 'PEOU', constructId: 'perceived-ease-of-use' },
  },
  {
    id: 'tam3',
    label: 'TAM3',
    year: 2008,
    postAdoption: false,
    mandatoryUse: true,
    isSpecific: true,
    confirmation: false,
    parsimony: 17,
    dv: 'BI',
    fc: { label: 'PEC', constructId: 'facilitating-conditions' },
  },
  {
    id: 'utaut2',
    label: 'UTAUT2',
    year: 2012,
    postAdoption: true,
    mandatoryUse: false,
    isSpecific: true,
    confirmation: false,
    parsimony: 9,
    dv: 'UB',
    fc: { label: 'FC', constructId: 'facilitating-conditions' },
  },
  {
    id: 'tam2',
    label: 'TAM2',
    year: 2000,
    postAdoption: false,
    mandatoryUse: true,
    isSpecific: true,
    confirmation: false,
    parsimony: 11,
    dv: 'BI',
    fc: { label: 'PEOU', constructId: 'perceived-ease-of-use' },
  },
].sort((a, b) => b.year - a.year);
---

<BaseLayout title="Models" description="Theoretical models - TAM, ECT, ECM and more">
  <h1>Models</h1>
  <p class="page-desc">Theoretical models with diagrams, constructs, and citations. Click a card to open the model detail page.</p>

  {timelineYears.length > 0 && (
    <section class="models-timeline-section" aria-label="Models by year established">
      <h2 class="models-section-title">Timeline by year established</h2>
      <p class="models-timeline-desc">Abbreviations only — click a model to open its detail page. <span class="models-key-legend"><span class="models-key-star" aria-hidden="true">★</span> marks the models used in this thesis.</span></p>
      <div class="models-timeline-scroll">
        <ol class="models-timeline">
          {timelineYears.map((year) => (
            <li class="models-timeline-year">
              <div class="models-timeline-models">
                {timelineByYear[year].map((model) => (
                  <a
                    href={`${base}models/${model.id}/`}
                    class={`models-timeline-abbrev${keyModelIds.has(model.id) ? ' models-timeline-abbrev-key' : ''}`}
                    title={`${model.abbreviation}${model.authors?.length ? ` — ${model.authors.join(', ')}` : ''} (${year})${keyModelIds.has(model.id) ? ' — used in this thesis' : ''}`}
                  >
                    {keyModelIds.has(model.id) && <span class="models-timeline-abbrev-star" aria-hidden="true">★</span>}
                    {model.abbreviation}
                  </a>
                ))}
              </div>
              <div class="models-timeline-rail" aria-hidden="true">
                <span class="models-timeline-dot" />
              </div>
              <time class="models-timeline-year-label" datetime={String(year)}>{year}</time>
            </li>
          ))}
        </ol>
      </div>
    </section>
  )}

  <section class="models-comparison-section" aria-labelledby="models-comparison-title">
    <h2 id="models-comparison-title" class="models-section-title">Key model comparison</h2>
    <p class="models-comparison-desc">
      Post-adoption indicates explicit coverage of realized, continued, or performance-linked use.
      Mandatory use indicates suitability for organizational settings where use may be required.
      IS-specific distinguishes technology/IS models from general behavioral theories. DV shows each
      model's principal dependent variable. Confirmation identifies models that explicitly compare
      experience with prior expectations. Parsimony is shown as the number of core constructs. FC
      shows the construct closest to facilitating conditions.
    </p>
    <div class="models-comparison-scroll">
      <table class="models-comparison-table">
        <thead>
          <tr>
            <th scope="col">Model</th>
            <th scope="col">Year</th>
            <th scope="col">Post-adoption</th>
            <th scope="col">Mandatory use</th>
            <th scope="col">IS-specific</th>
            <th scope="col">Confirmation</th>
            <th scope="col"><abbr title="Number of core constructs">Parsimony</abbr></th>
            <th scope="col"><abbr title="Dependent variable">DV</abbr></th>
            <th scope="col"><abbr title="Facilitating conditions">FC</abbr></th>
          </tr>
        </thead>
        <tbody>
          {modelComparison.map((row) => (
            <tr>
              <th scope="row">
                <a href={`${base}models/${row.id}/`}>{row.label}</a>
              </th>
              <td class="comparison-year">{row.year}</td>
              <td class={row.postAdoption ? 'comparison-yes' : 'comparison-no'}>
                <span aria-hidden="true">{row.postAdoption ? '✓' : '×'}</span>
                <span class="sr-only">{row.postAdoption ? 'Yes' : 'No'}</span>
              </td>
              <td class={row.mandatoryUse ? 'comparison-yes' : 'comparison-no'}>
                <span aria-hidden="true">{row.mandatoryUse ? '✓' : '×'}</span>
                <span class="sr-only">{row.mandatoryUse ? 'Yes' : 'No'}</span>
              </td>
              <td class={row.isSpecific ? 'comparison-yes' : 'comparison-no'}>
                <span aria-hidden="true">{row.isSpecific ? '✓' : '×'}</span>
                <span class="sr-only">{row.isSpecific ? 'Yes' : 'No'}</span>
              </td>
              <td class={row.confirmation ? 'comparison-yes' : 'comparison-no'}>
                <span aria-hidden="true">{row.confirmation ? '✓' : '×'}</span>
                <span class="sr-only">{row.confirmation ? 'Yes' : 'No'}</span>
              </td>
              <td class="comparison-parsimony">{row.parsimony}</td>
              <td class="comparison-dv">{row.dv}</td>
              <td class={row.fc ? 'comparison-fc' : 'comparison-no'}>
                {row.fc ? (
                  <a
                    href={`${base}constructs/${row.fc.constructId}/`}
                    title={`Closest facilitating-conditions construct: ${row.fc.label}`}
                  >
                    {row.fc.label}
                  </a>
                ) : (
                  <>
                    <span aria-hidden="true">×</span>
                    <span class="sr-only">No close facilitating-conditions construct</span>
                  </>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="models-comparison-note">
      DV: BI = behavioral intention; CI = continuance intention; U = utilization; PI = performance
      impact; UB = use behavior. FC: PBC = perceived behavioral control; TTF = task–technology fit;
      FC = facilitating conditions; PEOU = perceived ease of use; PEC = perceptions of external control.
    </p>
  </section>

  <section class="models-section">
    <h2 class="models-section-title">Theoretical Models</h2>
    <div class="models-grid">
      {theoreticalModels.map((model: any) => (
        <article class={`model-card${keyModelIds.has(model.id) ? ' model-card-key' : ''}`}>
          {keyModelIds.has(model.id) && <span class="model-card-key-badge"><span aria-hidden="true">★</span> Used in this thesis</span>}
          <h3><a href={`${base}models/${model.id}/`}>{model.name}</a></h3>
          <span class="abbrev">{model.abbreviation}</span>
          <p class="model-meta">{(model.authors && model.authors.length > 0 ? model.authors.join(', ') : '—')}{(model.year != null ? ` (${model.year})` : '')}</p>
          <p class="model-desc-teaser">{model.description.slice(0, 160)}{model.description.length > 160 ? '…' : ''}</p>
          <div class="meta">
            <span>Constructs: {model.constructs.slice(0, 4).map((c: string) => model.constructAbbreviations?.[c] || c).join(', ')}{model.constructs.length > 4 ? '…' : ''}</span>
          </div>
        </article>
      ))}
    </div>
  </section>

  {thesisModels.length > 0 && (
    <section class="models-section models-section-thesis">
      <h2 class="models-section-title">Featured Thesis Models</h2>
      <div class="models-grid">
        {thesisModels.map((model: any) => (
          <article class="model-card model-card-thesis">
            <h3><a href={`${base}models/${model.id}/`}>{model.name}</a></h3>
            <span class="abbrev">{model.abbreviation}</span>
            <p class="model-meta">{(model.authors && model.authors.length > 0 ? model.authors.join(', ') : '—')}{(model.year != null ? ` (${model.year})` : '')}</p>
            <p class="model-desc-teaser">{model.description.slice(0, 160)}{model.description.length > 160 ? '…' : ''}</p>
            <div class="meta">
              <span>Constructs: {model.constructs.slice(0, 4).map((c: string) => model.constructAbbreviations?.[c] || c).join(', ')}{model.constructs.length > 4 ? '…' : ''}</span>
            </div>
          </article>
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .page-desc { color: var(--color-ink-muted); margin-bottom: 2rem; }

  .models-timeline-section {
    margin: 0 0 2.5rem 0;
    padding: 1.25rem 1.35rem 1.5rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 12px;
  }

  .models-timeline-desc {
    margin: -0.35rem 0 1.15rem 0;
    font-size: 0.875rem;
    color: var(--color-ink-muted);
  }

  .models-key-legend {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .models-key-star {
    color: var(--color-gold, #c8a13a);
    font-size: 0.95rem;
    line-height: 1;
  }

  .models-timeline-scroll {
    overflow-x: auto;
    padding-bottom: 0.35rem;
    -webkit-overflow-scrolling: touch;
  }

  .models-timeline {
    list-style: none;
    margin: 0;
    padding: 0.25rem 0.25rem 0;
    display: flex;
    align-items: flex-end;
    gap: 0;
    min-width: max-content;
  }

  .models-timeline-year {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 4.75rem;
    position: relative;
  }

  .models-timeline-models {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 0.75rem;
    min-height: 2rem;
  }

  .models-timeline-abbrev {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.28rem 0.55rem;
    border-radius: 999px;
    background: #fff;
    border: 1.5px solid var(--color-maroon);
    color: var(--color-maroon);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-decoration: none;
    line-height: 1.2;
    white-space: nowrap;
    transition: background 0.15s, color 0.15s, transform 0.15s;
  }

  .models-timeline-abbrev:hover {
    background: var(--color-maroon);
    color: #fff;
    text-decoration: none;
    transform: translateY(-1px);
  }

  .models-timeline-abbrev-key {
    background: var(--color-gold, #c8a13a);
    border-color: var(--color-gold, #c8a13a);
    color: #3a2c00;
    box-shadow: 0 0 0 3px rgba(200, 161, 58, 0.22);
  }

  .models-timeline-abbrev-key:hover {
    background: #b8901f;
    border-color: #b8901f;
    color: #fff;
  }

  .models-timeline-abbrev-star {
    margin-right: 0.28rem;
    font-size: 0.72rem;
    line-height: 1;
  }

  .models-timeline-rail {
    position: relative;
    width: 100%;
    height: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .models-timeline-rail::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 2px;
    background: var(--color-maroon-muted, #c4a4ad);
    transform: translateY(-50%);
  }

  .models-timeline-year:first-child .models-timeline-rail::before {
    left: 50%;
  }

  .models-timeline-year:last-child .models-timeline-rail::before {
    right: 50%;
  }

  .models-timeline-dot {
    position: relative;
    z-index: 1;
    width: 0.65rem;
    height: 0.65rem;
    border-radius: 50%;
    background: var(--color-maroon);
    border: 2px solid #fff;
    box-shadow: 0 0 0 1px var(--color-maroon-muted, #c4a4ad);
  }

  .models-timeline-year-label {
    margin-top: 0.45rem;
    font-size: 0.78rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    color: var(--color-ink-muted);
  }

  .models-section + .models-section {
    margin-top: 2.25rem;
  }

  .models-comparison-section {
    margin: 0 0 2.5rem;
  }

  .models-comparison-desc {
    max-width: 58rem;
    margin: -0.35rem 0 1rem;
    color: var(--color-ink-muted);
    font-size: 0.875rem;
    line-height: 1.55;
  }

  .models-comparison-scroll {
    overflow-x: auto;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: #fff;
    -webkit-overflow-scrolling: touch;
  }

  .models-comparison-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
    table-layout: fixed;
  }

  .models-comparison-table th,
  .models-comparison-table td {
    padding: 0.6rem 0.4rem;
    border-bottom: 1px solid var(--color-border);
    text-align: center;
    vertical-align: middle;
  }

  .models-comparison-table th:first-child {
    text-align: left;
    padding-left: 0.85rem;
    width: 4.5rem;
  }

  .models-comparison-table thead th {
    background: var(--color-bg-alt);
    color: var(--color-ink);
    font-size: 0.68rem;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    overflow-wrap: anywhere;
    hyphens: auto;
  }

  .models-comparison-table tbody tr:last-child th,
  .models-comparison-table tbody tr:last-child td {
    border-bottom: 0;
  }

  .models-comparison-table tbody tr:hover {
    background: rgba(92, 29, 42, 0.035);
  }

  .comparison-yes {
    color: #15803d;
    font-size: 1.15rem;
    font-weight: 800;
  }

  .comparison-year {
    color: var(--color-ink-muted);
    font-variant-numeric: tabular-nums;
  }

  .comparison-dv {
    color: var(--color-maroon);
    font-size: 0.82rem;
    font-weight: 750;
    white-space: nowrap;
  }

  .comparison-parsimony {
    color: var(--color-ink);
    font-size: 0.95rem;
    font-weight: 750;
    font-variant-numeric: tabular-nums;
  }

  .comparison-no {
    color: #dc2626;
    font-size: 1.1rem;
    font-weight: 700;
  }

  .comparison-fc a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 3rem;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    background: rgba(92, 29, 42, 0.08);
    color: var(--color-maroon);
    font-size: 0.78rem;
    font-weight: 750;
    text-decoration: none;
  }

  .comparison-fc a:hover {
    background: var(--color-maroon);
    color: #fff;
  }

  .models-comparison-note {
    margin: 0.7rem 0 0;
    color: var(--color-ink-muted);
    font-size: 0.8rem;
    line-height: 1.5;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .models-section-title {
    margin: 0 0 1rem 0;
    font-size: 1.25rem;
  }

  .models-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .model-card {
    padding: 1.5rem;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    position: relative;
  }

  .model-card-key {
    border-color: var(--color-gold, #c8a13a);
    border-width: 2px;
    background: linear-gradient(180deg, rgba(200, 161, 58, 0.08), rgba(200, 161, 58, 0) 55%);
    box-shadow: 0 2px 10px rgba(200, 161, 58, 0.18);
  }

  .model-card-key-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    margin-bottom: 0.6rem;
    padding: 0.2rem 0.6rem;
    background: var(--color-gold, #c8a13a);
    color: #3a2c00;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    border-radius: 999px;
  }

  .model-card h3 { margin-top: 0; font-size: 1.25rem; }
  .model-card .abbrev {
    display: inline-block;
    margin-left: 0.5rem;
    padding: 0.15rem 0.5rem;
    background: var(--color-bg-alt);
    font-size: 0.8rem;
    font-weight: 600;
    border-radius: 4px;
  }
  .model-meta { font-size: 0.875rem; color: var(--color-ink-muted); margin: 0.5rem 0; }
  .model-desc-teaser { font-size: 0.9rem; margin: 0.75rem 0; line-height: 1.5; }
  .model-card .meta { font-size: 0.85rem; margin-top: 0.5rem; color: var(--color-ink-muted); }

  .models-section-thesis .models-section-title {
    color: var(--color-maroon);
  }

  .model-card-thesis {
    border-color: var(--color-maroon-muted);
    background: var(--color-bg-alt);
  }
</style>
