---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PapersPage from '../../components/PapersPage';
---

<BaseLayout title="Papers" description="Save paper links with motivation and tags">
  <h1>Papers</h1>
  <p class="page-desc">Save interesting papers with a link and why you kept them. Tag them for later.</p>

  <PapersPage client:visible />
</BaseLayout>

<style>
  .page-desc {
    color: var(--color-ink-muted);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  /* Papers form & list (React) – use :global so styles apply */
  :global(.papers-page .papers-add-section) {
    margin-bottom: 2.5rem;
  }
  :global(.papers-page .papers-add-header) {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }
  :global(.papers-page .papers-add-btn) {
    padding: 0.55rem 1.2rem;
    background: var(--color-maroon);
    color: #fff;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    font-size: 0.9rem;
    transition: background 0.2s;
  }
  :global(.papers-page .papers-add-btn:hover) {
    background: var(--color-maroon-dark);
  }
  :global(.papers-page .papers-form) {
    max-width: 960px;
    padding: 2.5rem 3rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    border-left: 4px solid var(--color-maroon);
    box-shadow: var(--shadow-sm);
  }
  :global(.papers-page .papers-form-title) {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    color: var(--color-ink);
    margin: 0 0 0.5rem 0;
  }
  :global(.papers-page .papers-form-hint) {
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    margin-bottom: 2.5rem;
  }
  :global(.papers-page .papers-url-row) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }
  :global(.papers-page .papers-url-row .papers-input) {
    flex: 1;
    min-width: 200px;
  }
  :global(.papers-page .papers-fetch-btn) {
    flex-shrink: 0;
    padding: 0.65rem 1.25rem;
    background: var(--color-bg-alt);
    border: 2px solid var(--color-maroon);
    color: var(--color-maroon);
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }
  :global(.papers-page .papers-fetch-btn:hover:not(:disabled)) {
    background: var(--color-maroon);
    color: #fff;
  }
  :global(.papers-page .papers-fetch-btn:disabled) {
    opacity: 0.6;
    cursor: not-allowed;
  }
  :global(.papers-page .papers-field-hint) {
    font-size: 0.8rem;
    color: var(--color-ink-muted);
    margin-top: 0.25rem;
  }
  :global(.papers-page .papers-form-field-row) {
    flex-direction: row;
    flex-wrap: wrap;
    gap: 1.5rem;
  }
  :global(.papers-page .papers-form-field-row > div) {
    flex: 1;
    min-width: 180px;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  :global(.papers-page .papers-input-short) {
    max-width: 6rem;
  }
  :global(.papers-page .papers-form-field) {
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  :global(.papers-page .papers-form-field-motivation) {
    margin-bottom: 3.5rem;
    gap: 1.25rem;
  }
  :global(.papers-page .papers-form-field-motivation label) {
    display: block;
    margin-bottom: 0;
    flex-shrink: 0;
  }
  :global(.papers-page .papers-form-field label),
  :global(.papers-page .papers-form-label) {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-ink);
  }
  :global(.papers-page .papers-form-field-inline) {
    margin-bottom: 1.25rem;
  }
  :global(.papers-page .papers-checkbox-label) {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.9rem;
    color: var(--color-ink);
    cursor: pointer;
  }
  :global(.papers-page .papers-checkbox-label input[type='checkbox']) {
    width: 1rem;
    height: 1rem;
  }
  :global(.papers-page .papers-input),
  :global(.papers-page .papers-textarea) {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 2px solid var(--color-border);
    border-radius: 8px;
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-ink);
    background: #fff;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }
  :global(.papers-page .papers-input:focus),
  :global(.papers-page .papers-textarea:focus) {
    outline: none;
    border-color: var(--color-maroon);
    box-shadow: 0 0 0 3px rgba(113, 32, 56, 0.12);
  }
  :global(.papers-page .papers-textarea) {
    min-height: 140px;
    resize: vertical;
    line-height: 1.6;
  }
  :global(.papers-page .papers-tag-chips) {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  :global(.papers-page .papers-tag-chip) {
    padding: 0.65rem 1.35rem;
    border: 2px solid var(--color-border);
    background: var(--color-bg-alt);
    border-radius: 999px;
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-ink);
    transition: border-color 0.2s, background 0.2s, color 0.2s;
  }
  :global(.papers-page .papers-tag-chip:hover) {
    border-color: var(--color-maroon-muted);
    background: rgba(113, 32, 56, 0.06);
  }
  :global(.papers-page .papers-tag-chip.selected) {
    background: var(--color-maroon);
    color: #fff;
    border-color: var(--color-maroon);
  }
  :global(.papers-page .papers-submit) {
    margin-top: 1.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--color-maroon);
    color: #fff;
    border: 2px solid var(--color-gold);
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    font-size: 1rem;
    transition: background 0.2s, border-color 0.2s;
  }
  :global(.papers-page .papers-submit:hover:not(:disabled)) {
    background: var(--color-maroon-dark);
    border-color: var(--color-gold-light);
  }
  :global(.papers-page .papers-submit:disabled) {
    opacity: 0.7;
    cursor: not-allowed;
  }
  :global(.papers-page .papers-history-section) {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
  :global(.papers-page .papers-history-title) {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--color-border);
    color: var(--color-ink);
  }
  :global(.papers-page .papers-filters) {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  :global(.papers-page .papers-search) {
    flex: 1;
    min-width: 200px;
    padding: 0.65rem 1rem;
    border: 2px solid var(--color-border);
    border-radius: 8px;
    font-size: 0.95rem;
  }
  :global(.papers-page .papers-search:focus) {
    outline: none;
    border-color: var(--color-maroon);
  }
  :global(.papers-page .papers-select) {
    padding: 0.65rem 1rem;
    border: 2px solid var(--color-border);
    border-radius: 8px;
    font-size: 0.95rem;
  }
  :global(.papers-page .papers-sort-toggle) {
    padding: 0.45rem 0.75rem;
    border-radius: 8px;
    border: 2px solid var(--color-border);
    background: var(--color-bg-alt);
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
  }
  :global(.papers-page .papers-sort-toggle:hover) {
    border-color: var(--color-maroon-muted);
    background: rgba(113, 32, 56, 0.06);
  }
  :global(.papers-page .papers-sort-panel) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    font-size: 0.9rem;
  }
  :global(.papers-page .papers-sort-panel label) {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  :global(.papers-page .papers-sort-label) {
    font-weight: 600;
    color: var(--color-ink);
  }
  :global(.papers-page .papers-sort-direction-btn) {
    padding: 0.45rem 0.9rem;
    border-radius: 8px;
    border: 2px solid var(--color-border);
    background: var(--color-bg-alt);
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
  }
  :global(.papers-page .papers-sort-direction-btn:hover) {
    border-color: var(--color-maroon-muted);
    background: rgba(113, 32, 56, 0.06);
  }
  :global(.papers-page .papers-pagination) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1rem;
    padding: 0.5rem 0;
  }
  :global(.papers-page .papers-pagination-info) {
    font-size: 0.9rem;
    color: var(--color-ink-muted);
  }
  :global(.papers-page .papers-pagination-buttons) {
    display: flex;
    gap: 0.5rem;
  }
  :global(.papers-page .papers-pagination-btn) {
    padding: 0.4rem 0.85rem;
    font-size: 0.9rem;
    font-weight: 600;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: #fff;
    color: var(--color-ink);
    cursor: pointer;
  }
  :global(.papers-page .papers-pagination-btn:hover:not(:disabled)) {
    border-color: var(--color-maroon-muted);
    background: rgba(113, 32, 56, 0.06);
  }
  :global(.papers-page .papers-pagination-btn:disabled) {
    opacity: 0.5;
    cursor: not-allowed;
  }
  :global(.papers-page .papers-entries) {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  :global(.papers-page .papers-entry) {
    padding: 1.5rem 1.75rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    box-shadow: var(--shadow-sm);
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  :global(.papers-page .papers-entry-golden) {
    border-color: var(--color-gold);
    box-shadow: 0 0 0 2px rgba(212, 175, 55, 0.5);
  }
  :global(.papers-page .papers-entry:hover) {
    border-color: var(--color-maroon-muted);
    box-shadow: var(--shadow-md);
  }
  :global(.papers-page .papers-entry-header) {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  :global(.papers-page .papers-entry-header-left) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }
  :global(.papers-page .papers-entry-actions) {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }
  :global(.papers-page .papers-entry-action) {
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    border: 1px solid var(--color-border);
    background: #fff;
    color: var(--color-ink);
    transition: border-color 0.2s, background 0.2s;
  }
  :global(.papers-page .papers-entry-action:hover:not(:disabled)) {
    border-color: var(--color-maroon-muted);
    background: rgba(113, 32, 56, 0.06);
  }
  :global(.papers-page .papers-entry-action.papers-entry-delete:hover:not(:disabled)) {
    border-color: var(--color-maroon);
    background: rgba(113, 32, 56, 0.1);
    color: var(--color-maroon);
  }
  :global(.papers-page .papers-entry-action:disabled) {
    opacity: 0.6;
    cursor: not-allowed;
  }
  :global(.papers-page .papers-entry-edit-form) {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  :global(.papers-page .papers-entry-edit-form .papers-form-field) {
    margin-bottom: 0;
  }
  :global(.papers-page .papers-entry-edit-actions) {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }
  :global(.papers-page .papers-btn) {
    padding: 0.5rem 1rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    border: 2px solid transparent;
    transition: background 0.2s, border-color 0.2s;
  }
  :global(.papers-page .papers-btn-primary) {
    background: var(--color-maroon);
    color: #fff;
    border-color: var(--color-gold);
  }
  :global(.papers-page .papers-btn-primary:hover:not(:disabled)) {
    background: var(--color-maroon-dark);
    border-color: var(--color-gold-light);
  }
  :global(.papers-page .papers-btn-secondary) {
    background: var(--color-bg-alt);
    color: var(--color-ink);
    border-color: var(--color-border);
  }
  :global(.papers-page .papers-btn-secondary:hover) {
    border-color: var(--color-maroon-muted);
  }
  :global(.papers-page .papers-btn:disabled) {
    opacity: 0.7;
    cursor: not-allowed;
  }
  :global(.papers-page .papers-entry-header time) {
    font-size: 0.9rem;
    color: var(--color-ink-muted);
  }
  :global(.papers-page .papers-entry-year) {
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    font-weight: 600;
  }
  :global(.papers-page .papers-entry-citations) {
    font-size: 0.9rem;
    color: var(--color-ink-muted);
  }
  :global(.papers-page .papers-summary-badge) {
    display: inline-block;
    padding: 0.2rem 0.55rem;
    font-size: 0.74rem;
    font-weight: 700;
    border-radius: 999px;
    background: #ecfdf3;
    border: 1px solid #4ade80;
    color: #166534;
    line-height: 1;
    letter-spacing: 0.01em;
  }
  :global(.papers-page .papers-summary-badge.papers-summary-badge-board) {
    font-size: 0.7rem;
    padding: 0.15rem 0.45rem;
  }
  :global(.papers-page .papers-snippet-count) {
    display: inline-block;
    padding: 0.2rem 0.55rem;
    font-size: 0.74rem;
    font-weight: 600;
    border-radius: 999px;
    background: rgba(113, 32, 56, 0.08);
    border: 1px solid rgba(113, 32, 56, 0.22);
    color: var(--color-ink);
    line-height: 1;
    letter-spacing: 0.01em;
  }
  :global(.papers-page .papers-snippet-count.papers-snippet-count-zero) {
    opacity: 0.55;
    font-weight: 500;
  }
  :global(.papers-page .papers-snippet-count-board) {
    font-size: 0.7rem;
    padding: 0.15rem 0.45rem;
  }
  :global(.papers-page .papers-entry-tags) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  :global(.papers-page .papers-tag-badge) {
    padding: 0.25rem 0.6rem;
    background: var(--color-bg-alt);
    font-size: 0.75rem;
    border-radius: 6px;
    color: var(--color-ink-muted);
    border: 1px solid var(--color-border);
  }
  :global(.papers-page .papers-entry-title) {
    margin: 0.5rem 0 0.25rem 0;
    font-size: 1.1rem;
    line-height: 1.4;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
  }
  :global(.papers-page .papers-entry-title a:first-of-type) {
    color: var(--color-maroon);
    text-decoration: none;
  }
  :global(.papers-page .papers-entry-title a:first-of-type:hover) {
    text-decoration: underline;
  }
  :global(.papers-page .papers-entry-clickable) {
    cursor: pointer;
  }
  :global(.papers-page .papers-entry-secondary-link) {
    margin: 0.1rem 0 0.4rem 0;
    font-size: 0.85rem;
  }
  :global(.papers-page .papers-entry-secondary-link a) {
    color: var(--color-ink-muted);
    text-decoration: underline;
  }
  :global(.papers-page .papers-entry-authors) {
    margin: 0.25rem 0 0.5rem 0;
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    line-height: 1.4;
  }
  :global(.papers-page .papers-entry-journal) {
    margin: 0.15rem 0 0.5rem 0;
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    font-style: italic;
    line-height: 1.4;
  }
  :global(.papers-page .papers-entry-url-fallback) {
    margin: 0.25rem 0 0.5rem 0;
    font-size: 0.85rem;
  }
  :global(.papers-page .papers-entry-url-fallback a) {
    color: var(--color-maroon);
  }
  :global(.papers-page .papers-entry-motivation) {
    margin: 0.5rem 0 0;
    color: var(--color-ink-muted);
    line-height: 1.6;
  }
  :global(.papers-page .papers-entry-comments) {
    margin-top: 0.85rem;
    padding-top: 0.75rem;
    border-top: 1px dashed var(--color-border);
  }
  :global(.papers-page .papers-entry-comments-title) {
    margin: 0 0 0.45rem 0;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-ink-muted);
  }
  :global(.papers-page .papers-entry-comments-empty) {
    margin: 0 0 0.6rem 0;
    font-size: 0.85rem;
    color: var(--color-ink-muted);
  }
  :global(.papers-page .papers-entry-comments-list) {
    margin: 0 0 0.65rem 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  :global(.papers-page .papers-entry-comment-item) {
    padding: 0.45rem 0.6rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: #fafafa;
  }
  :global(.papers-page .papers-entry-comment-content) {
    margin: 0 0 0.25rem 0;
    font-size: 0.87rem;
    color: var(--color-ink);
    line-height: 1.45;
    white-space: pre-wrap;
  }
  :global(.papers-page .papers-entry-comment-time) {
    font-size: 0.75rem;
    color: var(--color-ink-muted);
  }
  :global(.papers-page .papers-entry-comment-form) {
    display: flex;
    gap: 0.5rem;
    align-items: flex-end;
  }
  :global(.papers-page .papers-entry-comment-input) {
    flex: 1;
    min-height: 2.5rem;
    resize: vertical;
    padding: 0.5rem 0.65rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    line-height: 1.4;
    background: #fff;
  }
  :global(.papers-page .papers-entry-comment-input:focus) {
    outline: none;
    border-color: var(--color-maroon);
    box-shadow: 0 0 0 2px rgba(113, 32, 56, 0.12);
  }
  :global(.papers-page .papers-entry-comment-add) {
    padding: 0.45rem 0.75rem;
    border-radius: 6px;
    border: 1px solid var(--color-border);
    background: #fff;
    color: var(--color-ink);
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
  }
  :global(.papers-page .papers-entry-comment-add:hover:not(:disabled)) {
    border-color: var(--color-maroon-muted);
    background: rgba(113, 32, 56, 0.06);
  }
  :global(.papers-page .papers-entry-comment-add:disabled) {
    opacity: 0.55;
    cursor: not-allowed;
  }
  :global(.papers-page .papers-empty) {
    color: var(--color-ink-muted);
    padding: 2.5rem;
    text-align: center;
    font-size: 0.95rem;
  }
  :global(.papers-page .papers-entry-count) {
    font-weight: 400;
    color: var(--color-ink-muted);
    font-size: 0.95rem;
  }
  :global(.papers-page .papers-setup) {
    max-width: 480px;
    padding: 2rem 2.5rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    border-left: 4px solid var(--color-gold);
  }
  :global(.papers-page .papers-setup-hint) {
    font-size: 0.9rem;
    margin-top: 1rem;
    color: var(--color-ink-muted);
  }
  :global(.papers-page .papers-setup code),
  :global(.papers-page .papers-setup-hint code) {
    background: var(--color-bg-alt);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-size: 0.85rem;
  }
  :global(.papers-page .papers-loading) {
    padding: 2.5rem;
    color: var(--color-ink-muted);
    text-align: center;
  }
  :global(.papers-page .papers-error) {
    color: var(--color-maroon);
    font-size: 0.95rem;
    margin-bottom: 1.25rem;
    padding: 1rem 1.25rem;
    background: rgba(113, 32, 56, 0.08);
    border-radius: 8px;
    border-left: 4px solid var(--color-maroon);
  }

  /* Status guide */
  :global(.papers-page .papers-status-guide-section) {
    margin-bottom: 1.5rem;
  }
  :global(.papers-page .papers-status-guide-toggle) {
    padding: 0.5rem 0.75rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-maroon);
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }
  :global(.papers-page .papers-status-guide-toggle:hover) {
    background: var(--color-bg-alt);
    border-color: var(--color-maroon-muted);
  }
  :global(.papers-page .papers-status-guide) {
    margin-top: 0.75rem;
    padding: 1.25rem 1.5rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 10px;
  }
  :global(.papers-page .papers-status-guide-intro) {
    margin: 0 0 0.75rem 0;
    font-size: 0.9rem;
    color: var(--color-ink-muted);
  }
