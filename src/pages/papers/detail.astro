---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PaperDetailPage from '../../components/PaperDetailPage';
---

<BaseLayout title="Paper details" description="View paper metadata and generate APA 7 reference">
  <PaperDetailPage client:load />
</BaseLayout>

<style>
  :global(.paper-detail-page) {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1rem 3rem;
  }
  :global(.paper-detail-back) {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--color-maroon);
    text-decoration: none;
    font-weight: 500;
  }
  :global(.paper-detail-back:hover) {
    text-decoration: underline;
  }
  :global(.paper-detail-loading),
  :global(.paper-detail-error) {
    color: var(--color-ink-muted);
    margin: 2rem 0;
  }
  :global(.paper-detail-error) {
    color: var(--color-error, #b91c1c);
  }
  :global(.paper-detail-header) {
    margin-bottom: 2rem;
  }
  :global(.paper-detail-title) {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    line-height: 1.3;
    margin: 0 0 0.5rem 0;
    color: var(--color-ink);
  }
  :global(.paper-detail-authors) {
    margin: 0 0 0.75rem 0;
    color: var(--color-ink-muted);
    font-size: 1rem;
  }
  :global(.paper-detail-meta-row) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    align-items: center;
  }
  :global(.paper-detail-year) {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    background: var(--color-bg-alt);
    border-radius: 6px;
    font-size: 0.9rem;
  }
  :global(.paper-detail-status) {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 6px;
    font-size: 0.85rem;
  }
  :global(.paper-detail-status-not-read) { background: #e2e8f0; color: #475569; }
  :global(.paper-detail-status-1st-reading) { background: #dbeafe; color: #1e40af; }
  :global(.paper-detail-status-2nd-reading) { background: #e0e7ff; color: #3730a3; }
  :global(.paper-detail-status-read) { background: #fef9c3; color: #854d0e; }
  :global(.paper-detail-status-completed) { background: #dcfce7; color: #166534; }
  :global(.paper-detail-status-archive) { background: #f3e8ff; color: #6b21a8; }
  :global(.paper-detail-golden) {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    background: linear-gradient(135deg, #fef3c7, #fde68a);
    color: #92400e;
    border-radius: 6px;
    font-size: 0.85rem;
  }
  :global(.paper-detail-section) {
    margin-bottom: 1.75rem;
  }
  :global(.paper-detail-section-title) {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 0.5rem 0;
  }
  :global(.paper-detail-link) {
    color: var(--color-maroon);
    text-decoration: none;
  }
  :global(.paper-detail-link:hover) {
    text-decoration: underline;
  }
  :global(.paper-detail-motivation) {
    margin: 0;
    color: var(--color-ink-muted);
    line-height: 1.6;
  }
  :global(.paper-detail-tags) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  :global(.paper-detail-tag) {
    padding: 0.25rem 0.6rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-size: 0.875rem;
  }
  :global(.paper-detail-citations) {
    margin: 0;
    font-size: 1rem;
  }
  :global(.paper-detail-apa-section) {
    margin-top: 2rem;
    padding: 1.25rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 12px;
  }
  :global(.paper-detail-apa-hint) {
    margin: 0 0 0.75rem 0;
    font-size: 0.9rem;
    color: var(--color-ink-muted);
  }
  :global(.paper-detail-apa-box) {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  :global(.paper-detail-apa-output) {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    line-height: 1.5;
    padding: 1rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    white-space: pre-wrap;
    word-break: break-word;
  }
  :global(.paper-detail-apa-copy) {
    align-self: flex-start;
    padding: 0.5rem 1rem;
    background: var(--color-maroon);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-weight: 500;
    cursor: pointer;
  }
  :global(.paper-detail-apa-copy:hover) {
    background: var(--color-maroon-dark);
  }
  :global(.paper-detail-created) {
    margin-top: 2rem;
    font-size: 0.875rem;
    color: var(--color-ink-muted);
  }
  :global(.paper-detail-summary) {
    padding: 1.25rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 12px;
  }
  :global(.paper-detail-summary-header) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  :global(.paper-detail-summary-header-actions) {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: center;
  }
  :global(.paper-detail-summary-loading),
  :global(.paper-detail-summary-empty),
  :global(.paper-detail-summary-generating) {
    margin: 0 0 0.75rem 0;
    font-size: 0.9rem;
    color: var(--color-ink-muted);
  }
  :global(.paper-detail-summary-error) {
    margin: 0 0 0.75rem 0;
    font-size: 0.9rem;
    color: var(--color-error, #b91c1c);
  }
  :global(.paper-detail-summary-btn) {
    padding: 0.5rem 1rem;
    background: var(--color-maroon);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-weight: 500;
    cursor: pointer;
  }
  :global(.paper-detail-summary-btn.paper-detail-summary-btn-secondary) {
    background: #fff;
    color: var(--color-maroon);
    border: 1px solid var(--color-border);
  }
  :global(.paper-detail-summary-btn:hover:not(:disabled)) {
    opacity: 0.9;
  }
  :global(.paper-detail-summary-btn:disabled) {
    opacity: 0.6;
    cursor: not-allowed;
  }
  :global(.paper-detail-summary-editor) {
    padding: 1rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    margin-bottom: 0.75rem;
  }
  :global(.paper-detail-summary-label) {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    margin-bottom: 0.75rem;
  }
  :global(.paper-detail-summary-textarea) {
    width: 100%;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    padding: 0.6rem 0.7rem;
    font-size: 0.9rem;
    resize: vertical;
    background: #fff;
    color: var(--color-ink);
  }
  :global(.paper-detail-summary-editor-actions) {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }
  :global(.paper-detail-summary-fields) {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  :global(.paper-detail-summary-grid) {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  :global(.paper-detail-summary-block) {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  :global(.paper-detail-summary-block:last-child) {
    border-bottom: none;
  }
  :global(.paper-detail-summary-heading) {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-maroon);
    margin: 0 0 0.35rem 0;
  }
  :global(.paper-detail-summary-text) {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--color-ink);
    word-break: break-word;
  }
  :global(.paper-detail-summary-rich) {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  :global(.paper-detail-summary-paragraph) {
    margin: 0;
  }
  :global(.paper-detail-summary-list) {
    margin: 0;
    padding-left: 1.25rem;
  }
  :global(.paper-detail-summary-list li) {
    margin: 0.1rem 0;
  }
  :global(.paper-detail-snippets) {
    margin-top: 2rem;
  }
  :global(.paper-detail-snippets-hint) {
    margin: 0 0 0.75rem 0;
    font-size: 0.9rem;
    color: var(--color-ink-muted);
  }
  :global(.paper-detail-snippet-form) {
    padding: 1rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    margin-bottom: 1.25rem;
  }
  :global(.paper-detail-snippet-label) {
    display: block;
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 0.5rem;
    color: var(--color-ink);
  }
  :global(.paper-detail-snippet-input) {
    margin-top: 0.25rem;
    width: 100%;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    padding: 0.6rem 0.7rem;
    font-size: 0.9rem;
    resize: vertical;
  }
  :global(.paper-detail-snippet-meta-row) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.75rem;
    margin-bottom: 0.75rem;
  }
  :global(.paper-detail-snippet-label-inline) {
    display: flex;
    flex-direction: column;
    font-size: 0.85rem;
    gap: 0.25rem;
  }
  :global(.paper-detail-snippet-input-inline) {
    border-radius: 6px;
    border: 1px solid var(--color-border);
    padding: 0.4rem 0.6rem;
    font-size: 0.85rem;
  }
  :global(.paper-detail-snippet-add) {
    margin-top: 0.25rem;
    padding: 0.5rem 1rem;
    background: var(--color-maroon);
    color: #fff;
    border-radius: 8px;
    border: none;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
  }
  :global(.paper-detail-snippet-add:disabled) {
    opacity: 0.6;
    cursor: default;
  }
  :global(.paper-detail-snippet-error) {
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: var(--color-error, #b91c1c);
  }
  :global(.paper-detail-snippet-list) {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  :global(.paper-detail-snippet-empty) {
    font-size: 0.9rem;
    color: var(--color-ink-muted);
  }
  :global(.paper-detail-snippet-card) {
    padding: 0.9rem 1rem;
    background: #fff;
    border-radius: 10px;
    border: 1px solid var(--color-border);
  }
  :global(.paper-detail-snippet-content) {
    margin: 0 0 0.5rem 0;
    font-size: 0.9rem;
    line-height: 1.5;
  }
  :global(.paper-detail-snippet-links) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 0.4rem;
  }
  :global(.paper-detail-snippet-tags) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 0.4rem;
  }
  :global(.paper-detail-snippet-chip) {
    display: inline-block;
    font-size: 0.8rem;
    padding: 0.15rem 0.6rem;
    border-radius: 999px;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    color: var(--color-maroon);
    text-decoration: none;
  }
  :global(.paper-detail-snippet-chip:hover) {
    text-decoration: underline;
  }
  :global(.paper-detail-snippet-tag) {
    display: inline-block;
    font-size: 0.8rem;
    padding: 0.15rem 0.6rem;
    border-radius: 999px;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
  }
  :global(.paper-detail-snippet-meta) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1rem;
    margin-bottom: 0.5rem;
  }
  :global(.paper-detail-snippet-page) {
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    font-weight: 500;
  }
  :global(.paper-detail-snippet-page-input) {
    width: 4.5rem;
  }
  :global(.paper-detail-snippet-footer) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 0.35rem;
  }
  :global(.paper-detail-snippet-date) {
    font-size: 0.8rem;
    color: var(--color-ink-muted);
  }
  :global(.paper-detail-snippet-delete) {
    font-size: 0.8rem;
    border: none;
    background: transparent;
    color: var(--color-error, #b91c1c);
    cursor: pointer;
  }
</style>
