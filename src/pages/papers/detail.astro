---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PaperDetailPage from '../../components/PaperDetailPage';
---

<BaseLayout title="Paper details" description="View paper metadata and generate APA 7 reference">
  <PaperDetailPage client:load />
</BaseLayout>

<style>
  :global(.paper-detail-page) {
    max-width: min(1180px, calc(100vw - 2rem));
    margin: 0 auto;
    padding: 0 1rem 3rem;
  }
  :global(.paper-detail-back) {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--color-maroon);
    text-decoration: none;
    font-weight: 500;
  }
  :global(.paper-detail-back:hover) {
    text-decoration: underline;
  }
  :global(.paper-detail-loading),
  :global(.paper-detail-error) {
    color: var(--color-ink-muted);
    margin: 2rem 0;
  }
  :global(.paper-detail-error) {
    color: var(--color-error, #b91c1c);
  }
  :global(.paper-detail-offline-banner) {
    padding: 0.75rem 1rem;
    margin-bottom: 1.25rem;
    background: #ecfdf5;
    color: #065f46;
    border-radius: 8px;
    font-size: 0.9rem;
    line-height: 1.5;
  }
  :global(.paper-detail-offline-save-message) {
    padding: 0.65rem 0.9rem;
    margin: 0 0 1rem 0;
    background: #ecfdf5;
    color: #065f46;
    border-radius: 8px;
    font-size: 0.875rem;
    line-height: 1.45;
  }
  :global(.paper-detail-header) {
    margin-bottom: 2rem;
  }
  :global(.paper-detail-title) {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    line-height: 1.3;
    margin: 0 0 0.5rem 0;
    color: var(--color-ink);
  }
  :global(.paper-detail-authors) {
    margin: 0 0 0.75rem 0;
    color: var(--color-ink-muted);
    font-size: 1rem;
  }
  :global(.paper-detail-meta-row) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    align-items: center;
  }
  :global(.paper-detail-year) {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    background: var(--color-bg-alt);
    border-radius: 6px;
    font-size: 0.9rem;
  }
  :global(.paper-detail-golden) {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    background: linear-gradient(135deg, #fef3c7, #fde68a);
    color: #92400e;
    border-radius: 6px;
    font-size: 0.85rem;
  }
  :global(.paper-detail-section) {
    margin-bottom: 1.75rem;
  }
  :global(.paper-detail-section-title) {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 0.5rem 0;
  }
  :global(.paper-detail-link) {
    color: var(--color-maroon);
    text-decoration: none;
  }
  :global(.paper-detail-link:hover) {
    text-decoration: underline;
  }
  :global(.paper-detail-motivation) {
    margin: 0;
    color: var(--color-ink-muted);
    line-height: 1.6;
  }
  :global(.paper-detail-tags) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  :global(.paper-detail-tag) {
    padding: 0.25rem 0.6rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-size: 0.875rem;
  }
  :global(.paper-detail-citations) {
    margin: 0;
    font-size: 1rem;
  }
  :global(.paper-detail-model-links-intro),
  :global(.paper-detail-field-links-intro) {
    margin: 0 0 0.75rem 0;
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    line-height: 1.5;
  }
  :global(.paper-detail-model-links),
  :global(.paper-detail-field-links) {
    padding: 1rem 1.25rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }
  :global(.paper-detail-model-links-setup),
  :global(.paper-detail-field-links-setup) {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-ink-muted);
  }
  :global(.paper-detail-model-links-error),
  :global(.paper-detail-field-links-error) {
    color: var(--color-error, #b91c1c);
    font-size: 0.875rem;
    margin: 0 0 0.75rem 0;
  }
  :global(.paper-detail-model-links-label),
  :global(.paper-detail-field-links-label) {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 0.35rem;
    color: var(--color-ink);
  }
  :global(.paper-detail-model-links-row),
  :global(.paper-detail-field-links-row) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }
  :global(.paper-detail-model-links-select),
  :global(.paper-detail-field-links-select) {
    flex: 1;
    min-width: 200px;
    padding: 0.5rem 0.65rem;
    border: 2px solid var(--color-border);
    border-radius: 8px;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    background: #fff;
  }
  :global(.paper-detail-model-links-select:focus),
  :global(.paper-detail-field-links-select:focus) {
    outline: none;
    border-color: var(--color-maroon);
  }
  :global(.paper-detail-model-links-add),
  :global(.paper-detail-field-links-add) {
    padding: 0.5rem 1rem;
    background: var(--color-maroon);
    color: #fff;
    border: 2px solid var(--color-gold);
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
  }
  :global(.paper-detail-model-links-add:disabled),
  :global(.paper-detail-field-links-add:disabled) {
    opacity: 0.55;
    cursor: not-allowed;
  }
  :global(.paper-detail-model-links-loading),
  :global(.paper-detail-field-links-loading) {
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    margin: 0.5rem 0 0 0;
  }
  :global(.paper-detail-model-links-empty),
  :global(.paper-detail-field-links-empty) {
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    margin: 0.5rem 0 0 0;
  }
  :global(.paper-detail-model-links-list),
  :global(.paper-detail-field-links-list) {
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0 0;
  }
  :global(.paper-detail-model-links-item),
  :global(.paper-detail-field-links-item) {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.5rem 0;
    border-top: 1px solid var(--color-border);
    font-size: 0.9rem;
    line-height: 1.45;
  }
  :global(.paper-detail-model-links-item:first-child),
  :global(.paper-detail-field-links-item:first-child) {
    border-top: none;
    padding-top: 0;
  }
  :global(.paper-detail-model-links-model),
  :global(.paper-detail-field-links-name) {
    color: var(--color-maroon);
    font-weight: 600;
    text-decoration: none;
    flex: 1;
  }
  :global(.paper-detail-model-links-model:hover),
  :global(.paper-detail-field-links-name:hover) {
    text-decoration: underline;
  }
  :global(.paper-detail-model-links-remove),
  :global(.paper-detail-field-links-remove) {
    flex-shrink: 0;
    padding: 0.2rem 0.5rem;
    font-size: 0.8rem;
    font-weight: 600;
    border: 1px solid var(--color-border);
    background: #fff;
    border-radius: 6px;
    cursor: pointer;
    color: var(--color-ink-muted);
  }
  :global(.paper-detail-model-links-remove:hover:not(:disabled)),
  :global(.paper-detail-field-links-remove:hover:not(:disabled)) {
    border-color: var(--color-maroon);
    color: var(--color-maroon);
  }
  :global(.paper-detail-field-links-item-main) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    flex: 1;
    min-width: 0;
  }
  :global(.paper-detail-field-links-badge) {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    padding: 0.12rem 0.45rem;
    border-radius: 999px;
    background: #e5e7eb;
    color: #4b5563;
  }
  :global(.paper-detail-field-links-badge-manual) {
    background: rgba(113, 32, 56, 0.1);
    color: var(--color-maroon);
  }
  :global(.paper-detail-comments) {
    padding: 1rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 12px;
  }
  :global(.paper-detail-comments-add) {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }
  :global(.paper-detail-comments-add-fields) {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  :global(.paper-detail-comments-image-tools) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  :global(.paper-detail-comments-file-label) {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    cursor: pointer;
    font-size: 0.85rem;
    color: var(--color-maroon);
    font-weight: 600;
  }
  :global(.paper-detail-comments-file-input) {
    position: absolute;
    width: 0.1px;
    height: 0.1px;
    opacity: 0;
    overflow: hidden;
    z-index: -1;
  }
  :global(.paper-detail-comments-file-text) {
    text-decoration: underline;
  }
  :global(.paper-detail-comments-file-clear) {
    padding: 0.2rem 0.5rem;
    font-size: 0.8rem;
    border: 1px solid var(--color-border);
    background: #fff;
    border-radius: 6px;
    cursor: pointer;
    color: var(--color-ink-muted);
  }
  :global(.paper-detail-comments-file-clear:hover) {
    border-color: var(--color-maroon-muted);
    color: var(--color-maroon);
  }
  :global(.paper-detail-comments-preview-wrap) {
    margin-top: 0.25rem;
  }
  :global(.paper-detail-comments-preview) {
    max-width: 100%;
    max-height: 200px;
    width: auto;
    height: auto;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    object-fit: contain;
    display: block;
  }
  :global(.paper-detail-comments-image-link) {
    display: block;
    margin: 0.35rem 0 0.25rem 0;
  }
  :global(.paper-detail-comments-image) {
    max-width: 100%;
    max-height: 280px;
    width: auto;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    object-fit: contain;
    display: block;
  }
  :global(.paper-detail-comments-input) {
    width: 100%;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    padding: 0.6rem 0.75rem;
    font-size: 0.92rem;
    resize: vertical;
    background: #fff;
    color: var(--color-ink);
    min-height: 3rem;
  }
  :global(.paper-detail-comments-input:focus) {
    outline: none;
    border-color: var(--color-maroon);
    box-shadow: 0 0 0 2px rgba(113, 32, 56, 0.12);
  }
  :global(.paper-detail-comments-btn) {
    padding: 0.5rem 0.95rem;
    background: var(--color-maroon);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
  }
  :global(.paper-detail-comments-btn:hover:not(:disabled)) {
    background: var(--color-maroon-dark);
  }
  :global(.paper-detail-comments-btn:disabled) {
    opacity: 0.6;
    cursor: not-allowed;
  }
  :global(.paper-detail-comments-error) {
    margin: 0 0 0.5rem 0;
    font-size: 0.9rem;
    color: var(--color-error, #b91c1c);
  }
  :global(.paper-detail-comments-empty) {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-ink-muted);
  }
  :global(.paper-detail-comments-list) {
    margin: 0.35rem 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  :global(.paper-detail-comments-item) {
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: #fff;
  }
  :global(.paper-detail-comments-content) {
    margin: 0 0 0.25rem 0;
    color: var(--color-ink);
    line-height: 1.45;
    white-space: pre-wrap;
  }
  :global(.paper-detail-comments-time) {
    font-size: 0.8rem;
    color: var(--color-ink-muted);
  }
  :global(.paper-detail-apa-section) {
    margin-top: 2rem;
    padding: 1.25rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 12px;
  }
  :global(.paper-detail-apa-hint) {
    margin: 0 0 0.75rem 0;
    font-size: 0.9rem;
    color: var(--color-ink-muted);
  }
  :global(.paper-detail-apa-box) {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  :global(.paper-detail-apa-output) {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    line-height: 1.5;
    padding: 1rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    white-space: pre-wrap;
    word-break: break-word;
  }
  :global(.paper-detail-apa-copy) {
    align-self: flex-start;
    padding: 0.5rem 1rem;
    background: var(--color-maroon);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-weight: 500;
    cursor: pointer;
  }
  :global(.paper-detail-apa-copy:hover) {
    background: var(--color-maroon-dark);
  }
  :global(.paper-detail-created) {
    margin-top: 2rem;
    font-size: 0.875rem;
    color: var(--color-ink-muted);
  }
  :global(.paper-detail-summary) {
    padding: 1.25rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 12px;
  }
  :global(.paper-detail-summary-header) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  :global(.paper-detail-summary-header-actions) {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: center;
  }
  :global(.paper-detail-summary-loading),
  :global(.paper-detail-summary-empty),
  :global(.paper-detail-summary-generating) {
    margin: 0 0 0.75rem 0;
    font-size: 0.9rem;
    color: var(--color-ink-muted);
  }
  :global(.paper-detail-summary-error) {
    margin: 0 0 0.75rem 0;
    font-size: 0.9rem;
    color: var(--color-error, #b91c1c);
  }
  :global(.paper-detail-summary-btn) {
    padding: 0.5rem 1rem;
    background: var(--color-maroon);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-weight: 500;
    cursor: pointer;
  }
  :global(.paper-detail-summary-btn.paper-detail-summary-btn-secondary) {
    background: #fff;
    color: var(--color-maroon);
    border: 1px solid var(--color-border);
  }
  :global(.paper-detail-summary-btn:hover:not(:disabled)) {
    opacity: 0.9;
  }
  :global(.paper-detail-summary-btn:disabled) {
    opacity: 0.6;
    cursor: not-allowed;
  }
  :global(.paper-detail-summary-editor) {
    padding: 1rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    margin-bottom: 0.75rem;
  }
  :global(.paper-detail-summary-label) {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    margin-bottom: 0.75rem;
  }
  :global(.paper-detail-summary-textarea) {
    width: 100%;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    padding: 0.6rem 0.7rem;
    font-size: 0.9rem;
    resize: vertical;
    background: #fff;
    color: var(--color-ink);
  }
  :global(.paper-detail-summary-editor-actions) {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }
  :global(.paper-detail-summary-fields) {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  :global(.paper-detail-summary-fields-edit) {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(240px, 340px);
    gap: 1rem 1.5rem;
    align-items: start;
  }
  :global(.paper-detail-summary-fields-edit .paper-detail-summary-fields-main),
  :global(.paper-detail-summary-fields-edit .paper-detail-summary-fields-side) {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-width: 0;
  }
  :global(.paper-detail-summary-layout) {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(240px, 340px);
    gap: 1rem 1.75rem;
    align-items: start;
  }
  :global(.paper-detail-summary-col-main),
  :global(.paper-detail-summary-col-side) {
    min-width: 0;
  }
  :global(.paper-detail-summary-col-side) {
    position: sticky;
    top: 0.75rem;
    padding: 0.75rem 1rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    align-self: start;
  }
  :global(.paper-detail-summary-col-side .paper-detail-summary-block) {
    padding: 0.65rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  :global(.paper-detail-summary-col-side .paper-detail-summary-block:last-child) {
    border-bottom: none;
    padding-bottom: 0;
  }
  @media (max-width: 900px) {
    :global(.paper-detail-summary-layout),
    :global(.paper-detail-summary-fields-edit) {
      grid-template-columns: 1fr;
    }
    :global(.paper-detail-summary-col-side) {
      position: static;
    }
  }
  :global(.paper-detail-summary-grid) {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  :global(.paper-detail-summary-col-main .paper-detail-summary-grid) {
    gap: 0;
  }
  :global(.paper-detail-summary-block) {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  :global(.paper-detail-summary-col-main .paper-detail-summary-block:last-child) {
    border-bottom: none;
  }
  :global(.paper-detail-summary-block:last-child) {
    border-bottom: none;
  }
  :global(.paper-detail-summary-heading) {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-maroon);
    margin: 0 0 0.35rem 0;
  }
  :global(.paper-detail-summary-text) {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--color-ink);
    word-break: break-word;
  }
  :global(.paper-detail-summary-rich) {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  :global(.paper-detail-summary-paragraph) {
    margin: 0;
  }
  :global(.paper-detail-summary-list) {
    margin: 0;
    padding-left: 1.25rem;
    list-style-position: outside;
  }
  :global(.paper-detail-summary-list.paper-detail-summary-list-ul) {
    list-style-type: disc !important;
  }
  :global(.paper-detail-summary-list.paper-detail-summary-list-ol) {
    list-style-type: decimal !important;
  }
  :global(.paper-detail-summary-list li) {
    display: list-item;
    margin: 0.1rem 0;
  }
  :global(.paper-detail-summary-sublist) {
    margin-top: 0.2rem;
  }
  :global(.paper-detail-summary-bullet-block) {
    margin: 0;
  }
  :global(.summary-narration) {
    margin: 0 0 1.25rem 0;
    padding: 1rem 1.1rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    border-left: 4px solid var(--color-gold);
  }
  :global(.summary-narration-header) {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 0.85rem;
  }
  :global(.summary-narration-icon) {
    font-size: 1.5rem;
    line-height: 1;
  }
  :global(.summary-narration-meta) {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  :global(.summary-narration-title) {
    font-size: 0.95rem;
    color: var(--color-maroon);
  }
  :global(.summary-narration-sub) {
    font-size: 0.8rem;
    color: var(--color-ink-muted);
  }
  :global(.summary-narration-error) {
    margin: 0 0 0.65rem 0;
    font-size: 0.85rem;
    color: var(--color-error, #b91c1c);
  }
  :global(.summary-narration-hint) {
    margin: 0 0 0.65rem 0;
    font-size: 0.85rem;
    color: var(--color-ink-muted);
  }
  :global(.summary-narration-controls) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  :global(.summary-narration-btn) {
    padding: 0.5rem 1rem;
    border-radius: 8px;
    font-weight: 500;
    font-size: 0.9rem;
    cursor: pointer;
    border: none;
  }
  :global(.summary-narration-btn-primary) {
    background: var(--color-maroon);
    color: #fff;
  }
  :global(.summary-narration-btn-secondary) {
    background: #fff;
    color: var(--color-maroon);
    border: 1px solid var(--color-border);
  }
  :global(.summary-narration-btn:disabled) {
    opacity: 0.6;
    cursor: not-allowed;
  }
  :global(.summary-narration-progress) {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  :global(.summary-narration-seek) {
    width: 100%;
    accent-color: var(--color-maroon);
  }
  :global(.summary-narration-time) {
    font-size: 0.8rem;
