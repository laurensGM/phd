---
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Writing"
  description="Words, argumentation, humanizing prose, layered revision, and systematic literature review guidance."
>
  <h1>Writing</h1>
  <p class="page-desc">
    Quick links to word lists, academic argument, humanizing your draft, layered revision, and your SLR notes and process.
  </p>

  <div class="rq-hub-grid">
    <a href={`${base}tools/writing/`} class="rq-hub-card">
      <span class="rq-hub-icon" aria-hidden="true">✍️</span>
      <h2 class="rq-hub-title">Words</h2>
      <p class="rq-hub-desc">Adverbs, phrases, and reporting verbs for structure, contrast, and stance.</p>
      <span class="rq-hub-link">Open words →</span>
    </a>
    <a href={`${base}writing/revise-and-edit/`} class="rq-hub-card">
      <span class="rq-hub-icon" aria-hidden="true">📐</span>
      <h2 class="rq-hub-title">Revise and edit</h2>
      <p class="rq-hub-desc">Revise from global message down to sentences—one layer at a time.</p>
      <span class="rq-hub-link">Open revise and edit →</span>
    </a>
    <a href={`${base}writing/argument/`} class="rq-hub-card">
      <span class="rq-hub-icon" aria-hidden="true">⚖️</span>
      <h2 class="rq-hub-title">Argument</h2>
      <p class="rq-hub-desc">Talk-show metaphor, Toulmin elements, counterarguments, and writing steps.</p>
      <span class="rq-hub-link">Open argument →</span>
    </a>
    <a
      href={`${base}writing/humanize/`}
      class="rq-hub-card"
      data-requires-permission="writing.humanize"
    >
      <span class="rq-hub-icon" aria-hidden="true">📝</span>
      <h2 class="rq-hub-title">Humanize</h2>
      <p class="rq-hub-desc">Citation rhythm, short sentences, authorial voice, and other anti-AI-prose checks.</p>
      <span class="rq-hub-link">Open humanize →</span>
    </a>
    <a href={`${base}slr/`} class="rq-hub-card">
      <span class="rq-hub-icon" aria-hidden="true">📋</span>
      <h2 class="rq-hub-title">SLR</h2>
      <p class="rq-hub-desc">Systematic literature review — scope, process, and guidance.</p>
      <span class="rq-hub-link">Open SLR →</span>
    </a>
    <a
      href={`${base}writing/lr-process/`}
      class="rq-hub-card"
      data-requires-permission="writing.lr_process"
    >
      <span class="rq-hub-icon" aria-hidden="true">🔄</span>
      <h2 class="rq-hub-title">LR process</h2>
      <p class="rq-hub-desc">End-to-end literature workflow — discover, read, snippets, claims, synthesize, and writing.</p>
      <span class="rq-hub-link">Open LR process →</span>
    </a>
  </div>
</BaseLayout>

<style>
  .page-desc {
    color: var(--color-ink-muted);
    margin-bottom: 2rem;
    line-height: 1.6;
    max-width: 40rem;
  }
  .rq-hub-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .rq-hub-card {
    display: flex;
    flex-direction: column;
    padding: 2rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    border-left: 4px solid var(--color-maroon);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .rq-hub-card:hover {
    border-color: var(--color-maroon-muted);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    text-decoration: none;
    color: inherit;
  }
  .rq-hub-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }
  .rq-hub-title {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    margin: 0 0 0.5rem 0;
    color: var(--color-maroon);
  }
  .rq-hub-desc {
    flex: 1;
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--color-ink);
  }
  .rq-hub-link {
    margin-top: 1rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-maroon);
  }
</style>
