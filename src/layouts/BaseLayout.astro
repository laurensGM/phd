---
import AuthBar from '../components/AuthBar';

interface Props {
  title: string;
  description?: string;
  /** Keep the logo spinner until client content calls PhDLoader.hide / usePageLoader. */
  deferLoader?: boolean;
  /** Navbar colour theme — admin uses dark blue. */
  navTheme?: 'default' | 'admin';
}

const {
  title,
  description = "PhD Manager - Organizing research, models, constructs, and literature",
  deferLoader = false,
  navTheme = 'default',
} = Astro.props;
const base = import.meta.env.BASE_URL;
// Home link: use path-relative URL so it always resolves to this app's root (avoids going to portfolio when base is wrong)
const pathname = (Astro.url.pathname || '/').replace(/\/$/, '') || '/';
const pathSegments = pathname.split('/').filter(Boolean);
const baseSegments = base.replace(/\/$/, '').split('/').filter(Boolean);
const baseDepth = baseSegments.length;
const upLevels = Math.max(0, pathSegments.length - baseDepth);
const homeHref = upLevels === 0 ? (base || './') : '../'.repeat(upLevels);
const isAdminNav = navTheme === 'admin';
---

<!DOCTYPE html>
<html lang="en" data-defer-loader={deferLoader ? 'true' : undefined} data-nav-theme={navTheme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content={isAdminNav ? '#1e3a5f' : '#712038'} />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="PhD Manager" />
    <link rel="icon" type="image/jpeg" href={`${base}logo-pos-browser.jpeg`} />
    <link rel="apple-touch-icon" href={`${base}pwa-192x192.png`} />
    <link rel="manifest" href={`${base}manifest.webmanifest`} />
    <meta name="description" content={description} />
    <title>{title} | PhD Manager</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400;0,600;1,400&family=DM+Sans:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div id="page-loader" class="page-loader" role="status" aria-live="polite" aria-label="Loading">
      <svg
        class="page-loader-logo"
        viewBox="0 0 120 100"
        fill="none"
        aria-hidden="true"
      >
        <path
          class="cap-line cap-board"
          pathLength="100"
          d="M60 8 L114 34 L60 60 L6 34 Z"
        />
        <path
          class="cap-line cap-band"
          pathLength="100"
          d="M30 46 L33 72 Q34 80 44 80 L76 80 Q86 80 87 72 L90 46"
        />
        <path
          class="cap-line cap-string"
          pathLength="100"
          d="M110 37 L110 65"
        />
        <circle
          class="cap-line cap-knot"
          pathLength="100"
          cx="110"
          cy="69"
          r="4"
        />
        <path
          class="cap-line cap-tassel"
          pathLength="100"
          d="M104 73 L110 92 L116 73"
        />
      </svg>
      <span class="page-loader-text">Loading…</span>
    </div>
    <header class={`site-header${isAdminNav ? ' site-header-admin' : ''}`}>
      <nav class="nav-container">
        <a href={homeHref} class="logo" rel="home" aria-label="Home – PhD Manager">
          <img src={`${base}logo-pos.png`} alt="PhD Manager" class="logo-img" width="48" height="48" />
          <span class="logo-text">{isAdminNav ? 'PhD Admin' : 'PhD Manager'}</span>
        </a>
        <button
          type="button"
          class="nav-toggle"
          aria-expanded="false"
          aria-controls="nav-menu"
          aria-label="Open menu"
        >
          <span class="nav-toggle-bar" aria-hidden="true"></span>
          <span class="nav-toggle-bar" aria-hidden="true"></span>
          <span class="nav-toggle-bar" aria-hidden="true"></span>
        </button>
        <ul class="nav-links" id="nav-menu">
          <li class="nav-dropdown-wrap">
            <a
              href={`${base}literature/`}
              class="nav-dropdown-trigger"
              id="literature-trigger"
              aria-haspopup="true"
            >Literature</a>
            <ul class="nav-dropdown" aria-labelledby="literature-trigger">
              <li><a href={`${base}papers/`}>Papers</a></li>
              <li><a href={`${base}models/`}>Models</a></li>
              <li><a href={`${base}constructs/`}>Constructs</a></li>
              <li><a href={`${base}fields/`}>Fields</a></li>
              <li><a href={`${base}snippets/`}>Snippets</a></li>
              <li><a href={`${base}claims/`}>Claims</a></li>
              <li><a href={`${base}academics/`}>Academics</a></li>
              <li><a href={`${base}theory-map/`}>Theory Map</a></li>
            </ul>
          </li>
          <li class="nav-dropdown-wrap">
            <a
              href={`${base}writing/`}
              class="nav-dropdown-trigger"
              id="writing-trigger"
              aria-haspopup="true"
            >Writing</a>
            <ul class="nav-dropdown" aria-labelledby="writing-trigger">
              <li><a href={`${base}tools/writing/`}>Words</a></li>
              <li><a href={`${base}writing/revise-and-edit/`}>Revise and edit</a></li>
              <li><a href={`${base}writing/argument/`}>Argument</a></li>
              <li><a href={`${base}writing/humanize/`}>Humanize</a></li>
              <li><a href={`${base}slr/`}>SLR</a></li>
              <li><a href={`${base}writing/lr-process/`}>LR process</a></li>
            </ul>
          </li>
          <li class="nav-dropdown-wrap">
            <a
              href={`${base}methods/`}
              class="nav-dropdown-trigger"
              id="methods-trigger"
              aria-haspopup="true"
            >Methods</a>
            <ul class="nav-dropdown" aria-labelledby="methods-trigger">
              <li><a href={`${base}methods/qual-vs-quant/`}>Qual vs Quant</a></li>
              <li><a href={`${base}methods/quant/`}>Quant</a></li>
              <li><a href={`${base}methods/qual/`}>Qual</a></li>
              <li><a href={`${base}methods/secondary-data/`}>Secondary data</a></li>
              <li><a href={`${base}methods/sampling/`}>Sampling</a></li>
              <li><a href={`${base}methods/theory-maturity/`}>Theory maturity</a></li>
              <li><a href={`${base}methods/uoa/`}>UoA</a></li>
              <li><a href={`${base}methods/ethics/`}>Ethics</a></li>
            </ul>
          </li>
          <li class="nav-dropdown-wrap">
            <a
              href={`${base}research-questions/`}
              class="nav-dropdown-trigger"
              id="rq-trigger"
              aria-haspopup="true"
            >Research</a>
            <ul class="nav-dropdown" aria-labelledby="rq-trigger">
              <li><a href={`${base}research-questions/process/`}>Process</a></li>
              <li><a href={`${base}research-questions/proposal/`}>Proposal</a></li>
              <li><a href={`${base}research-questions/paradigms/`}>Paradigms</a></li>
              <li><a href={`${base}research-questions/questions/`}>Questions</a></li>
              <li><a href={`${base}research-questions/objectives/`}>Objectives</a></li>
              <li><a href={`${base}research-questions/contribution/`}>Contribution</a></li>
              <li><a href={`${base}research-questions/must-dos/`}>10 must do&rsquo;s</a></li>
            </ul>
          </li>
          <li class="nav-dropdown-wrap">
            <a
              href={`${base}tools/`}
              class="nav-dropdown-trigger"
              id="tools-trigger"
              aria-haspopup="true"
            >Tools</a>
            <ul class="nav-dropdown" aria-labelledby="tools-trigger">
              <li><a href={`${base}tools/ai/`}>AI tools</a></li>
              <li><a href={`${base}tools/databases/`}>Databases</a></li>
              <li><a href={`${base}tools/golden-nuggets/`}>Golden nuggets</a></li>
              <li><a href={`${base}tools/faq/`}>FAQ</a></li>
              <li><a href={`${base}tools/memes/`}>Memes</a></li>
            </ul>
          </li>
          <li class="nav-dropdown-wrap">
            <a
              href={`${base}outline/`}
              class="nav-dropdown-trigger"
              id="phd-manager-trigger"
              aria-haspopup="true"
            >Manager</a>
            <ul class="nav-dropdown" aria-labelledby="phd-manager-trigger">
              <li><a href={`${base}outline/`}>PhD milestones</a></li>
              <li><a href={`${base}phd-outline/`}>PhD outline</a></li>
              <li><a href={`${base}diary/`}>Diary</a></li>
              <li><a href={`${base}tasks/`}>Tasks</a></li>
              <li><a href={`${base}meeting-notes/`}>Meeting notes</a></li>
              <li><a href={`${base}supervisor/`}>Supervisor</a></li>
              <li><a href={`${base}members/`}>Members</a></li>
            </ul>
          </li>
          <li class="nav-admin-link-slot" id="nav-admin-slot" hidden>
            <a href={`${base}admin/`} class="nav-admin-link">Admin</a>
          </li>
        </ul>
        <div id="auth-bar-root" class="nav-auth">
          <AuthBar client:load />
        </div>
      </nav>
    </header>
    <main class="main-content">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-brand">
        <img src={`${base}logo-pos.png`} alt="PhD Manager" class="footer-logo" width="32" height="32" />
        <div>
          <p class="footer-title">PhD Manager</p>
        </div>
      </div>
      <p class="footer-tagline">Organizing research one snippet at a time</p>
    </footer>
    <script is:inline>
      (function () {
        var loader = document.getElementById('page-loader');
        if (!loader) return;
        var MIN_SHOW = 450;
        var MAX_DEFER_MS = 15000;
        var startedAt = Date.now();
        var pending = 0;
        var hideTimer = null;
        var deferred = document.documentElement.getAttribute('data-defer-loader') === 'true';

        function applyHidden(hidden) {
          if (hideTimer) {
            window.clearTimeout(hideTimer);
            hideTimer = null;
          }
          if (hidden) {
            var elapsed = Date.now() - startedAt;
            var wait = Math.max(0, MIN_SHOW - elapsed);
            hideTimer = window.setTimeout(function () {
              if (pending > 0) return;
              loader.classList.add('is-hidden');
            }, wait);
          } else {
            startedAt = Date.now();
            loader.classList.remove('is-hidden');
          }
        }

        function showLoader() {
          pending += 1;
          applyHidden(false);
        }

        function hideLoader() {
          pending = Math.max(0, pending - 1);
          if (pending === 0) applyHidden(true);
        }

        function readyLoader() {
          pending = 0;
          deferred = false;
          document.documentElement.removeAttribute('data-defer-loader');
          applyHidden(true);
        }

        window.PhDLoader = {
          show: showLoader,
          hide: hideLoader,
          ready: readyLoader,
        };

        function maybeHideAfterShellLoad() {
          if (deferred) {
            // Keep the visible shell spinner until React content finishes loading.
            window.setTimeout(function () {
              if (!loader.classList.contains('is-hidden')) readyLoader();
            }, MAX_DEFER_MS);
            return;
          }
          applyHidden(true);
        }

        if (document.readyState === 'complete') {
          maybeHideAfterShellLoad();
        } else {
          window.addEventListener('load', maybeHideAfterShellLoad);
        }

        // Show the loader while navigating to another internal page.
        document.addEventListener('click', function (e) {
          if (e.defaultPrevented || e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
          var link = e.target && e.target.closest ? e.target.closest('a[href]') : null;
          if (!link) return;
          if (link.target && link.target !== '_self') return;
          if (link.hasAttribute('download')) return;
          var href = link.getAttribute('href');
          if (!href || href.charAt(0) === '#') return;
          var url;
          try { url = new URL(link.href, window.location.href); } catch (err) { return; }
          if (url.origin !== window.location.origin) return;
          if (url.pathname === window.location.pathname && url.search === window.location.search) return;
          pending = 0;
          showLoader();
        });

        window.addEventListener('beforeunload', function () {
          pending = 0;
          showLoader();
        });

        window.addEventListener('pageshow', function (e) {
          if (e.persisted) {
            pending = 0;
            applyHidden(true);
          }
        });
      })();
    </script>
    <script src={`${base}registerSW.js`} defer></script>
    <script is:inline>
      (function () {
        if (!('serviceWorker' in navigator)) return;
        var reloaded = false;
        navigator.serviceWorker.addEventListener('controllerchange', function () {
          if (reloaded) return;
          reloaded = true;
          window.location.reload();
        });
        navigator.serviceWorker.ready.then(function (reg) {
          reg.update();
          if (reg.waiting) reg.waiting.postMessage({ type: 'SKIP_WAITING' });
        });
      })();
    </script>
    <script is:inline>
      (function () {
        var header = document.querySelector('.site-header');
        var toggle = document.querySelector('.nav-toggle');
        var menu = document.getElementById('nav-menu');
        if (!header || !toggle || !menu) return;

        function setOpen(open) {
          header.classList.toggle('nav-open', open);
          toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
          toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
        }

        toggle.addEventListener('click', function () {
          setOpen(!header.classList.contains('nav-open'));
        });

        menu.querySelectorAll('a').forEach(function (link) {
          link.addEventListener('click', function () {
            setOpen(false);
          });
        });

        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') setOpen(false);
        });

        window.matchMedia('(min-width: 769px)').addEventListener('change', function (e) {
          if (e.matches) setOpen(false);
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  :root {
    /* Stellenbosch Business School branding (aligned with logo) */
    --color-bg: #F8F5F2;
    --color-bg-alt: #EDE8E2;
    --color-ink: #2D1F24;
    --color-ink-muted: #5C4A4F;
    --color-maroon: #712038;
    --color-maroon-dark: #4A1925;
    --color-maroon-muted: #9C416B;
    --color-gold: #D4AF37;
    --color-gold-light: #E5C65C;
    --color-gold-dark: #8B704C;
    --color-accent: #712038;
    --color-accent-hover: #4A1925;
    --color-border: #E0D6CC;
    --font-serif: 'Crimson Pro', Georgia, serif;
    --font-sans: 'DM Sans', system-ui, sans-serif;
    --shadow-sm: 0 1px 3px rgba(45, 31, 36, 0.06);
    --shadow-md: 0 4px 12px rgba(45, 31, 36, 0.08);
  }

  * {
    box-sizing: border-box;
  }

  /* Page loading overlay: traces the logo outline */
  .page-loader {
    position: fixed;
    inset: 0;
    z-index: 2000;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    background: var(--color-bg);
    opacity: 1;
    visibility: visible;
    transition: opacity 0.35s ease, visibility 0.35s ease;
  }

  .page-loader.is-hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .page-loader-logo {
    width: 120px;
    height: 100px;
  }

  .page-loader-text {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-maroon);
    opacity: 0.75;
  }

  .cap-line {
    fill: none;
    stroke: var(--color-gold);
    stroke-width: 4;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    animation: cap-trace 2s ease-in-out infinite;
  }

  .cap-board { animation-delay: 0s; }
  .cap-band { animation-delay: 0.18s; }
  .cap-string { animation-delay: 0.36s; }
  .cap-knot { animation-delay: 0.48s; }
  .cap-tassel { animation-delay: 0.56s; }

  @keyframes cap-trace {
    0% { stroke-dashoffset: 100; }
    45% { stroke-dashoffset: 0; }
    75% { stroke-dashoffset: 0; }
    100% { stroke-dashoffset: -100; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cap-line {
      animation: cap-pulse 1.4s ease-in-out infinite;
      stroke-dashoffset: 0;
    }
    @keyframes cap-pulse {
      0%, 100% { opacity: 0.35; }
      50% { opacity: 1; }
    }
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-ink);
    background: var(--color-bg);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .site-header {
    background: var(--color-maroon);
    color: white;
    padding: 0.75rem 1.5rem;
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 3px solid var(--color-gold);
  }

  .site-header-admin {
    background: #1e3a5f;
    border-bottom-color: #7eb6e8;
  }
  .site-header-admin .logo-text {
    color: #9ec9f0;
  }
  .site-header-admin .nav-avatar {
    background: #2a4a73;
    border-color: #7eb6e8;
  }
  .site-header-admin .nav-avatar:hover,
  .site-header-admin .nav-avatar:focus-visible {
    background: #355a88;
    box-shadow: 0 0 0 3px rgba(126, 182, 232, 0.35);
  }
  .site-header-admin .nav-sign-in {
    color: #9ec9f0;
    border-color: rgba(126, 182, 232, 0.55);
  }
  .site-header-admin .nav-links a:hover,
  .site-header-admin a.nav-dropdown-trigger:hover {
    color: #cfe6f8;
    background: rgba(255, 255, 255, 0.1);
  }
  .nav-admin-link {
    color: #9ec9f0 !important;
    font-weight: 700;
    border: 1px solid rgba(126, 182, 232, 0.45);
    border-radius: 999px;
    padding: 0.35rem 0.75rem !important;
  }
  .site-header:not(.site-header-admin) .nav-admin-link {
    color: #c5d9f0 !important;
    border-color: rgba(197, 217, 240, 0.4);
    background: rgba(30, 58, 95, 0.35);
  }
  .site-header:not(.site-header-admin) .nav-admin-link:hover {
    background: rgba(30, 58, 95, 0.55) !important;
    color: #fff !important;
  }
  .site-header-admin .nav-admin-link {
    background: rgba(255, 255, 255, 0.1);
  }
  .site-header-admin .nav-admin-link:hover {
    background: rgba(255, 255, 255, 0.18) !important;
    color: #fff !important;
  }

  .nav-profile-menu-admin {
    color: #1e3a5f;
    font-weight: 600;
  }

  .admin-lead {
    color: var(--color-ink-muted);
    max-width: 42rem;
    line-height: 1.5;
    margin: 0 0 1.25rem;
  }
  .admin-muted {
    color: var(--color-ink-muted);
    font-size: 0.9rem;
  }
  .admin-banner {
    margin: 0.85rem 0 0;
    padding: 0.65rem 0.8rem;
    border-radius: 8px;
    font-size: 0.9rem;
    line-height: 1.45;
  }
  .admin-banner-ok {
    background: #ecfdf5;
    color: #065f46;
    border: 1px solid #a7f3d0;
  }
  .admin-banner-warn {
    background: #fff7ed;
    color: #9a3412;
    border: 1px solid #fed7aa;
  }
  .admin-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: #fff;
    margin-bottom: 1.75rem;
  }
  .admin-perm-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    font-size: 0.82rem;
    min-width: 720px;
  }
  .admin-perm-table th,
  .admin-perm-table td {
    padding: 0.65rem 0.55rem;
    border-bottom: 1px solid var(--color-border);
    text-align: center;
    vertical-align: middle;
  }
  .admin-perm-table thead th {
    background: #1e3a5f;
    color: #fff;
    font-weight: 600;
    position: sticky;
    top: 0;
    z-index: 2;
  }
  .admin-perm-table thead th.admin-perm-sticky {
    text-align: left;
    left: 0;
    z-index: 3;
  }
  .admin-perm-sticky {
    position: sticky;
    left: 0;
    background: #fff;
    text-align: left;
    z-index: 1;
    min-width: 9.5rem;
    box-shadow: 2px 0 6px rgba(0, 0, 0, 0.04);
  }
  .admin-perm-table tbody th.admin-perm-sticky {
    background: #f4f7fb;
  }
  .admin-perm-col-label {
    display: inline-block;
    max-width: 6.5rem;
    white-space: normal;
    line-height: 1.25;
    font-size: 0.72rem;
  }
  .admin-role-name {
    font-weight: 700;
    color: #1e3a5f;
    font-size: 0.9rem;
  }
  .admin-role-hint {
    font-weight: 400;
    font-size: 0.72rem;
    color: var(--color-ink-muted);
    margin-top: 0.15rem;
  }
  .admin-check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }
  .admin-check input {
    width: 1.05rem;
    height: 1.05rem;
    accent-color: #1e3a5f;
    cursor: pointer;
  }
  .admin-perm-legend h2 {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    color: #1e3a5f;
    margin: 0 0 0.75rem;
  }
  .admin-perm-cat {
    margin-bottom: 1rem;
  }
  .admin-perm-cat h3 {
    font-size: 0.95rem;
    margin: 0 0 0.35rem;
    color: var(--color-maroon);
  }
  .admin-perm-cat ul {
    margin: 0;
    padding-left: 1.1rem;
    line-height: 1.55;
    font-size: 0.88rem;
  }

  .nav-auth {
    flex-shrink: 0;
    margin-left: 0.75rem;
    display: flex;
    align-items: center;
    min-width: 2.25rem;
    min-height: 2.25rem;
  }

  .nav-profile {
    position: relative;
  }

  .nav-sign-in {
    color: var(--color-gold);
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
    padding: 0.4rem 0.7rem;
    border-radius: 999px;
    border: 1px solid rgba(212, 175, 55, 0.55);
    white-space: nowrap;
  }
