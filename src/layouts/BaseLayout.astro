  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-family: var(--font-sans);
    font-size: 1.2rem;
    font-weight: 700;
    color: #fff;
    text-decoration: none;
    padding: 0.2rem 0.5rem;
    border-radius: 6px;
    transition: color 0.2s ease, background 0.2s ease;
  }

  .logo:hover {
    color: var(--color-gold-light);
    background: rgba(255, 255, 255, 0.12);
    text-decoration: none;
  }

  .logo:hover .logo-img {
    opacity: 0.95;
  }

  .logo-img {
    flex-shrink: 0;
    height: 48px;
    width: auto;
    object-fit: contain;
  }

  .logo-text {
    white-space: nowrap;
    color: var(--color-gold); /* #D4AF37 */
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 1;
  }

  .nav-links a {
    color: rgba(255, 255, 255, 0.92);
    text-decoration: none;
    font-size: 0.9rem;
    padding: 0.4rem 0.65rem;
    border-radius: 6px;
    transition: color 0.2s ease, background 0.2s ease;
  }

  .nav-links a:hover {
    color: var(--color-gold-light);
    background: rgba(255, 255, 255, 0.12);
    text-decoration: none;
  }

  .nav-dropdown-wrap {
    position: relative;
    list-style: none;
  }

  .nav-dropdown-trigger {
    display: inline-block;
    color: rgba(255, 255, 255, 0.92);
    font-size: 0.9rem;
    padding: 0.4rem 0.65rem;
    border-radius: 6px;
    cursor: pointer;
    transition: color 0.2s ease, background 0.2s ease;
    user-select: none;
    text-decoration: none;
  }

  a.nav-dropdown-trigger:hover {
    text-decoration: none;
    color: var(--color-gold-light);
    background: rgba(255, 255, 255, 0.12);
  }

  .nav-dropdown-wrap:hover .nav-dropdown-trigger,
  .nav-dropdown-wrap:focus-within .nav-dropdown-trigger {
    color: var(--color-gold-light);
    background: rgba(255, 255, 255, 0.12);
  }

  .nav-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    margin: 0.25rem 0 0 0;
    padding: 0.35rem 0;
    list-style: none;
    background: var(--color-maroon);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    min-width: 140px;
    box-shadow: var(--shadow-md);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.2s ease, visibility 0.2s ease, transform 0.2s ease;
    z-index: 50;
  }

  .nav-dropdown-wrap:hover .nav-dropdown,
  .nav-dropdown-wrap:focus-within .nav-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .nav-dropdown li {
    margin: 0;
  }

  .nav-dropdown a {
    display: block;
    padding: 0.5rem 1rem;
    color: rgba(255, 255, 255, 0.92);
    font-size: 0.9rem;
    text-decoration: none;
  }

  .nav-dropdown a:hover {
    color: var(--color-gold-light);
    background: rgba(255, 255, 255, 0.12);
    text-decoration: none;
  }

  .main-content {
    flex: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    width: 100%;
  }

  .site-footer {
    background: var(--color-maroon);
    color: var(--color-gold-light);
    padding: 1.25rem 1.5rem;
    text-align: center;
    font-size: 0.85rem;
    border-top: 3px solid var(--color-gold);
  }

  .footer-brand {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .footer-logo {
    opacity: 0.95;
  }

  .footer-title {
    font-weight: 600;
    margin: 0;
    font-size: 0.95rem;
    color: var(--color-gold); /* #D4AF37 */
  }

  .footer-tagline {
    margin: 0;
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.8rem;
  }

  h1, h2, h3 {
    font-family: var(--font-serif);
  }

  h1 { font-size: 2.25rem; margin-bottom: 0.5rem; }
  h2 { font-size: 1.5rem; margin-top: 2rem; margin-bottom: 0.75rem; }
  h3 { font-size: 1.2rem; margin-top: 1.5rem; margin-bottom: 0.5rem; }

  a {
    color: var(--color-maroon);
    text-decoration: none;
  }

  a:hover {
    color: var(--color-maroon-dark);
    text-decoration: underline;
  }

  /* Primary buttons: maroon with gold accent */
  button.diary-add-btn,
  button.diary-submit,
  .link-card {
    border: 1px solid transparent;
  }
  button.diary-add-btn,
  button.diary-submit {
    box-shadow: 0 0 0 1px var(--color-gold);
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0.5rem;
    margin: 0;
    border: 1px solid rgba(255, 255, 255, 0.35);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.08);
    cursor: pointer;
    flex-shrink: 0;
  }

  .nav-toggle:hover,
  .nav-toggle:focus-visible {
    background: rgba(255, 255, 255, 0.16);
    outline: 2px solid var(--color-gold-light);
    outline-offset: 2px;
  }

  .nav-toggle-bar {
    display: block;
    width: 100%;
    height: 2px;
    background: #fff;
    border-radius: 1px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .site-header.nav-open .nav-toggle-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .site-header.nav-open .nav-toggle-bar:nth-child(2) {
    opacity: 0;
  }

  .site-header.nav-open .nav-toggle-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Content-page TOCs: scroll with the page on mobile */
  @media (max-width: 899px) {
    nav[aria-label="On this page"] {
      position: static !important;
      top: auto !important;
      max-height: none !important;
      overflow: visible !important;
    }
  }

  @media (max-width: 768px) {
    .site-header {
      padding: 0.65rem 1rem;
    }

    .nav-toggle {
      display: flex;
    }

    .nav-container {
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .nav-auth {
      margin-left: auto;
      order: 2;
    }

    .nav-toggle {
      order: 3;
      margin-left: 0.35rem;
    }

    .logo {
      order: 1;
    }

    .logo-text {
      font-size: 1.05rem;
    }

    .nav-links {
      display: none;
      flex: 1 1 100%;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      order: 4;
      margin: 0.35rem 0 0;
      padding: 0.25rem 0;
      border-top: 1px solid rgba(255, 255, 255, 0.2);
    }

    .site-header.nav-open .nav-links {
      display: flex;
      max-height: calc(100dvh - 4rem);
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
    }

    .nav-links > li {
      width: 100%;
    }

    .nav-dropdown-wrap {
      width: 100%;
      border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    }

    .nav-dropdown-wrap:last-child {
      border-bottom: none;
    }

    .nav-dropdown-trigger {
      display: block;
      width: 100%;
      padding: 0.85rem 0.5rem;
      font-weight: 600;
    }

    /* Hub links only on mobile — submenus stay on desktop hover */
    .site-header .nav-dropdown,
    .nav-dropdown-wrap:hover .nav-dropdown,
    .nav-dropdown-wrap:focus-within .nav-dropdown {
      display: none !important;
      height: 0 !important;
      max-height: 0 !important;
      overflow: hidden !important;
      padding: 0 !important;
      margin: 0 !important;
      border: none !important;
      visibility: hidden !important;
      opacity: 0 !important;
      pointer-events: none !important;
    }
  }

  /* ECM-IS diagram (on-brand: page background, maroon/gold palette) */
  .ecm-diagram-wrap {
    margin: 1.5rem 0;
    padding: 2rem 1rem;
    background: var(--color-bg);
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .ecm-diagram-title {
    font-size: 1.4rem;
    color: var(--color-ink);
    margin-bottom: 6px;
    text-align: center;
  }
  .ecm-diagram-subtitle {
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    margin-bottom: 2rem;
    text-align: center;
  }
  .ecm-diagram {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    flex-wrap: nowrap;
    width: 100%;
    max-width: 1100px;
    overflow-x: auto;
  }
  .ecm-diagram:has(.ecm-diagram-main-flow) {
    flex-direction: column;
    flex-wrap: wrap;
    overflow-x: visible;
    padding: 0.5rem 0;
  }
  .ecm-box {
    background: #fff;
    border-radius: 12px;
    padding: 18px 16px;
    text-align: center;
    box-shadow: var(--shadow-sm);
    border: 2px solid transparent;
    transition: all 0.2s;
    cursor: pointer;
    min-width: 130px;
    max-width: 150px;
    flex-shrink: 0;
    text-decoration: none;
    color: inherit;
  }
  .ecm-box:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    text-decoration: none;
    color: inherit;
  }
  .ecm-box .ecm-box-label {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    margin-bottom: 6px;
  }
  .ecm-box .ecm-box-name {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--color-ink);
    margin-bottom: 6px;
    line-height: 1.3;
  }
  .ecm-box .ecm-box-desc {
    font-size: 0.72rem;
    color: var(--color-ink-muted);
    line-height: 1.4;
  }
  .ecm-box.prior { border-color: var(--color-maroon-muted); }
  .ecm-box.prior .ecm-box-label { color: var(--color-maroon-muted); }
  .ecm-box.confirm { border-color: var(--color-gold-dark); }
  .ecm-box.confirm .ecm-box-label { color: var(--color-gold-dark); }
  .ecm-box.satisfy { border-color: var(--color-gold); }
  .ecm-box.satisfy .ecm-box-label { color: var(--color-gold); }
  .ecm-box.intention { border-color: var(--color-gold-light); }
  .ecm-box.intention .ecm-box-label { color: var(--color-gold-dark); }
  .ecm-box.behavior { border-color: var(--color-maroon); }
  .ecm-box.behavior .ecm-box-label { color: var(--color-maroon); }
  /* Generic model diagram (TAM2, UTAUT, etc.) – same box styling with category colors */
  .ecm-box.ecm-box--social { border-color: var(--color-maroon-muted); }
  .ecm-box.ecm-box--social .ecm-box-label { color: var(--color-maroon-muted); }
  .ecm-box.ecm-box--cognitive { border-color: var(--color-gold-dark); }
  .ecm-box.ecm-box--cognitive .ecm-box-label { color: var(--color-gold-dark); }
  .ecm-box.ecm-box--neutral { border-color: var(--color-border); }
  .ecm-box.ecm-box--neutral .ecm-box-label { color: var(--color-ink-muted); }
  .ecm-arrow-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .ecm-arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }
  .ecm-arrow-line {
    width: 48px;
    height: 2px;
    background: var(--color-ink-muted);
    position: relative;
  }
  .ecm-arrow-line::after {
    content: '';
    position: absolute;
    right: -6px;
    top: -4px;
    border: 5px solid transparent;
    border-left-color: var(--color-ink-muted);
  }
  .ecm-arrow-label {
    font-size: 0.65rem;
    color: var(--color-ink-muted);
    text-align: center;
    max-width: 60px;
    line-height: 1.2;
    margin-top: 2px;
  }
  .ecm-diagram-main-flow {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0;
  }
  .ecm-fc-row {
    width: 100%;
    display: flex;
    justify-content: center;
    margin-top: 1.5rem;
    padding-top: 0.5rem;
  }
  .ecm-fc-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .ecm-fc-arrow-to-line {
    width: 2px;
    height: 22px;
